{
  "name": "8links-pbn-boilerplate",
  "type": "module",
  "version": "1.0.0",
  "description": "Boilerplate Astro para sites PBN compatíveis com 8links - estrutura de blog com Content Collections",
  "scripts": {
    "dev": "astro dev",
    "dev:full": "concurrently \"bun run dev\" \"bun run capture-api\"",
    "capture-api": "bun run scripts/capture-server.ts",
    "capture-server": "bun run scripts/capture-server.ts",
    "build": "astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^4.16.0"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "@astrojs/vercel": "^7.4.0",
    "@tailwindcss/typography": "^0.5.16",
    "concurrently": "^9.1.0",
    "puppeteer": "^23.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0"
  }
}
