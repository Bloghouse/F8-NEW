---
/**
 * Página Equipe
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-our-team.html
 * Grid de membros da equipe com fotos e cargos.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumb from '../components/PageBreadcrumb.astro';
import { siteConfig } from '../config';
import { IMG_TEAM } from '../lib/porto-images';

const team = [
  { name: 'João Silva', role: 'CEO & Fundador', img: 'img-002.jpg', slug: 'john' },
  { name: 'Maria Santos', role: 'Diretora de Marketing', img: 'img-003.jpg', slug: 'jane' },
  { name: 'Pedro Oliveira', role: 'Diretor de Estratégia', img: 'img-004.jpg', slug: 'mike' },
  { name: 'Ana Costa', role: 'Diretora de Clientes', img: 'img-005.jpg', slug: 'sarah' },
  { name: 'Carlos Mendes', role: 'Diretor Criativo', img: 'img-006.jpg', slug: 'darlene-robertson' },
  { name: 'Lúcia Ferreira', role: 'Gerente de Projetos', img: 'img-007.jpg', slug: 'kristin-watson' },
];
---

<BaseLayout
  title={`Equipe | ${siteConfig.siteName}`}
  description="Conheça a equipe criativa que impulsiona nosso sucesso em marketing."
>
  <article class="porto-equipe">
    <section class="py-12 md:py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-accent-secondary)]">Nossa Equipe</h1>
          <PageBreadcrumb items={[{ label: 'Início', href: '/' }, { label: 'Equipe' }]} />
        </div>
      </div>
    </section>

    <section class="py-12">
      <div class="container mx-auto px-4 max-w-7xl text-center">
        <h2 class="text-2xl md:text-4xl font-bold text-white mb-4">Conheça as mentes <span class="text-[var(--color-accent)]">criativas</span> que impulsionam nosso sucesso em <span class="text-[var(--color-accent-secondary)]">marketing</span></h2>
      </div>
    </section>

    <section class="py-12 pb-24">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {team.map((m) => (
            <a href={`/equipe/${m.slug}`} class="group block">
              <div class="overflow-hidden rounded-xl mb-4">
                <img src={IMG_TEAM(m.img)} alt={m.name} class="w-full aspect-[4/5] object-cover group-hover:scale-105 transition-transform duration-300" />
              </div>
              <h3 class="text-xl font-bold text-white group-hover:text-[var(--color-accent)] transition-colors">{m.name}</h3>
              <p class="text-[var(--color-body-2)]">{m.role}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
