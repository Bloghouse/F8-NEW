---
/**
 * Página Galeria (Grid) - baseada em public/reference/gallery-grid.html/
 * Grid de imagens do template Melanie Hanson
 * Imagens: /reference/gallery-grid.html/images/img-XXX.ext
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const IMG = (f: string) => `/reference/gallery-grid.html/images/${f}`;

const items = [
  { img: 'img-002.jpg', title: 'Como se Amar Mais' },
  { img: 'img-003.jpg', title: 'Como Rastrear Saúde e Perda de Peso' },
  { img: 'img-004.jpg', title: 'Chás Detox Podem Prejudicar Sua Saúde?' },
  { img: 'img-005.jpg', title: '5 Formas de se Sentir Bem no Outono e Inverno' },
  { img: 'img-006.jpg', title: 'Alimentação Saudável' },
  { img: 'img-007.jpg', title: 'Estilo de Vida Ativo' },
  { img: 'img-008.jpg', title: 'Mindfulness' },
  { img: 'img-009.jpg', title: 'Receitas Saudáveis' },
  { img: 'img-010.jpg', title: 'Treinos ao Ar Livre' },
];
---

<BaseLayout
  title={`Galeria | ${siteConfig.siteName}`}
  description="Galeria de fotos e inspirações para um estilo de vida saudável."
>
  <article class="galeria-page">
    <!-- Hero -->
    <section class="py-20 px-6 bg-white text-gray-800">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Galeria</h1>
        <nav class="text-sm text-gray-500">
          <a href="/" class="text-[#efa758] hover:underline">Início</a>
          <span class="mx-2">/</span>
          <span>Galeria</span>
        </nav>
      </div>
    </section>

    <!-- Grid -->
    <section class="py-12 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {items.map((item) => (
            <a href="/blog" class="group block relative overflow-hidden rounded-lg aspect-[4/3]">
              <img src={IMG(item.img)} alt={item.title} class="w-full h-full object-cover group-hover:scale-105 transition duration-300" />
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">
                <span class="text-white font-semibold text-center px-4">{item.title}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <nav class="py-8 px-6 text-center">
      <a href="/" class="text-[#efa758] hover:underline">← Voltar ao Início</a>
    </nav>
  </article>
</BaseLayout>
