---
/**
 * Página Serviços
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-services.html
 * Lista de serviços oferecidos.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumb from '../components/PageBreadcrumb.astro';
import { siteConfig } from '../config';
import { IMG_SERVICES } from '../lib/porto-images';

const services = [
  { title: 'Estratégia', desc: 'Pesquisa de mercado, estratégia de marca, SEO e jornada do cliente.', icon: 'img-001' },
  { title: 'Marketing', desc: 'Conteúdo, mídias sociais, email marketing e publicidade PPC.', icon: 'img-002' },
  { title: 'Design', desc: 'Design gráfico, web design, identidade visual e UX/UI.', icon: 'img-003' },
];
---

<BaseLayout
  title={`Serviços | ${siteConfig.siteName}`}
  description="Estratégia, Marketing e Design. Soluções completas para impulsionar sua marca."
>
  <article class="porto-servicos">
    <section class="py-12 md:py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-accent-secondary)]">Serviços</h1>
          <PageBreadcrumb items={[{ label: 'Início', href: '/' }, { label: 'Serviços' }]} />
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4 max-w-7xl">
        <h2 class="text-2xl md:text-4xl font-bold text-white text-center mb-12">O que fazemos</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {services.map((s) => (
            <div class="p-8 rounded-xl bg-[var(--color-bg-elevated)] border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors">
              <h3 class="text-xl font-bold text-white mb-4">{s.title}</h3>
              <p class="text-[var(--color-body-2)]">{s.desc}</p>
            </div>
          ))}
        </div>
        <div class="text-center mt-12">
          <a href="/contato" class="inline-flex items-center gap-2 px-6 py-4 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium rounded-lg transition-colors min-h-[44px]">
            Fale conosco <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
