---
/**
 * Página Início (Homepage)
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1.html
 * Hero, marquee, logos, seção de serviços, números de impacto, projetos em destaque, depoimentos.
 * Traduzido para português, cores preservadas.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import { IMG } from '../lib/porto-images';
---

<BaseLayout
  title={`Início | ${siteConfig.siteName}`}
  description="Marketing digital e estratégias inovadoras. Impulsionamos marcas além das expectativas."
>
  <article class="porto-inicio">
    <!-- Hero -->
    <section class="relative overflow-hidden border-t-0 pt-20 md:pt-28 pb-8 md:pb-16">
      <div class="absolute inset-0 bg-[var(--color-bg-light)] -z-10" aria-hidden="true"></div>
      <div class="container mx-auto px-4 md:px-8 max-w-7xl">
        <div class="grid lg:grid-cols-2 gap-12 items-center min-h-[60vh]">
          <div class="text-center lg:text-left order-2 lg:order-1">
            <div class="inline-block mb-4">
              <span class="bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-secondary)] text-white text-sm md:text-base font-medium px-4 py-1 rounded-full">Vamos lá</span>
              <span class="text-2xl md:text-4xl font-semibold text-[var(--color-bg)] ml-2">Além das Expectativas</span>
            </div>
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-[var(--color-bg)] mb-6 leading-tight">
              Construindo <strong class="relative"><mark class="bg-transparent text-[var(--color-accent-secondary)]">Sucesso</mark></strong><br>
              <mark class="bg-transparent text-[var(--color-accent-secondary)]">Através do</mark> <strong>Marketing</strong>
            </h1>
            <div class="flex flex-wrap gap-6 justify-center lg:justify-start mb-8">
              <div class="flex items-center gap-2">
                <div class="w-12 h-12 rounded-lg bg-white border shadow-md flex items-center justify-center">
                  <span class="text-[var(--color-accent-secondary)] text-xl">✓✓</span>
                </div>
                <span class="font-medium text-[var(--color-bg)]">Marketing Digital</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-12 h-12 rounded-lg bg-white border shadow-md flex items-center justify-center">
                  <span class="text-[var(--color-accent-secondary)] text-xl">✓✓</span>
                </div>
                <span class="font-medium text-[var(--color-bg)]">Agência de Crescimento</span>
              </div>
            </div>
            <a href="/servicos" class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-bg)] hover:bg-[var(--color-bg-elevated)] text-white font-medium rounded-lg transition-colors min-h-[44px]">
              Saiba mais <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="order-1 lg:order-2 grid grid-cols-3 gap-2 md:gap-4">
            <div class="space-y-4">
              <div class="bg-white rounded-xl p-2 shadow-lg"><img src={IMG('img-002.png')} alt="" class="w-full h-auto object-contain" loading="eager" /></div>
              <div class="bg-white rounded-xl shadow-lg"><img src={IMG('img-003.png')} alt="" class="w-full h-auto object-contain" /></div>
              <div class="bg-white rounded-xl shadow-lg"><img src={IMG('img-004.png')} alt="" class="w-full h-auto object-contain" /></div>
            </div>
            <div class="space-y-4 pt-8">
              <div class="bg-white rounded-xl p-2 md:p-4 shadow-lg"><img src={IMG('img-005.png')} alt="" class="w-full h-auto object-contain" /></div>
              <div class="bg-white rounded-xl shadow-lg"><img src={IMG('img-006.png')} alt="" class="w-full h-auto object-contain" /></div>
            </div>
            <div class="space-y-4 pt-4">
              <div class="bg-white rounded-xl p-2 shadow-lg"><img src={IMG('img-007.png')} alt="" class="w-full h-auto object-contain" /></div>
              <div class="bg-white rounded-xl shadow-lg"><img src={IMG('img-008.png')} alt="" class="w-full h-auto object-contain" /></div>
              <div class="bg-white rounded-xl shadow-lg"><img src={IMG('img-009.png')} alt="" class="w-full h-auto object-contain" /></div>
              <div class="bg-white rounded-xl shadow-lg"><img src={IMG('img-010.png')} alt="" class="w-full h-auto object-contain" /></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee -->
    <section class="py-3 bg-gradient-to-r from-[var(--color-tertiary)] to-[var(--color-quaternary)] overflow-hidden" aria-hidden="true">
      <div class="animate-marquee whitespace-nowrap text-[var(--color-bg)] font-medium text-lg">
        <span class="inline-block mr-8">Planejamento •</span>
        <span class="inline-block mr-8">Posicionamento •</span>
        <span class="inline-block mr-8">Pesquisa de Mercado •</span>
        <span class="inline-block mr-8">Otimização •</span>
        <span class="inline-block mr-8">Análise •</span>
        <span class="inline-block mr-8">Estratégia •</span>
        <span class="inline-block mr-8">Planejamento •</span>
        <span class="inline-block mr-8">Posicionamento •</span>
        <span class="inline-block mr-8">Pesquisa de Mercado •</span>
      </div>
    </section>

    <!-- Logos clientes -->
    <section class="py-12 md:py-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
          <img src={IMG('img-011.png')} alt="Cliente" class="h-8 md:h-10 object-contain opacity-70 hover:opacity-100 transition" />
          <img src={IMG('img-012.png')} alt="Cliente" class="h-8 md:h-10 object-contain opacity-70 hover:opacity-100 transition" />
          <img src={IMG('img-013.png')} alt="Cliente" class="h-8 md:h-10 object-contain opacity-70 hover:opacity-100 transition" />
          <img src={IMG('img-014.png')} alt="Cliente" class="h-8 md:h-10 object-contain opacity-70 hover:opacity-100 transition" />
          <img src={IMG('img-015.png')} alt="Cliente" class="h-8 md:h-10 object-contain opacity-70 hover:opacity-100 transition" />
          <img src={IMG('img-016.png')} alt="Cliente" class="h-8 md:h-10 object-contain opacity-70 hover:opacity-100 transition" />
        </div>
      </div>
    </section>

    <!-- O que fazemos -->
    <section class="py-16 md:py-24 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-8">
            <h2 class="text-2xl md:text-4xl font-bold text-[var(--color-bg)] leading-snug">
              Capacitando marcas com estratégias inovadoras para impulsionar <span class="relative inline-block"><span class="relative z-10">crescimento</span><img src={IMG('img-017.svg')} alt="" class="absolute inset-0 w-full h-full" /></span> e sucesso.
            </h2>
            <a href="/sobre" class="inline-flex items-center gap-2 mt-6 px-6 py-3 bg-[var(--color-bg)] hover:bg-[var(--color-bg-elevated)] text-white font-medium rounded-lg transition-colors min-h-[44px]">
              Saiba mais <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="lg:col-span-4">
            <p class="text-lg text-[var(--color-body)]">Desbloqueie o potencial da sua marca com estratégias de marketing sob medida que conectam, engajam e geram resultados mensuráveis.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Números de impacto -->
    <section class="py-16 md:py-24 bg-[var(--color-bg)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <span class="inline-block bg-[var(--color-quaternary)] text-[var(--color-accent-secondary)] text-sm font-medium px-4 py-1 rounded-full mb-6">Números de Impacto</span>
        <div class="grid md:grid-cols-3 gap-12">
          <div>
            <p class="text-4xl md:text-5xl font-bold text-[var(--color-accent)]">10+</p>
            <h3 class="text-2xl md:text-3xl font-bold text-white mt-2 mb-3">Anos de Crescimento</h3>
            <p class="text-[var(--color-body-2)]">Mais de uma década impulsionando crescimento consistente, entregando resultados impactantes e capacitando marcas a alcançar todo o seu potencial.</p>
          </div>
          <div>
            <p class="text-4xl md:text-5xl font-bold text-[var(--color-accent)]">5M+</p>
            <h3 class="text-2xl md:text-3xl font-bold text-white mt-2 mb-3">Receita Gerada</h3>
            <p class="text-[var(--color-body-2)]">Milhões em receita gerada através de campanhas estratégicas, ajudando nossos clientes a alcançar sucesso financeiro notável e crescimento sustentável.</p>
          </div>
          <div>
            <p class="text-4xl md:text-5xl font-bold text-[var(--color-accent)]">100+</p>
            <h3 class="text-2xl md:text-3xl font-bold text-white mt-2 mb-3">Negócios Atendidos</h3>
            <p class="text-[var(--color-body-2)]">Parceiros com centenas de empresas em diversos setores, entregando soluções de marketing sob medida que geram resultados e fomentam sucesso a longo prazo.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- O que fazemos - Serviços -->
    <section class="py-16 md:py-24 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <span class="inline-block bg-[var(--color-tertiary)] text-[var(--color-accent-secondary)] text-sm font-medium px-4 py-1 rounded-full mb-6">O que fazemos</span>
        <div class="grid lg:grid-cols-2 gap-12">
          <div class="space-y-12">
            <div>
              <h3 class="text-sm font-semibold text-[var(--color-accent)] mb-2">Estratégia</h3>
              <h4 class="text-2xl md:text-4xl font-bold text-[var(--color-bg)] mb-4">Estratégia</h4>
              <ul class="list-none space-y-2 text-[var(--color-body)]">
                <li>• Pesquisa e Análise de Mercado</li>
                <li>• Estratégia de Marca</li>
                <li>• Estratégia de Marketing Digital</li>
                <li>• Estratégia de Conteúdo</li>
                <li>• Estratégia SEO e SEM</li>
                <li>• Mapeamento da Jornada do Cliente</li>
                <li>• Estratégia Go-to-Market</li>
                <li>• Estratégia de Mídias Sociais</li>
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-[var(--color-accent)] mb-2">Marketing</h3>
              <h4 class="text-2xl md:text-4xl font-bold text-[var(--color-bg)] mb-4">Marketing</h4>
              <ul class="list-none space-y-2 text-[var(--color-body)]">
                <li>• Marketing de Conteúdo</li>
                <li>• Marketing em Mídias Sociais</li>
                <li>• SEO</li>
                <li>• Email Marketing</li>
                <li>• Publicidade PPC</li>
                <li>• Marketing de Influenciadores</li>
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-[var(--color-accent)] mb-2">Design</h3>
              <h4 class="text-2xl md:text-4xl font-bold text-[var(--color-bg)] mb-4">Design</h4>
              <ul class="list-none space-y-2 text-[var(--color-body)]">
                <li>• Design Gráfico</li>
                <li>• Web Design</li>
                <li>• Logo e Identidade Visual</li>
                <li>• UX e UI Design</li>
              </ul>
            </div>
          </div>
          <div class="flex items-center justify-center">
            <img src={IMG('img-020.png')} alt="Serviços" class="max-w-md w-full h-auto object-contain" />
          </div>
        </div>
      </div>
    </section>

    <!-- Projetos em destaque -->
    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4 max-w-7xl">
        <span class="inline-block bg-[var(--color-quaternary)] text-[var(--color-accent-secondary)] text-sm font-medium px-4 py-1 rounded-full mb-6">Projetos em Destaque</span>
        <ul class="space-y-8 mt-12">
          <li class="border-b border-[var(--color-border)] pb-8">
            <a href="/cases/okler-themes" class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 group">
              <span class="text-[var(--color-body)] text-sm">01</span>
              <span class="text-2xl md:text-4xl font-semibold text-white group-hover:text-[var(--color-accent)] transition-colors">Okler Themes</span>
              <span class="text-[var(--color-body)]">Marketing</span>
            </a>
          </li>
          <li class="border-b border-[var(--color-border)] pb-8">
            <a href="/cases/porto" class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 group">
              <span class="text-[var(--color-body)] text-sm">02</span>
              <span class="text-2xl md:text-4xl font-semibold text-white group-hover:text-[var(--color-accent)] transition-colors">Porto</span>
              <span class="text-[var(--color-body)]">Design</span>
            </a>
          </li>
          <li class="border-b border-[var(--color-border)] pb-8">
            <a href="/cases/envato" class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 group">
              <span class="text-[var(--color-body)] text-sm">03</span>
              <span class="text-2xl md:text-4xl font-semibold text-white group-hover:text-[var(--color-accent)] transition-colors">Envato</span>
              <span class="text-[var(--color-body)]">Estratégia</span>
            </a>
          </li>
          <li class="pb-8">
            <a href="/cases" class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 group">
              <span class="text-[var(--color-body)] text-sm">04</span>
              <span class="text-2xl md:text-4xl font-semibold text-white group-hover:text-[var(--color-accent)] transition-colors">Ver todos os cases</span>
              <span class="text-[var(--color-body)]">→</span>
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- Depoimentos -->
    <section class="py-16 md:py-24 bg-[var(--color-bg)] relative">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-flex gap-1 text-yellow-400 text-xl mb-2">★★★★★</span>
            <p class="text-lg text-[var(--color-body)] mb-2">Além das Expectativas</p>
            <h3 class="text-2xl md:text-4xl font-bold text-white">Veja o que nossos clientes estão <span class="relative inline-block"><span class="relative z-10">dizendo!</span><img src={IMG('img-017.svg')} alt="" class="absolute inset-0 w-full h-full" /></span></h3>
          </div>
          <div class="bg-[var(--color-bg-light)] rounded-xl p-8">
            <p class="text-[var(--color-bg)] text-lg leading-relaxed mb-6">Superaram as expectativas com suas estratégias de marketing inovadoras. Eles entenderam nossa marca e entregaram campanhas direcionadas que aumentaram significativamente nossos resultados.</p>
            <strong class="text-[var(--color-accent)] uppercase font-medium">João Silva, {siteConfig.siteName}</strong>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Footer -->
    <section class="py-16 md:py-24 bg-[var(--color-bg)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <h3 class="text-2xl md:text-4xl font-bold text-white mb-6">Vamos criar algo <span class="underline decoration-[var(--color-accent)]">incrível</span> juntos!</h3>
        <a href="/contato" class="inline-flex items-center gap-2 px-6 py-4 bg-white text-[var(--color-bg)] hover:bg-[var(--color-tertiary)] font-medium rounded-lg transition-colors min-h-[44px]">
          Vamos conversar! <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </article>

  <style>
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      animation: marquee 60s linear infinite;
    }
  </style>
</BaseLayout>
