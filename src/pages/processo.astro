---
/**
 * Página Processo
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-our-process.html
 * Como trabalhamos - etapas do processo.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumb from '../components/PageBreadcrumb.astro';
import { siteConfig } from '../config';

const steps = [
  { n: '01', title: 'Descoberta', desc: 'Entendemos sua marca, objetivos e público-alvo.' },
  { n: '02', title: 'Estratégia', desc: 'Desenvolvemos o plano de marketing sob medida.' },
  { n: '03', title: 'Execução', desc: 'Implementamos campanhas e acompanhamos resultados.' },
  { n: '04', title: 'Otimização', desc: 'Ajustamos e melhoramos continuamente.' },
];
---

<BaseLayout
  title={`Nosso Processo | ${siteConfig.siteName}`}
  description="Descoberta, Estratégia, Execução e Otimização. Nosso método para resultados."
>
  <article class="porto-processo">
    <section class="py-12 md:py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-accent-secondary)]">Nosso Processo</h1>
          <PageBreadcrumb items={[{ label: 'Início', href: '/' }, { label: 'Processo' }]} />
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4 max-w-7xl">
        <h2 class="text-2xl md:text-4xl font-bold text-white text-center mb-16">Como trabalhamos</h2>
        <div class="grid md:grid-cols-4 gap-8">
          {steps.map((s) => (
            <div class="text-center">
              <span class="inline-block text-4xl font-bold text-[var(--color-accent)] mb-4">{s.n}</span>
              <h3 class="text-xl font-bold text-white mb-3">{s.title}</h3>
              <p class="text-[var(--color-body-2)]">{s.desc}</p>
            </div>
          ))}
        </div>
        <div class="text-center mt-16">
          <a href="/contato" class="inline-flex items-center gap-2 px-6 py-4 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium rounded-lg transition-colors min-h-[44px]">
            Começar projeto <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
