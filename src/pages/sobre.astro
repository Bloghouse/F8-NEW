---
/**
 * Página Sobre / Quem Somos
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-who-we-are.html
 * Quem somos, cultura, valores, números de impacto, depoimentos.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumb from '../components/PageBreadcrumb.astro';
import { siteConfig } from '../config';
import { IMG_WHO } from '../lib/porto-images';
---

<BaseLayout
  title={`Quem Somos | ${siteConfig.siteName}`}
  description="Impulsionamos crescimento através de estratégias de marketing inovadoras, focadas em resultados."
>
  <article class="porto-sobre">
    <!-- Page header -->
    <section class="py-12 md:py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-accent-secondary)]">Quem Somos</h1>
          <PageBreadcrumb items={[
            { label: 'Início', href: '/' },
            { label: 'Sobre' },
          ]} />
        </div>
      </div>
    </section>

    <!-- Intro -->
    <section class="py-12 md:py-16">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid xl:grid-cols-12 gap-12 items-center">
          <div class="xl:col-span-8">
            <h2 class="text-2xl md:text-4xl font-bold text-white">Impulsionando crescimento através de estratégias de marketing inovadoras, focadas em resultados</h2>
          </div>
          <div class="xl:col-span-4">
            <div class="flex items-center gap-4 mb-6">
              <img src={IMG_WHO('img-002.png')} alt="" class="rounded-full w-16 h-16 object-cover" />
              <img src={IMG_WHO('img-003.svg')} alt="" class="w-12 h-12" />
            </div>
            <p class="text-[var(--color-body-2)]">Desbloqueie o potencial da sua marca com estratégias de marketing sob medida que conectam, engajam e geram resultados mensuráveis.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Parallax -->
    <section class="py-24 bg-cover bg-center bg-fixed" style={`background-image: url(${IMG_WHO('img-011.jpg')})`} aria-hidden="true">
      <div class="container mx-auto px-4 max-w-7xl py-24"></div>
    </section>

    <!-- Empowering Brands -->
    <section class="py-16 bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-secondary)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-4">
            <h3 class="text-2xl md:text-3xl font-bold text-white">Capacitando Marcas!</h3>
          </div>
          <div class="lg:col-span-8">
            <span class="inline-block bg-white text-[var(--color-accent)] text-sm font-medium px-4 py-1 rounded-full mb-4">Sobre Ajudar Empresas</span>
            <p class="text-white/90 text-lg leading-relaxed">Somos apaixonados por ajudar empresas a crescer através de soluções de marketing estratégicas, inovadoras e baseadas em dados. Fundados nos princípios de criatividade, integridade e foco no cliente, nossa equipe de profissionais de marketing dedicados entrega resultados mensuráveis que impulsionam o sucesso.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Números -->
    <section class="py-16 bg-[var(--color-bg)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <span class="inline-block bg-[var(--color-quaternary)] text-[var(--color-accent-secondary)] text-sm font-medium px-4 py-1 rounded-full mb-8">Números de Impacto</span>
        <div class="grid md:grid-cols-3 gap-12">
          <div>
            <p class="text-4xl md:text-5xl font-bold text-[var(--color-accent)]">10+</p>
            <h4 class="text-2xl font-bold text-white mt-2 mb-3">Anos de Crescimento</h4>
            <p class="text-[var(--color-body-2)]">Mais de uma década impulsionando crescimento consistente e capacitando marcas.</p>
          </div>
          <div>
            <p class="text-4xl md:text-5xl font-bold text-[var(--color-accent)]">5M+</p>
            <h4 class="text-2xl font-bold text-white mt-2 mb-3">Receita Gerada</h4>
            <p class="text-[var(--color-body-2)]">Milhões em receita através de campanhas estratégicas para nossos clientes.</p>
          </div>
          <div>
            <p class="text-4xl md:text-5xl font-bold text-[var(--color-accent)]">100+</p>
            <h4 class="text-2xl font-bold text-white mt-2 mb-3">Negócios Atendidos</h4>
            <p class="text-[var(--color-body-2)]">Parcerias com centenas de empresas em diversos setores.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cultura e Valores -->
    <section class="py-16 md:py-24 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-5 flex items-center justify-center">
            <img src={IMG_WHO('img-004.jpg')} alt="Cultura" class="rounded-xl max-w-md w-full object-cover aspect-[4/3]" />
          </div>
          <div class="lg:col-span-7 space-y-12">
            <div>
              <h3 class="text-sm font-semibold text-[var(--color-accent)] mb-2">Cultura</h3>
              <h4 class="text-2xl md:text-4xl font-bold text-[var(--color-bg)] mb-4">Nossa Cultura</h4>
              <p class="text-[var(--color-body)] mb-4">Nossa cultura é o coração de quem somos. Acreditamos que um ambiente positivo e colaborativo é a chave para desbloquear a criatividade e impulsionar o sucesso.</p>
              <p class="text-[var(--color-body)] mb-4">Promovemos uma cultura onde cada voz é ouvida e cada ideia é valorizada. Comunicação aberta, respeito mútuo e compromisso com aprendizado contínuo são os pilares do nosso trabalho.</p>
            </div>
          </div>
        </div>
        <div class="grid lg:grid-cols-12 gap-12 mt-16">
          <div class="lg:col-span-5 flex items-center justify-center order-2 lg:order-1">
            <img src={IMG_WHO('img-005.jpg')} alt="Valores" class="rounded-xl max-w-md w-full object-cover aspect-[4/3]" />
          </div>
          <div class="lg:col-span-7 space-y-6 order-1 lg:order-2">
            <h3 class="text-sm font-semibold text-[var(--color-accent)]">Valores</h3>
            <h4 class="text-2xl md:text-4xl font-bold text-[var(--color-bg)]">Nossos Valores</h4>
            <p class="text-[var(--color-body)]">Nossos valores guiam tudo o que fazemos: <strong>Integridade</strong>, <strong>Inovação</strong>, <strong>Colaboração</strong>, <strong>Excelência</strong> e <strong>Foco no Cliente</strong>. São a base sobre a qual construímos nosso sucesso e o de nossos clientes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Depoimentos -->
    <section class="py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-flex gap-1 text-yellow-500 text-xl mb-2">★★★★★</span>
            <p class="text-lg text-[var(--color-body)] mb-2">Além das Expectativas</p>
            <h3 class="text-2xl md:text-4xl font-bold text-[var(--color-bg)]">Veja o que nossos clientes estão <span class="text-[var(--color-accent-secondary)]">dizendo!</span></h3>
          </div>
          <div class="bg-white rounded-xl p-8 shadow-lg">
            <p class="text-[var(--color-bg)] text-lg leading-relaxed mb-6">Superaram as expectativas com suas estratégias de marketing inovadoras. Entenderam nossa marca e entregaram campanhas que aumentaram significativamente nossos resultados.</p>
            <strong class="text-[var(--color-accent)] uppercase font-medium">João Silva, {siteConfig.siteName}</strong>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-[var(--color-bg)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <h3 class="text-2xl md:text-4xl font-bold text-white mb-6">Vamos criar algo incrível juntos!</h3>
        <a href="/contato" class="inline-flex items-center gap-2 px-6 py-4 bg-white text-[var(--color-bg)] hover:bg-[var(--color-tertiary)] font-medium rounded-lg transition-colors min-h-[44px]">
          Vamos conversar! <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>
