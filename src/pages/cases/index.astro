---
/**
 * Página Cases / Portfolio (lista)
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-case-studies.html
 * Lista de cases de sucesso.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBreadcrumb from '../../components/PageBreadcrumb.astro';
import { siteConfig } from '../../config';
import { IMG_CASES } from '../../lib/porto-images';

const cases = [
  { slug: 'okler-themes', title: 'Okler Themes', type: 'Marketing', img: 'img-001.png' },
  { slug: 'porto', title: 'Porto', type: 'Design', img: 'img-002.svg' },
  { slug: 'envato', title: 'Envato', type: 'Estratégia', img: 'img-003.png' },
  { slug: 'theme-forest', title: 'Theme Forest', type: 'Marketing', img: 'img-004.png' },
  { slug: 'code-canyon', title: 'Code Canyon', type: 'Estratégia', img: 'img-005.png' },
];
---

<BaseLayout
  title={`Cases | ${siteConfig.siteName}`}
  description="Cases de sucesso e projetos de marketing que impulsionaram resultados."
>
  <article class="porto-cases">
    <section class="py-12 md:py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-accent-secondary)]">Cases</h1>
          <PageBreadcrumb items={[{ label: 'Início', href: '/' }, { label: 'Cases' }]} />
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {cases.map((c) => (
            <a href={`/cases/${c.slug}`} class="group block">
              <div class="aspect-[4/3] bg-[var(--color-bg-elevated)] rounded-xl mb-4 overflow-hidden">
                <img src={IMG_CASES(c.img)} alt={c.title} class="w-full h-full object-contain p-8 group-hover:scale-105 transition-transform" />
              </div>
              <span class="text-sm text-[var(--color-accent)]">{c.type}</span>
              <h3 class="text-xl font-bold text-white group-hover:text-[var(--color-accent)] transition-colors">{c.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
