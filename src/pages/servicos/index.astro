---
/**
 * Página Serviços - Services
 * Baseada em public/reference/html-bexon-demo-service.html/
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBreadcrumb from '../../components/PageBreadcrumb.astro';
import { siteConfig } from '../../config';

const REF = 'html-bexon-demo-service.html';
const IMG = (file: string) => `/reference/${REF}/images/${file}`;

const servicos = [
  { titulo: 'Desenvolvimento de Estratégia Empresarial', desc: 'Soluções de Experiência do Cliente para aprimorar cada ponto de contato da jornada do seu cliente.', slug: 'estrategia-empresarial' },
  { titulo: 'Soluções de Experiência do Cliente', desc: 'Utilizamos tecnologias e estratégias de ponta para mantê-lo competitivo no mercado.', slug: 'experiencia-cliente' },
  { titulo: 'Suporte e Manutenção de TI', desc: 'Garantimos que sua infraestrutura de tecnologia funcione de forma fluida e segura.', slug: 'suporte-ti' },
  { titulo: 'Consultoria de Sustentabilidade e ESG', desc: 'Utilizamos tecnologias e estratégias de ponta para mantê-lo competitivo.', slug: 'sustentabilidade-esg' },
  { titulo: 'Programas de Treinamento e Desenvolvimento', desc: 'Utilizamos tecnologias e estratégias de ponta para mantê-lo competitivo.', slug: 'treinamento-desenvolvimento' },
  { titulo: 'Estratégia e Campanhas de Marketing', desc: 'Marketing eficaz é fundamental para impulsionar o crescimento dos negócios.', slug: 'marketing' },
];
---

<BaseLayout title={`Serviços | ${siteConfig.siteName}`} description="Conheça nossos serviços de consultoria empresarial.">
  <article>
    <section class="py-16 px-6 bg-[#0c1e21] text-white">
      <div class="max-w-4xl mx-auto text-center">
        <PageBreadcrumb title="Serviços" />
        <h1 class="text-4xl font-bold mt-4">Serviços</h1>
      </div>
    </section>

    <section class="py-20 px-6 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {servicos.map((s) => (
            <a href={`/servicos/${s.slug}`} class="block p-8 rounded-lg border border-[#d8e5e5] hover:border-[#1e8a8a] hover:shadow-lg transition-all group">
              <div class="w-14 h-14 rounded-full bg-[#1e8a8a]/20 flex items-center justify-center text-[#1e8a8a] mb-4 group-hover:bg-[#1e8a8a] group-hover:text-white transition-colors">◆</div>
              <h3 class="font-bold text-[#0c1e21] group-hover:text-[#1e8a8a] transition-colors">{s.titulo}</h3>
              <p class="text-sm text-[#364e52] mt-2">{s.desc}</p>
              <span class="inline-flex items-center gap-1 mt-4 text-[#1e8a8a] font-semibold">
                Saiba mais
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
