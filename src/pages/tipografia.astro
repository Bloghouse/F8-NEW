---
/**
 * Página Tipografia - baseada em public/reference/typography.html/
 * Demonstração de estilos tipográficos do template Melanie Hanson
 * Imagens: /reference/typography.html/images/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const IMG = (f: string) => `/reference/typography.html/images/${f}`;
---

<BaseLayout
  title={`Tipografia | ${siteConfig.siteName}`}
  description="Demonstração de tipografia e elementos de texto."
>
  <article class="tipografia-page prose prose-invert max-w-4xl mx-auto py-20 px-6">
    <h1 class="text-4xl font-bold mb-6">Tipografia</h1>

    <p class="mb-6">Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>

    <p class="mb-8">Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum. Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium.</p>

    <h1 class="text-4xl font-bold mb-4">Cabeçalho 1</h1>
    <p class="mb-6">Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>

    <h2 class="text-3xl font-bold mb-4">Cabeçalho 2</h2>
    <p class="mb-6">Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>

    <h3 class="text-2xl font-bold mb-4">Cabeçalho 3</h3>
    <p class="mb-6">Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>

    <h4 class="text-xl font-bold mb-4">Cabeçalho 4</h4>
    <p class="mb-6">Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>

    <h5 class="text-lg font-bold mb-4">Cabeçalho 5</h5>
    <p class="mb-6">Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>

    <h6 class="text-base font-bold mb-4">Cabeçalho 6</h6>
    <p class="mb-8">Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>

    <hr class="my-12 border-gray-700" />

    <h2 class="text-2xl font-bold mb-4">Elementos Inline</h2>
    <p class="mb-6">
      <strong>Texto em negrito</strong> e <em>texto em itálico</em>. Exemplo de <a href="/" class="text-[#efa758] hover:underline">link</a>.
    </p>

    <div class="grid md:grid-cols-2 gap-8 mt-12">
      <img src={IMG('img-002.jpg')} alt="" class="rounded-lg w-full" />
      <img src={IMG('img-003.jpg')} alt="" class="rounded-lg w-full" />
    </div>

    <nav class="py-8 text-center">
      <a href="/" class="text-[#efa758] hover:underline">← Voltar ao Início</a>
    </nav>
  </article>
</BaseLayout>
