---
/**
 * Página Detalhe da Vaga - Careers Details
 * Baseada em public/reference/html-bexon-demo-careers-details.html/
 * Rota: /carreiras/[slug]
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBreadcrumb from '../../components/PageBreadcrumb.astro';
import { siteConfig } from '../../config';

const REF = 'html-bexon-demo-careers-details.html';
const IMG = (file: string) => `/reference/${REF}/images/${file}`;

export function getStaticPaths() {
  return ['diretor-estrategia', 'analista-marketing', 'desenvolvedor-fullstack', 'consultor-esg'].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const titulo = slug ? slug.split('-').map((s) => s.charAt(0).toUpperCase() + s.slice(1)).join(' ') : 'Vaga';
---

<BaseLayout title={`${titulo} | ${siteConfig.siteName}`} description={`Candidatura para vaga de ${titulo}.`}>
  <article>
    <section class="py-16 px-6 bg-[#0c1e21] text-white">
      <div class="max-w-4xl mx-auto text-center">
        <PageBreadcrumb title={titulo} />
        <h1 class="text-4xl font-bold mt-4">{titulo}</h1>
        <p class="text-white/80 mt-2">São Paulo • Tempo integral</p>
      </div>
    </section>

    <section class="py-20 px-6 bg-white">
      <div class="max-w-3xl mx-auto prose prose-[#364e52]">
        <h2 class="text-xl font-bold text-[#0c1e21]">Descrição da Vaga</h2>
        <p class="text-[#364e52]">Procuramos um profissional talentoso para se juntar à nossa equipe. Você terá a oportunidade de trabalhar em projetos desafiadores e crescer conosco.</p>
        <h2 class="text-xl font-bold text-[#0c1e21] mt-8">Requisitos</h2>
        <ul class="list-disc pl-6 text-[#364e52]">
          <li>Experiência comprovada na área</li>
          <li>Boa comunicação</li>
          <li>Trabalho em equipe</li>
        </ul>
        <h2 class="text-xl font-bold text-[#0c1e21] mt-8">Benefícios</h2>
        <ul class="list-disc pl-6 text-[#364e52]">
          <li>Plano de saúde</li>
          <li>Vale-refeição</li>
          <li>Ambiente colaborativo</li>
        </ul>
        <div class="mt-12">
          <a href="/contato" class="inline-flex items-center gap-2 px-8 py-4 bg-[#1e8a8a] hover:bg-[#1a7777] text-white font-semibold rounded transition-colors">
            Candidatar-se
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="py-12 px-6 bg-[#d8e5e5]">
      <div class="max-w-4xl mx-auto text-center">
        <a href="/carreiras" class="text-[#1e8a8a] font-semibold hover:underline">← Voltar para Carreiras</a>
      </div>
    </section>
  </article>
</BaseLayout>
