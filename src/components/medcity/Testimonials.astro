---
/**
 * Testimonials - depoimentos de pacientes (carrossel ou grid)
 * Imagens: img-012, img-013, img-014 = thumbs 1, 2, 3
 */
const imgBase = '/reference/demos-medcity-about-us.html/images';
const testimonials = [
  { quote: 'Os médicos incluem profissionais altamente qualificados de diversas origens, trazendo habilidades e interesses variados. Há enfermeiras disponíveis para triagem de urgências e a equipe administrativa possui excelentes habilidades interpessoais.', author: 'Sami Wade', role: '7oroof Inc', img: 'img-012.png' },
  { quote: 'Os médicos incluem profissionais altamente qualificados de diversas origens, trazendo habilidades e interesses variados. Há enfermeiras disponíveis para triagem de urgências e a equipe administrativa possui excelentes habilidades interpessoais.', author: 'Ahmed', role: 'Web Inc', img: 'img-013.png' },
  { quote: 'Os médicos incluem profissionais altamente qualificados de diversas origens, trazendo habilidades e interesses variados. Há enfermeiras disponíveis para triagem de urgências e a equipe administrativa possui excelentes habilidades interpessoais.', author: 'Sonia Blake', role: 'Web Inc', img: 'img-014.png' },
];
---

<section class="py-16 md:py-24 bg-sky-900 text-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Histórias inspiradoras!</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <blockquote class="p-6 rounded-xl bg-white/10">
          <p class="text-sky-100 mb-4">"{t.quote}"</p>
          <footer class="flex items-center gap-3">
            <img src={`${imgBase}/${t.img}`} alt={t.author} class="w-12 h-12 rounded-full object-cover flex-shrink-0" />
            <div>
              <cite class="font-semibold not-italic">{t.author}</cite>
              <p class="text-sky-300 text-sm">{t.role}</p>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
