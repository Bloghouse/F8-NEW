    <p>&copy; {currentYear} {SITE_CONFIG.name}. Todos os direitos reservados.</p>
    <nav class="footer-nav">
      <a href="/">Início</a>
      <a href="/blog/">Blog</a>
      <a href="/sobre/">Sobre</a>
      <a href="/contato/">Contato</a>
    </nav>
  </div>
</footer>
