---
/**
 * projetos/[slug].astro – Detalhes de projeto (Prompt 5)
 * Ref: 2025-digilink-html-page-project-details.html.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'cartao-visual' } },
    { params: { slug: 'scrappy' } },
    { params: { slug: 'showcase' } },
    { params: { slug: 'onboarding' } },
    { params: { slug: 'cold-outreach' } },
  ];
}

const REF = '2025-digilink-html-page-project-details.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const { slug } = Astro.params;
const titulo = slug ? slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') : 'Detalhes do Projeto';
---

<BaseLayout title={titulo} description={`Case study: ${titulo}`} image={IMG('img-010.jpg')}>
  <PageTitle title={titulo} breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Projetos', href: '/projetos' }, { label: titulo }]} image={IMG('img-010.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <img src={IMG('img-003.jpg')} alt={titulo} class="w-full rounded-lg object-cover max-h-[500px] mb-12" />
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div>
          <p class="text-white/60 text-sm">Cliente</p>
          <p class="font-semibold text-white">Brooklyn Simmons</p>
        </div>
        <div>
          <p class="text-white/60 text-sm">Categoria</p>
          <p class="font-semibold text-white">Design de Website</p>
        </div>
        <div>
          <p class="text-white/60 text-sm">Data</p>
          <p class="font-semibold text-white">25 de fevereiro de 2026</p>
        </div>
        <div>
          <p class="text-white/60 text-sm">Local</p>
          <p class="font-semibold text-white">São Paulo, SP</p>
        </div>
      </div>
      <div class="prose prose-invert max-w-none">
        <h3 class="text-xl font-bold text-white mb-4">Melhor Solução Digital</h3>
        <p class="text-white/80 mb-4">
          Devemos explicar como surgiu essa ideia equivocada de denunciar o prazer e elogiar a dor, e daremos um relato completo do sistema, expondo os ensinamentos reais do grande explorador da verdade, o construtor-mestre da felicidade humana.
        </p>
        <p class="text-white/80 mb-8">
          Ninguém rejeita, não gosta ou evita o prazer em si, porque é prazer, mas porque aqueles que não sabem perseguir o prazer racionalmente encontram consequências extremamente dolorosas.
        </p>
        <div class="flex gap-4 mb-8 overflow-x-auto">
          <img src={IMG('img-005.jpg')} alt="" class="w-64 h-48 object-cover rounded-lg shrink-0" />
          <img src={IMG('img-004.jpg')} alt="" class="w-64 h-48 object-cover rounded-lg shrink-0" />
        </div>
        <h3 class="text-xl font-bold text-white mb-4">Fatos interessantes no desenvolvimento</h3>
        <p class="text-white/80 mb-4">
          Devemos explicar como surgiu essa ideia equivocada e daremos um relato completo do sistema. Ninguém rejeita o prazer em si, mas aqueles que não sabem perseguir o prazer racionalmente encontram consequências dolorosas.
        </p>
        <ul class="space-y-2 text-white/80">
          <li class="flex items-center gap-2">✓ Planejamento de sprints eficiente</li>
          <li class="flex items-center gap-2">✓ Abordagem iterativa de entrega</li>
          <li class="flex items-center gap-2">✓ Resolução de problemas</li>
        </ul>
      </div>
      <div class="mt-12">
        <a href="/projetos" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
          ← Voltar aos projetos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
