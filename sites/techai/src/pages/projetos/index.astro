---
/**
 * projetos/index.astro – Página Projetos/Case Studies (Prompts 4 e 6)
 * Ref: 2025-digilink-html-page-projects.html. Grid de projetos.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';

const REF = '2025-digilink-html-page-projects.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const projetos = [
  { img: 'img-005', titulo: 'Design de cartão de visita', tags: ['Branding', 'UI/UX', 'Design'] },
  { img: 'img-006', titulo: 'Scrappy & Resourceful', tags: ['Branding', 'UI/UX', 'Design'] },
  { img: 'img-007', titulo: 'Mostre seu processo', tags: ['Branding', 'UI/UX', 'Design'] },
  { img: 'img-008', titulo: 'Onboarding profissional', tags: ['Branding', 'UI/UX', 'Design'] },
  { img: 'img-009', titulo: 'Cold outreach direcionado', tags: ['Branding', 'UI/UX', 'Design'] },
];
---

<BaseLayout title="Nossos Projetos" description="Conheça nossos cases de sucesso" image={IMG('img-013.jpg')}>
  <PageTitle title="Nossos Projetos" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Projetos' }]} image={IMG('img-013.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projetos.map((p, i) => (
          <a href={`/projetos/${['cartao-visual', 'scrappy', 'showcase', 'onboarding', 'cold-outreach'][i]}`} class="group block rounded-lg overflow-hidden bg-white/5 border border-white/5 hover:border-[#D9F45F]/30 transition-colors">
            <div class="relative aspect-[4/3] overflow-hidden">
              <img src={IMG(`${p.img}.jpg`)} alt={p.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent" />
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <ul class="flex flex-wrap gap-2 mb-2">
                  {p.tags.map((t) => <li class="text-xs text-[#D9F45F]">{t}</li>)}
                </ul>
                <h3 class="font-bold text-white text-lg group-hover:text-[#D9F45F] transition-colors">{p.titulo}</h3>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
