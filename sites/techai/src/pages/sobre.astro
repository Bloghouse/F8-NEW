---
/**
 * sobre.astro – Página Sobre Nós (Prompt 2)
 * Ref: 2025-digilink-html-page-about.html. Seção sobre, features, marcas, serviços.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';

const REF = '2025-digilink-html-page-about.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;
---

<BaseLayout title="Sobre Nós" description="Conheça a TechAI" image={IMG('img-030.jpg')}>
  <PageTitle title="Sobre Nós" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Sobre Nós' }]} image={IMG('img-030.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12 items-center">
        <div>
          <p class="text-[#D9F45F] text-sm font-medium mb-4">Sobre nós</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Sua empresa no <span class="text-[#D9F45F]">topo do Google</span></h2>
          <p class="text-white/80 mb-6">Acreditamos em inovação, colaboração e design orientado por dados.</p>
          <div class="flex gap-8 mb-8">
            <div>
              <p class="text-2xl font-bold text-[#D9F45F]">2010</p>
              <p class="text-white/70 text-sm">Desde</p>
            </div>
            <div>
              <p class="text-2xl font-bold text-[#D9F45F]">89+</p>
              <p class="text-white/70 text-sm">Prêmios digitais</p>
            </div>
          </div>
          <div class="flex -space-x-3">
            <img src={IMG('img-004.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <img src={IMG('img-005.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <img src={IMG('img-006.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <img src={IMG('img-007.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-[#D9F45F]/20 text-[#D9F45F] text-sm font-medium">+</span>
          </div>
        </div>
        <div class="lg:col-span-2">
          <img src={IMG('img-008.jpg')} alt="Equipe" class="w-full rounded-lg object-cover max-h-[400px]" />
          <div class="mt-6 p-6 bg-white/5 rounded-lg flex gap-4">
            <img src={IMG('img-009.png')} alt="" class="w-10 h-10 shrink-0" />
            <p class="text-white/90 italic">O progresso verdadeiro não acontece isolado, mas em parceria — com quem confia em nós, nos desafia e cresce conosco.</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mt-16">
        <div class="flex gap-4">
          <img src={IMG('img-010.png')} alt="" class="w-12 h-12 shrink-0" />
          <div>
            <h3 class="font-bold text-white mb-2">Conteúdo Criativo e Design</h3>
            <p class="text-white/70 text-sm">Criamos conteúdo e design que conectam sua marca ao público.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <img src={IMG('img-011.png')} alt="" class="w-12 h-12 shrink-0" />
          <div>
            <h3 class="font-bold text-white mb-2">Estratégia e Consultoria</h3>
            <p class="text-white/70 text-sm">Planejamento estratégico para o crescimento do seu negócio.</p>
          </div>
        </div>
      </div>
      <div class="mt-8">
        <a href="/contato" class="inline-flex items-center px-6 py-3 rounded-md bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
          Fale conosco
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
