---
/**
 * blog/index.astro – Página Blog/Grid (Prompt 15)
 * Ref: 2025-digilink-html-news-grid.html.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';

const REF = '2025-digilink-html-news-grid.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const posts = [
  { img: 'img-003.jpg', titulo: 'Como a IA está transformando o marketing digital', data: '15 Mar 2026', slug: 'ia-marketing-digital' },
  { img: 'img-004.jpg', titulo: 'Tendências de UX para 2026', data: '10 Mar 2026', slug: 'tendencias-ux-2026' },
  { img: 'img-005.jpg', titulo: 'Automação de processos: por onde começar', data: '05 Mar 2026', slug: 'automacao-processos' },
  { img: 'img-005.jpg', titulo: 'Por que migrar seu blog WordPress para Astro?', data: '11 Mar 2026', slug: 'por-que-migrar-blog-wordpress-para-astro' },
];
---

<BaseLayout title="Blog" description="Artigos e novidades" image={IMG('img-009.jpg')}>
  <PageTitle title="Blog" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Blog' }]} image={IMG('img-009.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((p) => (
          <a href={`/blog/${p.slug}`} class="group block rounded-lg overflow-hidden bg-white/5 border border-white/5 hover:border-[#D9F45F]/30 transition-colors">
            <div class="aspect-video overflow-hidden">
              <img src={IMG(p.img)} alt={p.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            </div>
            <div class="p-6">
              <p class="text-[#D9F45F] text-sm mb-2">{p.data}</p>
              <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors">{p.titulo}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
