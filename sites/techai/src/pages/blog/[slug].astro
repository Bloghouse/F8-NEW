---
/**
 * blog/[slug].astro – Detalhes do post (Prompt 16)
 * Ref: 2025-digilink-html-news-details.html.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
import BlogCtaBanner from '../../components/BlogCtaBanner.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'ia-marketing-digital' } },
    { params: { slug: 'tendencias-ux-2026' } },
    { params: { slug: 'automacao-processos' } },
    { params: { slug: 'por-que-migrar-blog-wordpress-para-astro' } },
  ];
}

const REF = '2025-digilink-html-news-details.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const { slug } = Astro.params;
const titulos: Record<string, string> = {
  'ia-marketing-digital': 'Como a IA está transformando o marketing digital',
  'tendencias-ux-2026': 'Tendências de UX para 2026',
  'automacao-processos': 'Automação de processos: por onde começar',
  'por-que-migrar-blog-wordpress-para-astro': 'Por que migrar seu blog WordPress para Astro?',
};
const titulo = slug ? (titulos[slug] || slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')) : 'Post';

const conteudos: Record<string, { data: string; img?: string; paragrafos: string[]; subtitulo?: string; subParagrafo?: string }> = {
  'por-que-migrar-blog-wordpress-para-astro': {
    data: '11 de março de 2026',
    paragrafos: [
      'Se você gerencia um blog em WordPress, provavelmente já sentiu o peso de plugins, lentidão e complexidade. Migrar para Astro pode trazer performance, segurança e uma experiência de desenvolvimento muito mais leve.',
      'O Astro gera sites estáticos por padrão — ou seja, HTML puro no servidor. Isso resulta em carregamento instantâneo, melhor SEO e menos consumo de recursos. Ideal para blogs que priorizam velocidade e ranqueamento.',
      'Além disso, o Astro suporta "islands" de interatividade: você pode usar React, Vue ou outros frameworks apenas onde realmente precisar, mantendo o restante estático e rápido.',
    ],
    subtitulo: 'Quando vale a pena migrar?',
    subParagrafo: 'Se seu blog é focado em conteúdo, tem volume moderado de posts e você valoriza performance e SEO, a migração para Astro faz bastante sentido. Ferramentas como os adaptadores de conteúdo facilitam a transição.',
  },
};
const conteudo = slug ? conteudos[slug] : null;
const dataExibicao = conteudo?.data ?? '15 de março de 2026';
const imgPost = conteudo?.img ?? 'img-003.jpg';
---

<BaseLayout title={titulo} description={titulo} image={IMG('img-003.jpg')}>
  <PageTitle title={titulo} breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Blog', href: '/blog' }, { label: titulo }]} image={IMG('img-011.jpg')} />

  <article class="py-20 bg-[#131212]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <img src={IMG(imgPost)} alt={titulo} class="w-full rounded-lg object-cover max-h-[500px] mb-8" />
      <p class="text-white/60 text-sm mb-4">{dataExibicao}</p>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-6">{titulo}</h1>
      <div class="prose prose-invert max-w-none text-white/80 space-y-4">
        {conteudo ? (
          <>
            {conteudo.paragrafos.slice(0, Math.ceil(conteudo.paragrafos.length / 2)).map((p) => (
              <p>{p}</p>
            ))}
            <BlogCtaBanner />
            {conteudo.paragrafos.slice(Math.ceil(conteudo.paragrafos.length / 2)).map((p) => (
              <p>{p}</p>
            ))}
            {conteudo.subtitulo && <h2 class="text-xl font-bold text-white mt-8 mb-4">{conteudo.subtitulo}</h2>}
            {conteudo.subParagrafo && <p>{conteudo.subParagrafo}</p>}
          </>
        ) : (
          <>
            <p>
              Devemos explicar como a inteligência artificial está revolucionando a forma como as empresas se comunicam com seu público. As ferramentas de IA permitem personalização em escala, análise preditiva e automação de tarefas repetitivas.
            </p>
            <p>
              As tecnologias de processamento de linguagem natural (NLP) e machine learning estão permitindo que marcas criem experiências mais relevantes para cada usuário. Chatbots inteligentes, recomendações personalizadas e conteúdo gerado por IA são apenas o começo.
            </p>
            <BlogCtaBanner />
            <h2 class="text-xl font-bold text-white mt-8 mb-4">O futuro já começou</h2>
            <p>
              As empresas que adotam IA no marketing hoje estarão na frente da concorrência amanhã. A chave está em começar com casos de uso específicos e escalar gradualmente.
            </p>
          </>
        )}
      </div>
      <div class="mt-12">
        <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
          ← Voltar ao blog
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
