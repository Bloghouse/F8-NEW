---
/**
 * 404.astro – Página de erro 404 (Prompt 14)
 * Ref: 2025-digilink-html-page-404.html.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const REF = '2025-digilink-html-page-404.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;
---

<BaseLayout title="Página não encontrada" description="Erro 404" noIndex>
  <section class="min-h-[70vh] flex flex-col items-center justify-center px-4 bg-[#0D0D0D]">
    <img src={IMG('img-001.png')} alt="404" class="max-w-xs w-full mb-8 opacity-70" />
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">404</h1>
    <p class="text-white/70 text-center mb-8 max-w-md">A página que você procura não foi encontrada ou foi removida.</p>
    <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
      ← Voltar ao início
    </a>
  </section>
</BaseLayout>
