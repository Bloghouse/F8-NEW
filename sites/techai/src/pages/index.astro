---
/**
 * index.astro – Página inicial (home) do site TechAI
 * Baseada em 2025-digilink-html-page-about. Hero, sobre, features, marcas, serviços.
 * Conteúdo traduzido para português. Imagens via /reference/2025-digilink-html-page-about.html/images/
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const REF = '2025-digilink-html-page-about.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;
---

<BaseLayout title="TechAI" description="Agência especializada em soluções de IA e tecnologia" image={IMG('img-030.jpg')}>
  <section class="relative min-h-[70vh] flex items-center justify-center bg-cover bg-center" style={`background-image: url(${IMG('img-030.jpg')})`}>
    <div class="absolute inset-0 bg-black/60" />
    <div class="relative z-10 text-center px-4 py-20 max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
        Sua empresa no <span class="text-[#D9F45F]">topo do Google</span>
      </h1>
      <p class="text-lg text-white/90 mb-8">
        Acreditamos em inovação, colaboração e design orientado por dados para destacar nossos clientes no mundo digital.
      </p>
      <a href="/sobre" class="inline-flex items-center px-6 py-3 rounded-md bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
        Saiba mais
      </a>
    </div>
  </section>

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12 items-center">
        <div>
          <p class="text-[#D9F45F] text-sm font-medium mb-4 flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 14 14" fill="currentColor"><path d="M6.81319 13.8341C6.83947 14.0553 7.16053 14.0553 7.18681 13.8341L7.40705 11.9779C7.69143 9.58112 9.58112 7.69143 11.9779 7.40704L13.834 7.18681C14.0553 7.16053 14.0553 6.83947 13.834 6.81319L11.9779 6.59295C9.58112 6.30857 7.69143 4.41888 7.40705 2.02211L7.18681 0.165963C7.16053 -0.0553207 6.83947 -0.0553207 6.81319 0.165963L6.59296 2.02211C6.30857 4.41888 4.41888 6.30857 2.02209 6.59295L0.165943 6.81319C-0.0553144 6.83947 -0.0553144 7.16053 0.165943 7.18681L2.02209 7.40704C4.41888 7.69143 6.30857 9.58112 6.59296 11.9779L6.81319 13.8341Z"/></svg>
            Sobre nós
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Transformando negócios em <span class="text-[#D9F45F]">histórias de sucesso digital</span></h2>
          <p class="text-white/80 mb-6">Acreditamos em inovação, colaboração e design orientado por dados para destacar clientes no mundo digital.</p>
          <div class="flex gap-8 mb-8">
            <div>
              <p class="text-2xl font-bold text-[#D9F45F]">10M+</p>
              <p class="text-white/70 text-sm">Levantado mais que</p>
            </div>
            <div>
              <p class="text-2xl font-bold text-[#D9F45F]">89+</p>
              <p class="text-white/70 text-sm">Prêmios digitais</p>
            </div>
          </div>
          <div class="flex -space-x-3">
            <img src={IMG('img-004.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <img src={IMG('img-005.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <img src={IMG('img-006.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <img src={IMG('img-007.jpg')} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-[#D9F45F]/20 text-[#D9F45F] text-sm font-medium">+</span>
          </div>
        </div>
        <div class="lg:col-span-2">
          <img src={IMG('img-008.jpg')} alt="Equipe TechAI" class="w-full rounded-lg object-cover max-h-[400px]" />
          <div class="mt-6 p-6 bg-white/5 rounded-lg flex gap-4">
            <img src={IMG('img-009.png')} alt="" class="w-10 h-10 shrink-0" />
            <p class="text-white/90 italic">O progresso verdadeiro não acontece isolado, mas em parceria — com quem confia em nós, nos desafia e cresce conosco.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-[#D9F45F] relative overflow-hidden">
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-[#131212]" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <p class="text-[#0F0B19]/80 text-sm font-medium mb-4">Nossos diferenciais</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#0F0B19]">Transformando negócios em <span class="text-[#0F0B19]">histórias de sucesso digital</span></h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { icon: 'img-012.png', title: 'Estratégia de Marca', desc: 'Posicionamento e identidade visual' },
          { icon: 'img-013.png', title: 'Web Design', desc: 'Design e desenvolvimento de sites' },
          { icon: 'img-014.png', title: 'Marketing em Redes', desc: 'Gestão de mídias sociais' },
          { icon: 'img-015.png', title: 'Criação de Conteúdo', desc: 'Marketing de conteúdo' },
          { icon: 'img-016.png', title: 'Automação de E-mail', desc: 'E-mail marketing' },
        ].map((item) => (
          <div class="bg-[#0F0B19] p-6 rounded-lg text-white hover:scale-105 transition-transform">
            <img src={IMG(item.icon)} alt="" class="w-12 h-12 mb-4" />
            <h3 class="font-bold mb-2">{item.title}</h3>
            <p class="text-white/70 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/servicos" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-[#0F0B19] text-[#D9F45F] font-semibold hover:bg-[#1a1a1a] transition-colors">
          Mais serviços <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-white mb-12">Trabalhando com <span class="text-[#D9F45F]">30+ marcas</span> no mundo</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-items-center opacity-80">
        <img src={IMG('img-022.png')} alt="Cliente" class="max-h-12 w-auto object-contain" />
        <img src={IMG('img-023.png')} alt="Cliente" class="max-h-12 w-auto object-contain" />
        <img src={IMG('img-024.png')} alt="Cliente" class="max-h-12 w-auto object-contain" />
        <img src={IMG('img-023.png')} alt="Cliente" class="max-h-12 w-auto object-contain hidden md:block" />
      </div>
    </div>
  </section>

  <section class="py-20 bg-[#0D0D0D]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 mb-16">
        <div>
          <p class="text-[#D9F45F] text-sm font-medium mb-2">Nossos Serviços</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white">Serviços que <span class="text-[#D9F45F]">fazem diferença</span></h2>
        </div>
        <p class="text-white/70 max-w-md">Trazemos sua visão à vida com designs inovadores que combinam funcionalidade, sustentabilidade e estética.</p>
      </div>
      <div class="space-y-4">
        {[
          { title: 'Marketing Digital', desc: 'Estratégias integradas para sua presença digital' },
          { title: 'Branding', desc: 'Identidade e posicionamento de marca' },
          { title: 'Estratégia de Produto', desc: 'Desenvolvimento de produtos digitais' },
          { title: 'Consultoria', desc: 'Análise e recomendação estratégica' },
          { title: 'Motion Design', desc: 'Animações e vídeos para suas campanhas' },
        ].map((s) => (
          <a href="/servicos" class="block group p-6 rounded-lg bg-white/5 hover:bg-white/10 transition-colors border border-white/5">
            <div class="flex justify-between items-center">
              <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors">{s.title}</h3>
              <span class="text-[#D9F45F]">→</span>
            </div>
            <p class="text-white/70 mt-2 text-sm">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
