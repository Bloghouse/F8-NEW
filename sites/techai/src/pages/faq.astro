---
/**
 * faq.astro – Página FAQ (Prompt 10)
 * Ref: 2025-digilink-html-page-faq.html. Accordion de perguntas frequentes.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';

const REF = '2025-digilink-html-page-faq.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const faqs = [
  { q: 'Quais serviços sua agência digital oferece?', a: 'Oferecemos marketing digital, branding, design de websites, consultoria em transformação digital, automação de marketing e muito mais.' },
  { q: 'Há quanto tempo vocês estão no mercado?', a: 'Estamos no mercado desde 2010, com mais de 89 prêmios digitais e experiência comprovada com clientes em diversos setores.' },
  { q: 'Em quais indústrias vocês se especializam?', a: 'Trabalhamos com tecnologia, e-commerce, saúde, educação, finanças e serviços B2B em geral.' },
  { q: 'Vocês fazem websites personalizados?', a: 'Sim! Desenvolvemos websites totalmente personalizados, responsivos e otimizados para SEO.' },
  { q: 'Como funciona o processo de contratação?', a: 'Entre em contato, agendamos uma reunião para entender suas necessidades e elaboramos uma proposta personalizada.' },
  { q: 'Quais formas de pagamento vocês aceitam?', a: 'Aceitamos transferência bancária, PIX, cartão de crédito e boleto, com condições especiais para projetos maiores.' },
];
---

<BaseLayout title="Perguntas Frequentes" description="Tire suas dúvidas" image={IMG('img-006.jpg')}>
  <PageTitle title="Perguntas Frequentes" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'FAQ' }]} image={IMG('img-006.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">
        {faqs.map((item, i) => (
          <details class="group border border-white/10 rounded-lg bg-white/5 overflow-hidden" open={i === 0}>
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer list-none font-medium text-white hover:bg-white/5 transition-colors">
              {item.q}
              <span class="text-[#D9F45F] transition-transform group-open:rotate-180">▼</span>
            </summary>
            <div class="px-6 pb-4 text-white/80 text-sm border-t border-white/10">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
