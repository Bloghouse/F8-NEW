---
/**
 * equipe/[slug].astro – Detalhes de membro da equipe (Prompt 9)
 * Ref: 2025-digilink-html-page-team-details.html.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'wade-warren' } },
    { params: { slug: 'leslie-alexander' } },
    { params: { slug: 'eleanor-pena' } },
  ];
}

const REF = '2025-digilink-html-page-team-details.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const { slug } = Astro.params;
const nomes: Record<string, string> = { 'wade-warren': 'Wade Warren', 'leslie-alexander': 'Leslie Alexander', 'eleanor-pena': 'Eleanor Pena' };
const nome = slug ? (nomes[slug] || slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')) : 'Membro';
---

<BaseLayout title={nome} description={`Perfil de ${nome}`} image={IMG('img-008.jpg')}>
  <PageTitle title={nome} breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Equipe', href: '/equipe' }, { label: nome }]} image={IMG('img-008.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <img src={IMG('img-003.jpg')} alt={nome} class="w-full md:w-80 aspect-square object-cover rounded-xl shrink-0" />
        <div>
          <h2 class="text-2xl font-bold text-white mb-4">{nome}</h2>
          <p class="text-[#D9F45F] mb-4">UX Designer, Pesquisa</p>
          <p class="text-white/80 mb-6">
            Profissional apaixonado por criar experiências de usuário memoráveis. Com anos de experiência em design e pesquisa, combina criatividade com dados para entregar soluções que fazem a diferença.
          </p>
          <div class="flex gap-4">
            <a href="#" class="w-10 h-10 rounded-full bg-[#D9F45F]/20 text-[#D9F45F] flex items-center justify-center hover:bg-[#D9F45F] hover:text-[#0F0B19] transition-colors" aria-label="Instagram">📷</a>
            <a href="#" class="w-10 h-10 rounded-full bg-[#D9F45F]/20 text-[#D9F45F] flex items-center justify-center hover:bg-[#D9F45F] hover:text-[#0F0B19] transition-colors" aria-label="Twitter">𝕏</a>
            <a href="#" class="w-10 h-10 rounded-full bg-[#D9F45F]/20 text-[#D9F45F] flex items-center justify-center hover:bg-[#D9F45F] hover:text-[#0F0B19] transition-colors" aria-label="LinkedIn">in</a>
          </div>
        </div>
      </div>
      <div class="mt-12">
        <a href="/equipe" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
          ← Voltar à equipe
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
