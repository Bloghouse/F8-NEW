---
/**
 * equipe/index.astro – Página Nossa Equipe (Prompt 8)
 * Ref: 2025-digilink-html-page-team.html. Grid de membros da equipe.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';

const REF = '2025-digilink-html-page-team.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const membros = [
  { img: 'img-003.png', nome: 'Wade Warren', cargo: 'UX Designer', slug: 'wade-warren' },
  { img: 'img-004.png', nome: 'Leslie Alexander', cargo: 'UX Designer, Pesquisa', slug: 'leslie-alexander' },
  { img: 'img-005.png', nome: 'Eleanor Pena', cargo: 'UX Designer, Pesquisa', slug: 'eleanor-pena' },
];
---

<BaseLayout title="Nossa Equipe" description="Conheça nossa equipe" image={IMG('img-010.jpg')}>
  <PageTitle title="Nossa Equipe" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Equipe' }]} image={IMG('img-010.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {membros.map((m) => (
          <a href={`/equipe/${m.slug}`} class="group block text-center">
            <div class="relative overflow-hidden rounded-lg mb-4">
              <img src={IMG(m.img)} alt={m.nome} class="w-full aspect-square object-cover group-hover:scale-105 transition-transform" />
              <div class="absolute inset-0 bg-[#D9F45F]/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-4">
                <a href="#" class="w-10 h-10 rounded-full bg-[#D9F45F] text-[#0F0B19] flex items-center justify-center" aria-label="Instagram">📷</a>
                <a href="#" class="w-10 h-10 rounded-full bg-[#D9F45F] text-[#0F0B19] flex items-center justify-center" aria-label="Twitter">𝕏</a>
                <a href="#" class="w-10 h-10 rounded-full bg-[#D9F45F] text-[#0F0B19] flex items-center justify-center" aria-label="LinkedIn">in</a>
              </div>
            </div>
            <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors">{m.nome}</h3>
            <p class="text-white/70 text-sm">{m.cargo}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
