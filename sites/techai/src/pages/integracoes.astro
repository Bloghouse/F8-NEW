---
/**
 * integracoes.astro – Página Integrações (Prompt 7)
 * Ref NÃO EXISTE. Baseada em 2025-digilink-html-page-services.html.
 * Adaptada para tema de integrações (APIs, plataformas, etc).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';

const REF = '2025-digilink-html-page-services.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const integracoes = [
  { num: '01', titulo: 'Integração com CRMs', desc: 'Salesforce, HubSpot, Pipedrive' },
  { num: '02', titulo: 'APIs e Webhooks', desc: 'Conecte seus sistemas de forma segura' },
  { num: '03', titulo: 'Plataformas de E-commerce', desc: 'Shopify, Magento, WooCommerce' },
  { num: '04', titulo: 'Ferramentas de Marketing', desc: 'Google Ads, Meta, LinkedIn' },
  { num: '05', titulo: 'Automação e Zapier', desc: 'Integrações no-code' },
];
---

<BaseLayout title="Integrações" description="Integre a TechAI com suas ferramentas" image={IMG('img-008.jpg')}>
  <PageTitle title="Integrações" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Integrações' }]} image={IMG('img-008.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-[#D9F45F] text-sm font-medium mb-4">Integrações</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Conecte suas ferramentas</h2>
        <p class="text-white/70 max-w-2xl mx-auto">Integramos nossa plataforma com as principais ferramentas do mercado para agilizar seu fluxo de trabalho.</p>
      </div>
      <div class="space-y-4">
        {integracoes.map((i) => (
          <div class="block p-6 md:p-8 rounded-lg bg-white/5 border border-white/5 hover:border-[#D9F45F]/30 transition-colors">
            <div class="flex justify-between items-start flex-wrap gap-4">
              <div>
                <span class="text-[#D9F45F] font-mono text-sm">{i.num}.</span>
                <h3 class="font-bold text-white text-lg md:text-xl mt-2">{i.titulo}</h3>
                <p class="text-white/70 mt-2">{i.desc}</p>
              </div>
              <img src={IMG('img-003.png')} alt="" class="w-10 h-10 opacity-50" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
