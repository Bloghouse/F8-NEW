---
/**
 * precos.astro – Página Preços (Prompt 12)
 * Ref: 2025-digilink-html-page-pricing.html. Cards de planos.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';

const REF = '2025-digilink-html-page-pricing.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const planos = [
  { preco: '399', nome: 'Plano Starter', recomendado: false, itens: ['Consultoria de negócios', 'Até 10h de suporte/mês', 'Monitoramento de rede', 'Configuração de e-mail e software', 'Relatórios mensais de saúde'] },
  { preco: '660', nome: 'Plano Profissional', recomendado: true, itens: ['Consultoria de negócios', 'Até 10h de suporte/mês', 'Monitoramento de rede', 'Configuração de e-mail e software', 'Relatórios mensais de saúde'] },
  { preco: '990', nome: 'Plano Enterprise', recomendado: false, itens: ['Consultoria de negócios', 'Até 10h de suporte/mês', 'Monitoramento de rede', 'Configuração de e-mail e software', 'Relatórios mensais de saúde'] },
];
---

<BaseLayout title="Preços" description="Conheça nossos planos" image={IMG('img-007.jpg')}>
  <PageTitle title="Preços" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Preços' }]} image={IMG('img-007.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        {planos.map((p) => (
          <div class={`relative rounded-xl p-8 border ${p.recomendado ? 'border-[#D9F45F] bg-[#D9F45F]/5' : 'border-white/10 bg-white/5'} `}>
            {p.recomendado && <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-[#D9F45F] text-[#0F0B19] text-sm font-semibold">Recomendado</div>}
            <div class="mb-6">
              <span class="text-white/60">R$</span>
              <span class="text-4xl font-bold text-white">{p.preco}</span>
              <span class="text-white/60">/ano</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-6">{p.nome}</h3>
            <ul class="space-y-3 mb-8">
              {p.itens.map((item) => (
                <li class="flex items-center gap-2 text-white/80 text-sm">
                  <span class="text-[#D9F45F]">✓</span> {item}
                </li>
              ))}
            </ul>
            <a href="/contato" class="block w-full text-center py-3 rounded-lg bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
              Começar agora
            </a>
          </div>
        ))}
      </div>
      <div class="mt-16 text-center">
        <p class="text-white/80 mb-4">Pronto para o próximo passo? Vamos criar algo incrível juntos.</p>
        <a href="/contato" class="inline-flex items-center gap-2 text-[#D9F45F] font-semibold hover:underline">
          Entre em contato
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
