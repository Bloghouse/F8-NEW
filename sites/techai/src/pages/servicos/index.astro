---
/**
 * servicos/index.astro – Página Serviços/Features (Prompts 3 e 7)
 * Ref: 2025-digilink-html-page-services.html. Lista de serviços em cards.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';

const REF = '2025-digilink-html-page-services.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const servicos = [
  { num: '01', titulo: 'Estratégia de Marca e Posicionamento', link: '/servicos' },
  { num: '02', titulo: 'Marketing em Redes Sociais', link: '/servicos' },
  { num: '03', titulo: 'Consultoria em Transformação Digital', link: '/servicos' },
  { num: '04', titulo: 'Desenvolvimento Web e App', link: '/servicos' },
  { num: '05', titulo: 'Automação de Marketing', link: '/servicos' },
];
---

<BaseLayout title="Nossos Serviços" description="Conheça nossos serviços em IA e tecnologia" image={IMG('img-008.jpg')}>
  <PageTitle title="Nossos Serviços" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Serviços' }]} image={IMG('img-008.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">
        {servicos.map((s) => (
          <a href={s.link} class="block group relative p-6 md:p-8 rounded-lg bg-white/5 hover:bg-white/10 transition-colors border border-white/5 overflow-hidden">
            <div class="flex justify-between items-center">
              <div class="flex items-center gap-6">
                <span class="text-[#D9F45F] font-mono">{s.num}.</span>
                <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors text-lg md:text-xl">{s.titulo}</h3>
              </div>
              <img src={IMG('img-003.png')} alt="" class="w-10 h-10 opacity-50 group-hover:opacity-100 transition-opacity" />
            </div>
            <div class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 w-64 h-64 opacity-10">
              <div class="w-full h-full bg-cover bg-center rounded-l" style={`background-image: url(${IMG('img-009.jpg')})`} />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
