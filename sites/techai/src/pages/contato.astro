---
/**
 * contato.astro – Página Contato (Prompt 13)
 * Ref: 2025-digilink-html-page-contact.html. Formulário e informações.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';

const REF = '2025-digilink-html-page-contact.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;
---

<BaseLayout title="Contato" description="Entre em contato conosco" image={IMG('img-007.jpg')}>
  <PageTitle title="Contato" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Contato' }]} image={IMG('img-007.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <p class="text-[#D9F45F] text-sm font-medium mb-4">Envie-nos um e-mail</p>
          <h2 class="text-3xl font-bold text-white mb-8">Sinta-se à vontade para escrever</h2>
          <form class="space-y-6" action="#" method="post">
            <div class="grid sm:grid-cols-2 gap-6">
              <input type="text" name="nome" placeholder="Seu nome" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] focus:outline-none" required />
              <input type="email" name="email" placeholder="Seu e-mail" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] focus:outline-none" required />
            </div>
            <div class="grid sm:grid-cols-2 gap-6">
              <input type="text" name="assunto" placeholder="Assunto" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] focus:outline-none" required />
              <input type="tel" name="telefone" placeholder="Telefone" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] focus:outline-none" />
            </div>
            <textarea name="mensagem" rows={6} placeholder="Sua mensagem" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] focus:outline-none resize-none" required />
            <div class="flex gap-4">
              <button type="submit" class="px-6 py-3 rounded-lg bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors">
                Enviar mensagem
              </button>
              <button type="reset" class="px-6 py-3 rounded-lg border border-white/20 text-white hover:bg-white/5 transition-colors">
                Limpar
              </button>
            </div>
          </form>
        </div>
        <div>
          <p class="text-[#D9F45F] text-sm font-medium mb-4">Precisa de ajuda?</p>
          <h2 class="text-2xl font-bold text-white mb-6">Entre em contato</h2>
          <p class="text-white/70 mb-8">Estamos prontos para ajudar. Envie sua mensagem e responderemos o mais rápido possível.</p>
          <ul class="space-y-6">
            <li>
              <h4 class="text-white font-semibold mb-1">Dúvidas?</h4>
              <a href="tel:+5521995211289" class="text-[#D9F45F] hover:underline">+55 21 99521-1289</a>
            </li>
            <li>
              <h4 class="text-white font-semibold mb-1">E-mail</h4>
              <a href="mailto:contato@techai.com.br" class="text-[#D9F45F] hover:underline">contato@techai.com.br</a>
            </li>
            <li>
              <h4 class="text-white font-semibold mb-1">Visite</h4>
              <span class="text-white/70">Av. Paulista, 1000 - São Paulo, SP</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="h-96 bg-white/5">
    <iframe
      class="w-full h-full"
      src="https://maps.google.com/maps?width=100%25&amp;height=600&amp;hl=pt-BR&amp;q=S%C3%A3o%20Paulo&amp;t=&amp;z=12&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"
      title="Mapa"
    />
  </section>
</BaseLayout>
