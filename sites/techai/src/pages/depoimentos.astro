---
/**
 * depoimentos.astro – Página Depoimentos (Prompt 11)
 * Ref: 2025-digilink-html-page-testimonial.html. Cards de depoimentos.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';

const REF = '2025-digilink-html-page-testimonial.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;

const depoimentos = [
  { nome: 'Annette Black', cargo: 'Administradora', texto: 'Superou todas as expectativas com seu serviço excepcional e expertise. A dedicação e o profissionalismo tornaram todo o processo tranquilo e gratificante. Recomendo fortemente!' },
  { nome: 'Maria Silva', cargo: 'CEO, TechCorp', texto: 'A equipe da TechAI transformou nossa presença digital. O site ficou incrível e as métricas de conversão aumentaram significativamente.' },
  { nome: 'João Santos', cargo: 'Diretor de Marketing', texto: 'Parceria de excelência. Entregas no prazo, comunicação clara e resultados que superaram as metas. Profissionais de alto nível.' },
];
---

<BaseLayout title="Depoimentos" description="O que nossos clientes dizem" image={IMG('img-011.jpg')}>
  <PageTitle title="Depoimentos" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Depoimentos' }]} image={IMG('img-011.jpg')} />

  <section class="py-20 bg-[#131212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-4 gap-12">
        <div class="lg:col-span-1">
          <div class="relative">
            <img src={IMG('img-004.png')} alt="Clientes" class="w-full max-w-xs mx-auto" />
            <div class="mt-6 p-4 bg-[#D9F45F]/10 rounded-lg">
              <p class="text-3xl font-bold text-[#D9F45F]">4.7</p>
              <div class="flex gap-1 mt-2 text-[#D9F45F]">★★★★★</div>
              <p class="text-white/80 text-sm mt-2">De 3k+ membros, avaliado no Google</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-3 space-y-6">
          {depoimentos.map((d) => (
            <div class="p-8 rounded-lg bg-white/5 border border-white/10 relative">
              <img src={IMG('img-007.png')} alt="" class="w-12 h-12 mb-4 opacity-60" />
              <p class="text-white/90 italic mb-6">"{d.texto}"</p>
              <div>
                <p class="font-bold text-white">{d.nome}</p>
                <p class="text-white/60 text-sm">{d.cargo}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
