---
/**
 * BlogCtaBanner.astro – Banner CTA no meio dos artigos do blog
 * Convida o leitor a conhecer a consultoria de SEO da TechAI.
 */
const REF = '2025-digilink-html-news-details.html';
const IMG = (f: string) => `/reference/${REF}/images/${f}`;
---

<aside class="my-12 rounded-xl border border-[#D9F45F]/30 bg-[#D9F45F]/5 p-8 md:p-10">
  <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-8">
    <div class="flex-1">
      <p class="text-[#D9F45F] text-sm font-semibold mb-2">Consultoria de SEO</p>
      <h3 class="text-xl md:text-2xl font-bold text-white mb-3">Quer aparecer no topo do Google?</h3>
      <p class="text-white/80 mb-4">
        Nossa consultoria de SEO ajuda sua empresa a ranquear melhor, atrair mais visitantes qualificados e converter em clientes.
      </p>
      <a
        href="/contato"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-[#D9F45F] text-[#0F0B19] font-semibold hover:bg-[#c5e04f] transition-colors min-h-[44px] min-w-[44px]"
      >
        Conhecer consultoria
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
    <div class="shrink-0">
      <img src={IMG('img-011.jpg')} alt="Consultoria SEO TechAI" class="w-48 h-32 rounded-lg object-cover md:w-56 md:h-36" />
    </div>
  </div>
</aside>
