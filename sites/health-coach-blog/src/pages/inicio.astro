---
/**
 * Página inicial (Homepage)
 * Baseada em public/reference/item-health-coach-blog-lifestyle-site-template-full_screen_preview-19798424/
 * Template Melanie Hanson - Health Coach Blog & Lifestyle
 * Estrutura fiel à referência, conteúdo em português, cores preservadas (#efa758 coral/orange).
 * Imagens: about.html (mesmo template), paths /reference/about.html/images/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const IMG = (file: string) => `/reference/about.html/images/${file}`;
---

<BaseLayout
  title={`Início | ${siteConfig.siteName}`}
  description="Coach de saúde e estilo de vida. Aprenda a perder peso e ter uma pele impecável através de melhores hábitos alimentares."
>
  <article class="inicio-page">
    <!-- Hero -->
    <section class="relative min-h-[70vh] flex items-center justify-center bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url(/reference/about.html/images/img-003.jpg);">
      <div class="max-w-4xl mx-auto px-6 text-center text-white">
        <p class="text-sm uppercase tracking-widest mb-4 opacity-90">Criando e Quebrando Regras</p>
        <h1 class="text-4xl md:text-6xl font-bold mb-6">O Motivo pelo qual me tornei Coach de Saúde</h1>
        <p class="text-xl md:text-2xl mb-8 leading-relaxed">Olá! Sou Melanie, e vou te ensinar como perder peso e ter uma pele impecável através de melhores hábitos alimentares.</p>
        <a href="/sobre" class="inline-block px-8 py-4 bg-[#efa758] hover:bg-[#e09540] text-white font-semibold rounded transition-colors">Leia Minha História</a>
      </div>
    </section>

    <!-- Programas -->
    <section class="py-20 px-6 bg-white text-gray-800">
      <div class="max-w-6xl mx-auto text-center">
        <p class="text-sm uppercase tracking-widest text-[#efa758] mb-4">Programa</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-16">Uma Abordagem Fresca para Saúde e Vida</h2>

        <div class="grid md:grid-cols-3 gap-10">
          <div class="p-8 rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-bold mb-2 text-[#efa758]">1:1 Consultoria</h3>
            <p class="text-sm text-gray-500 mb-4">O Que Você Recebe</p>
            <p class="text-gray-600 mb-6">Sessões mensais onde descobrimos os hábitos e pensamentos que impedem um relacionamento saudável com a comida e seu corpo.</p>
            <a href="/precos" class="text-[#efa758] font-semibold hover:underline">Saiba mais</a>
          </div>
          <div class="p-8 rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-bold mb-2 text-[#efa758]">30 Dias Desafio</h3>
            <p class="text-sm text-gray-500 mb-4">Perfeito para você se</p>
            <p class="text-gray-600 mb-6">Você quer controlar seus desejos e descobrir um estilo de vida mais saudável durante um desafio online divertido e simples de 30 dias.</p>
            <a href="/precos" class="text-[#efa758] font-semibold hover:underline">Saiba mais</a>
          </div>
          <div class="p-8 rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-bold mb-2 text-[#efa758]">Coaching em Grupo</h3>
            <p class="text-sm text-gray-500 mb-4">Todos os benefícios</p>
            <p class="text-gray-600 mb-6">Você está pronto para explorar uma vida que te ama tanto quanto você ama através de sessões quinzenais individuais de coaching.</p>
            <a href="/precos" class="text-[#efa758] font-semibold hover:underline">Saiba mais</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Livro -->
    <section class="py-20 px-6 bg-gray-100">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1">
          <p class="text-sm uppercase tracking-widest text-[#efa758] mb-4">Nutricionista Holística & Especialista em Detox</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-6">O Novo Livro da Melanie Está Disponível</h2>
          <p class="text-gray-600 leading-relaxed">Os diversos "hacks" descritos no livro foram pensados para ajudar quem lida com perda de peso. As sugestões são práticas e facilmente incorporadas ao dia a dia. Baixe o livro hoje com apenas um clique!</p>
        </div>
        <div class="flex-1 flex gap-4">
          <img src={IMG('img-006.png')} alt="App Store" class="h-12 object-contain" />
          <img src={IMG('img-007.png')} alt="Google Play" class="h-12 object-contain" />
        </div>
      </div>
    </section>

    <!-- Programas Dietéticos -->
    <section class="py-20 px-6 bg-white text-gray-800">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm uppercase tracking-widest text-[#efa758] mb-4">Consultoria de Início Fresco</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-12">Programas Dietéticos</h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
          <div class="text-center p-6">
            <h3 class="text-lg font-bold text-[#efa758] mb-2">Como Alcançar a Forma dos Sonhos</h3>
          </div>
          <div class="text-center p-6">
            <h3 class="text-lg font-bold text-[#efa758] mb-2">Guia de Treino Passo a Passo</h3>
          </div>
          <div class="text-center p-6">
            <h3 class="text-lg font-bold text-[#efa758] mb-2">Tabata Explosivo para Máximos Resultados</h3>
          </div>
          <div class="text-center p-6">
            <h3 class="text-lg font-bold text-[#efa758] mb-2">Consultoria Gratuita</h3>
          </div>
        </div>

        <ul class="space-y-3 text-gray-600 mb-8 max-w-2xl">
          <li>Excepteur sint occaecat cupidatat non proident, sunt in culpa</li>
          <li>Duis aute irure dolor in reprehenderit in voluptate velit esse</li>
          <li>Ut enim ad minim veniam, quis nostrud exercitation ullamco</li>
          <li>Lorem ipsum dolor sit amet, consectetur adipisicing elit</li>
        </ul>

        <div class="flex flex-wrap gap-4">
          <a href="/precos" class="px-8 py-4 bg-[#efa758] hover:bg-[#e09540] text-white font-semibold rounded transition-colors">Comprar Agora</a>
          <a href="/precos" class="px-8 py-4 border-2 border-[#efa758] text-[#efa758] hover:bg-[#efa758] hover:text-white font-semibold rounded transition-colors">Programas</a>
        </div>
      </div>
    </section>

    <!-- Conquistas -->
    <section class="py-20 px-6 bg-gray-800 text-white">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm uppercase tracking-widest text-[#efa758] mb-4">Conquistas dos Nossos Membros</p>
        <h2 class="text-3xl font-bold mb-4">Lillie Watson perdeu 40 kg</h2>
        <blockquote class="text-xl italic mb-8 text-gray-300">"Melanie vai transformar completamente sua mentalidade em relação à comida e ao seu corpo. Agora sou mais gentil comigo mesma e mais feliz, não só porque perdi peso, mas porque aprendi a me apreciar e cuidar de mim."</blockquote>
        <a href="/blog" class="text-[#efa758] font-semibold hover:underline">Ver mais histórias</a>
      </div>
    </section>

    <!-- CTA Grátis -->
    <section class="py-16 px-6 bg-[#efa758] text-white text-center">
      <div class="max-w-2xl mx-auto">
        <p class="mb-4">Montei um guia de início rápido de duas semanas para te colocar no caminho, repleto de receitas, inspiração e conselhos. E é 100% GRÁTIS!</p>
        <a href="/precos" class="inline-block px-8 py-4 bg-white text-[#efa758] font-semibold rounded hover:bg-gray-100 transition-colors">Obtenha Grátis</a>
      </div>
    </section>

    <!-- Blog -->
    <section class="py-20 px-6 bg-white text-gray-800">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm uppercase tracking-widest text-[#efa758] mb-4">Seu Blog de Estilo de Vida Saudável</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-12">Artigos Incríveis</h2>

        <div class="grid md:grid-cols-3 gap-8">
          <article class="group">
            <a href="/blog" class="block">
              <img src={IMG('img-003.jpg')} alt="" class="w-full h-48 object-cover rounded-lg mb-4 group-hover:opacity-90 transition" />
              <h3 class="font-bold text-lg mb-2 group-hover:text-[#efa758] transition">Atualizações: Para Onde Estou Levando Esta Jornada Agora</h3>
              <p class="text-sm text-gray-500">Blog • Agosto 2016</p>
            </a>
          </article>
          <article class="group">
            <a href="/blog" class="block">
              <img src={IMG('img-004.jpg')} alt="" class="w-full h-48 object-cover rounded-lg mb-4 group-hover:opacity-90 transition" />
              <h3 class="font-bold text-lg mb-2 group-hover:text-[#efa758] transition">Como 30 Minutos Por Dia Podem te Deixar Mais Saudável</h3>
              <p class="text-sm text-gray-500">Saúde</p>
            </a>
          </article>
          <article class="group">
            <a href="/blog" class="block">
              <img src={IMG('img-005.jpg')} alt="" class="w-full h-48 object-cover rounded-lg mb-4 group-hover:opacity-90 transition" />
              <h3 class="font-bold text-lg mb-2 group-hover:text-[#efa758] transition">10 Formas de Trazer Mais Equilíbrio à Sua Vida</h3>
              <p class="text-sm text-gray-500">Saúde, Autoamor, Viagens</p>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- Contato CTA -->
    <section class="py-20 px-6 bg-gray-100">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">Mude sua saúde em um dia!</h2>
        <p class="text-xl text-gray-600 mb-6">Recomendações gratuitas</p>
        <a href="/contato" class="inline-block px-8 py-4 bg-[#efa758] hover:bg-[#e09540] text-white font-semibold rounded transition-colors">Obtenha</a>
      </div>
    </section>

    <!-- Formulário Consultoria -->
    <section class="py-20 px-6 bg-white text-gray-800">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold mb-6">Solicite uma Consultoria Gratuita</h2>
        <p class="text-gray-600 mb-8">Envie-me um e-mail com algumas palavras sobre o que você deseja alcançar e podemos agendar uma consulta inicial GRATUITA para discutir seu histórico de saúde e objetivos.</p>
        <form action="/contato" method="get" class="space-y-4">
          <div>
            <textarea name="message" rows="4" placeholder="Sua mensagem..." class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-[#efa758] focus:border-transparent"></textarea>
          </div>
          <button type="submit" class="px-8 py-4 bg-[#efa758] hover:bg-[#e09540] text-white font-semibold rounded transition-colors">Enviar Mensagem</button>
        </form>
      </div>
    </section>
  </article>
</BaseLayout>
