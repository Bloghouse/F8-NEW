---
/**
 * Página de Preços e Planos
 * Baseada em demos-medcity-pricing
 * 3 planos (Starter, Basic, Advanced) + formulário de agendamento
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import config from '../config';
import { refImg, REF } from '../lib/reference';

const slug = REF.pricing;
const planos = [
  { nome: 'Plano Básico', preco: 50, desc: 'Oferecemos todos os aspectos da prática médica para sua família, incluindo check-ups gerais.', itens: ['Revisão dos prontuários médicos', 'Verificação de pressão arterial', 'Exames como hemograma'] },
  { nome: 'Plano Intermediário', preco: 70, destaque: true, desc: 'Retorno rápido do projeto, economia substantial e padrões de qualidade.', itens: ['Revisão dos prontuários médicos', 'Verificação de pressão arterial', 'Hemograma e outros exames', 'Verificação da função pulmonar'] },
  { nome: 'Plano Avançado', preco: 90, desc: 'Retorno rápido, economia e padrões de qualidade.', itens: ['Revisão dos prontuários médicos', 'Verificação de pressão arterial', 'Hemograma e exames', 'Função pulmonar', 'Estreitamento das artérias', 'Outros testes especializados'] },
];
---

<BaseLayout title={`Preços e Planos | ${config.siteName}`} description="Conheça nossos planos de saúde e preços para consultas e tratamentos.">
  <article>
    <section class="relative min-h-[350px] flex items-center py-24" style={`background-image: url(${refImg(slug, 'img-019.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/60" />
      <div class="container mx-auto px-4 relative z-10 max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Cuidando dos Mais Necessitados na Comunidade.</h1>
        <p class="text-sky-100 mb-6">Estamos presentes desde 1990, com soluções inovadoras em serviços médicos.</p>
        <a href="/agendar" class="inline-flex items-center gap-2 px-6 py-3 bg-sky-500 hover:bg-sky-400 text-white font-medium rounded-lg border border-sky-400 transition">
          Encontrar um Médico <span>→</span>
        </a>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {planos.map((p) => (
            <article class={`rounded-xl overflow-hidden border ${p.destaque ? 'border-sky-500 bg-sky-900/20' : 'border-zinc-800 bg-[#111]'}`}>
              <div class="p-8">
                <h3 class="text-xl font-semibold text-white mb-2">{p.nome}</h3>
                <p class="text-zinc-400 text-sm mb-6">{p.desc}</p>
                <ul class="space-y-3 mb-8">
                  {p.itens.map((item) => (
                    <li key={item} class="flex items-center gap-2 text-zinc-400 text-sm">
                      <span class="text-sky-500">✓</span> {item}
                    </li>
                  ))}
                </ul>
                <div class="flex items-baseline gap-1 mb-6">
                  <span class="text-sky-400">R$</span>
                  <span class="text-4xl font-bold text-white">{p.preco}</span>
                  <span class="text-zinc-500">/mês</span>
                </div>
                <a href="/agendar" class={`block w-full py-3 text-center font-medium rounded-lg transition ${p.destaque ? 'bg-sky-600 hover:bg-sky-500 text-white' : 'bg-sky-500/20 text-sky-400 hover:bg-sky-500/30 border border-sky-500/50'}`}>
                  Contratar Agora
                </a>
              </div>
            </article>
          ))}
        </div>

        <p class="text-center text-zinc-400 mt-12">
          Oferecendo os cuidados de saúde do amanhã para sua família.
          <a href="/medicos/agenda" class="text-sky-400 hover:text-sky-300 ml-2 font-medium">
            Ver agenda dos médicos →
          </a>
        </p>

        <section class="mt-20 rounded-xl overflow-hidden p-6 md:p-8" style={`background-image: url(${refImg(slug, 'img-020.jpg')}); background-size: cover;`}>
          <div class="bg-sky-900/90 backdrop-blur rounded-xl p-6 md:p-8 max-w-3xl">
            <h3 class="text-2xl font-semibold text-white mb-2">Agendar Consulta</h3>
            <p class="text-sky-100 mb-6">Entre em contato com nossa equipe para dúvidas. Nossos médicos atendem chamadas urgentes.</p>
            <form class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              <select class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white">
                <option value="">Escolha a Clínica</option>
                <option>Clínica de Patologia</option>
              </select>
              <select class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white">
                <option value="">Escolha o Médico</option>
                <option>Ahmed Abdallah</option>
                <option>Maria Andaloro</option>
              </select>
              <input type="text" placeholder="Nome" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
              <input type="email" placeholder="E-mail" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
              <input type="tel" placeholder="Telefone" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
              <input type="date" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white" />
              <input type="time" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white" />
              <button type="submit" class="sm:col-span-2 lg:col-span-3 w-full py-4 bg-sky-500 hover:bg-sky-400 text-white font-medium rounded-lg flex items-center justify-center gap-2 transition border border-sky-400">
                Agendar Consulta <span>→</span>
              </button>
            </form>
          </div>
        </section>
      </div>
    </section>
  </article>
</BaseLayout>
