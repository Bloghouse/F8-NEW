---
/**
 * Listagem do blog - layout Medcity (demos-medcity-blog.html)
 * Hero com imagem, grid de cards. Conteúdo em português.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import config from '../../config';

const img = '/reference/demos-medcity-blog.html/images';
const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const gridImages = [`${img}/img-003.jpg`, `${img}/img-004.jpg`, `${img}/img-005.jpg`, `${img}/img-006.jpg`, `${img}/img-007.jpg`, `${img}/img-008.jpg`];
---

<BaseLayout title={`Blog | ${config.siteName}`} description={config.siteDescription}>
  <!-- Page title com fundo -->
  <section
    class="py-20 md:py-28 bg-cover bg-center"
    style={`background-image: linear-gradient(135deg, rgb(0 0 0 / 0.6), rgb(2 132 199 / 0.4)), url(${img}/img-009.jpg)`}
  >
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Essenciais da saúde</h1>
      <nav class="text-sm">
        <ol class="flex flex-wrap gap-2 text-white/80">
          <li><a href="/inicio" class="hover:text-white">Início</a></li>
          <li>/</li>
          <li class="text-white" aria-current="page">Blog</li>
        </ol>
      </nav>
    </div>
  </section>

  <!-- Grid de posts -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <article class="rounded-xl overflow-hidden bg-[var(--color-bg-elevated)] border border-[var(--color-border)] hover:border-sky-600/50 transition-colors">
            <a href={`/blog/${post.slug}`} class="block overflow-hidden">
              <img
                src={post.data.image || gridImages[i % gridImages.length]}
                alt={post.data.title}
                class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </a>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags?.slice(0, 2).map((tag) => (
                  <a href={`/blog?tag=${tag}`} class="px-2 py-0.5 rounded text-xs bg-sky-600/30 text-sky-300 hover:bg-sky-600/50">
                    {tag}
                  </a>
                ))}
              </div>
              <div class="flex gap-3 text-white/50 text-sm mb-2">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
                <span>{config.author}</span>
              </div>
              <h2 class="text-lg font-semibold text-white mb-3 line-clamp-2">
                <a href={`/blog/${post.slug}`} class="hover:text-sky-400 transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-white/60 text-sm line-clamp-3 mb-4">
                {post.data.description || 'Leia mais sobre este assunto.'}
              </p>
              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center gap-1 text-sky-400 text-sm font-medium hover:text-sky-300"
              >
                Ler mais
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
