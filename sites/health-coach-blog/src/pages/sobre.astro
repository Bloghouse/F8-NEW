---
/**
 * Página Sobre - baseada em public/reference/about.html/
 * Template Melanie Hanson Health Coach - estrutura fiel, conteúdo em português
 * Imagens: /reference/about.html/images/img-XXX.ext
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const IMG = (f: string) => `/reference/about.html/images/${f}`;
---

<BaseLayout
  title={`Sobre | ${siteConfig.siteName}`}
  description="Bem-vindo ao Wholeheartedly Healthy! Conheça minha história e como posso te ajudar a perder peso e ter uma pele impecável."
>
  <article class="sobre-page">
    <!-- Hero -->
    <section class="relative min-h-[50vh] flex items-center justify-center bg-cover bg-center py-20" style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url(/reference/about.html/images/img-003.jpg);">
      <div class="max-w-4xl mx-auto px-6 text-center text-white">
        <img src={IMG('img-002.png')} alt="" class="w-20 h-20 mx-auto mb-6" width="76" height="76" />
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Bem-vindo ao Wholeheartedly Healthy!</h1>
        <p class="text-lg opacity-90">Criando e Quebrando Regras</p>
        <p class="text-xl mt-6">Olá! Sou Melanie, e vou te ensinar como perder peso e ter uma pele impecável através de melhores hábitos alimentares.</p>
      </div>
    </section>

    <!-- Texto + Slider -->
    <section class="py-20 px-6 bg-gray-900 text-white">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-4">Fique Saudável e Vibrante para Sempre</h2>
          <p class="text-[#efa758] text-sm uppercase tracking-widest mb-6">Aumente sua energia</p>
          <p class="text-gray-300 leading-relaxed">
            Para meus clientes particulares de coaching de saúde, criei um roadmap personalizado para a saúde, usando uma visão holística da vida dos meus clientes.
            Junto com dieta e escolhas alimentares, também considero fatores como exercício, trabalho, relacionamentos, sono, estresse, ambiente,
            histórico médico e familiar, e estilo de vida ao orientar alguém a criar sua jornada de saúde. Mude sua saúde em um dia!
          </p>
        </div>
        <div class="relative">
          <img src={IMG('img-005.jpg')} alt="" class="w-full rounded-lg object-cover aspect-[4/3]" />
          <p class="text-center text-gray-400 mt-4 italic">"O que pensamos determina o que acontece conosco, então se quisermos mudar nossas vidas, precisamos expandir nossas mentes."</p>
        </div>
      </div>
    </section>

    <!-- Livro -->
    <section class="py-20 px-6 bg-white text-gray-800">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1">
          <h2 class="text-3xl font-bold mb-2">O Novo Livro da Melanie Está Disponível</h2>
          <p class="text-[#efa758] text-sm uppercase tracking-widest mb-4">Nutricionista Holística & Especialista em Detox de Estilo de Vida</p>
          <p class="text-gray-600 mb-6">Os diversos "hacks" descritos no livro foram pensados para ajudar quem lida com perda de peso. As sugestões são práticas e facilmente incorporadas ao dia a dia. Baixe o livro hoje com apenas um clique!</p>
          <div class="flex gap-4">
            <img src={IMG('img-006.png')} alt="App Store" class="h-12 object-contain" />
            <img src={IMG('img-007.png')} alt="Google Play" class="h-12 object-contain" />
          </div>
        </div>
      </div>
    </section>

    <!-- Certificados -->
    <section class="py-20 px-6 bg-gray-800 text-white">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-2">Sou uma Coach de Saúde e Bem-estar Certificada</h2>
        <p class="text-[#efa758] text-sm uppercase tracking-widest mb-12">Meus Certificados Profissionais</p>
        <div class="flex flex-wrap justify-center gap-8">
          <img src={IMG('img-008.png')} alt="Certificado 1" class="h-24 object-contain" />
          <img src={IMG('img-009.png')} alt="Certificado 2" class="h-24 object-contain" />
          <img src={IMG('img-010.png')} alt="Certificado 3" class="h-24 object-contain" />
        </div>
      </div>
    </section>

    <nav class="py-8 px-6 text-center">
      <a href="/inicio" class="text-[#efa758] hover:underline">← Voltar ao Início</a>
    </nav>
  </article>
</BaseLayout>
