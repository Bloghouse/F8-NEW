---
/**
 * Página de Perguntas Frequentes (FAQs)
 * Baseada em demos-medcity-faqs
 * Sidebar com emergência + horários + accordion de perguntas
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import config from '../config';
import { refImg, REF } from '../lib/reference';

const slug = REF.faqs;
const faqs = [
  { pergunta: 'Quais métodos de pagamento estão disponíveis?', resposta: 'Com qualquer produto financeiro que você adquirir, é importante saber que está recebendo a melhor orientação de uma empresa respeitável. Aceitamos cartões de crédito, débito, PIX e parcelamento.' },
  { pergunta: 'Qual plano é ideal para mim?', resposta: 'É importante avaliar suas necessidades de saúde. Consulte nossa equipe para orientação personalizada sobre os planos disponíveis.' },
  { pergunta: 'Preciso me comprometer com um contrato?', resposta: 'Oferecemos flexibilidade. Entre em contato para conhecer as opções de comprometimento e planos avulsos.' },
  { pergunta: 'E se eu escolher o plano errado?', resposta: 'Permitimos alterações dentro do período de carência. Nossa equipe está à disposição para ajustes.' },
  { pergunta: 'Há contratos ou compromissos?', resposta: 'Depende do plano escolhido. Oferecemos tanto planos mensais quanto anuais com benefícios diferenciados.' },
];
---

<BaseLayout title={`Perguntas Frequentes | ${config.siteName}`} description="Encontre respostas para as dúvidas mais comuns sobre nossos serviços e agendamentos.">
  <article>
    <section class="relative min-h-[200px] flex items-center py-16 pt-24" style={`background-image: url(${refImg(slug, 'img-013.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/60" />
      <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative z-10">
        <h1 class="text-4xl font-bold text-white">Perguntas Frequentes</h1>
        <nav class="text-white/90 text-sm" aria-label="Breadcrumb">
          <ol class="flex flex-wrap gap-2">
            <li><a href="/inicio" class="hover:text-sky-300">Início</a></li>
            <li>/</li>
            <li><a href="/sobre" class="hover:text-sky-300">Sobre</a></li>
            <li>/</li>
            <li class="text-white" aria-current="page">FAQs</li>
          </ol>
        </nav>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          <aside class="lg:col-span-4 space-y-6">
            <div class="rounded-xl overflow-hidden" style={`background-image: url(${refImg(slug, 'img-014.jpg')}); background-size: cover;`}>
              <div class="bg-sky-900/90 backdrop-blur p-6">
                <h3 class="font-semibold text-white text-lg mb-2">Casos de Emergência</h3>
                <p class="text-sky-100 text-sm mb-4">Entre em contato com nossa equipe para qualquer dúvida geral ou médica.</p>
                <a href="tel:+5511999999999" class="text-sky-300 font-medium">(11) 99999-9999</a>
              </div>
            </div>

            <div class="bg-[#111] rounded-xl p-6 border border-zinc-800">
              <h3 class="font-semibold text-white mb-4">Horário de Funcionamento</h3>
              <ul class="space-y-3 text-sm text-zinc-400">
                <li class="flex justify-between"><span>Segunda - Sexta</span><span>8h - 19h</span></li>
                <li class="flex justify-between"><span>Sábado</span><span>9h - 22h</span></li>
                <li class="flex justify-between"><span>Domingo</span><span>10h - 12h</span></li>
              </ul>
            </div>

            <a href="#" class="flex items-center justify-center gap-2 w-full py-3 px-4 bg-sky-600 hover:bg-sky-500 text-white rounded-lg font-medium transition">
              Relatórios de Pacientes 2024
            </a>
          </aside>

          <div class="lg:col-span-8 space-y-4">
            <h2 class="text-2xl font-semibold text-white mb-6">Dúvidas Comuns</h2>
            {faqs.map((faq, i) => (
              <details class="group bg-[#111] rounded-xl border border-zinc-800 overflow-hidden" open={i === 0}>
                <summary class="flex items-center justify-between p-5 cursor-pointer list-none text-white font-medium hover:bg-zinc-800/50 transition">
                  {faq.pergunta}
                  <span class="text-sky-400 group-open:rotate-180 transition">▼</span>
                </summary>
                <div class="px-5 pb-5 pt-0">
                  <p class="text-zinc-400">{faq.resposta}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
