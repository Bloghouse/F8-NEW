---
/**
 * Página de listagem de médicos em grid (doctors-grid)
 * Baseada em demos-medcity-doctors-grid
 * Hero com título, 6 cards de médicos em grid e paginação
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import config from '../../config';
import { refImg, REF } from '../../lib/reference';

const slug = REF.doctorsGrid;
const medicos = [
  { nome: 'Mike Dooley', cargo: 'Especialista em Cardiologia', img: 'img-003.jpg', desc: 'Formou-se em Engenharia Biomédica na Tulane University antes de frequentar a St George\'s University School of Medicine.' },
  { nome: 'Richard Muldoone', cargo: 'Especialista em Cardiologia', img: 'img-004.jpg', desc: 'Especialista em tratamentos de pele, cabelo, unhas e membranas mucosas. Também atende questões cosméticas.' },
  { nome: 'Maria Andaloro', cargo: 'Pediatra', img: 'img-005.jpg', desc: 'Formou-se em medicina e completou 3 anos de residência em pediatria. Aprovada nos exames do American Board of Pediatrics.' },
  { nome: 'Dupree Black', cargo: 'Urologista', img: 'img-006.jpg', desc: 'Diagnostica e trata doenças do trato urinário em homens e mulheres. Também atua no trato reprodutivo masculino.' },
  { nome: 'Markus Skar', cargo: 'Laboratório', img: 'img-007.jpg', desc: 'Desempenha papel importante nos cuidados com a saúde. Responsável por testes que fornecem informações cruciais.' },
  { nome: 'Kiano Barker', cargo: 'Patologista', img: 'img-008.jpg', desc: 'Auxilia no cuidado diário dos pacientes fornecendo informações aos médicos para garantir tratamento adequado.' },
];
---

<BaseLayout title={`Nossos Médicos | ${config.siteName}`} description="Conheça nossa equipe de médicos especialistas. Cardiologia, Pediatria, Urologia e mais.">
  <article>
    <section class="relative min-h-[400px] flex items-center py-24" style={`background-image: url(${refImg(slug, 'img-009.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/60" />
      <div class="container mx-auto px-4 relative z-10 max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Cuidando dos Mais Necessitados na Comunidade.</h1>
        <p class="text-sky-100 mb-6">Estamos presentes desde 1990, oferecendo soluções inovadoras e especialização em serviços médicos para tratamento e infraestrutura médica.</p>
        <a href="/agendar" class="inline-flex items-center gap-2 px-6 py-3 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg transition">
          Agendar Consulta
          <span>→</span>
        </a>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {medicos.map((m) => (
            <article class="bg-[#111] rounded-xl overflow-hidden border border-zinc-800 hover:border-sky-600/50 transition">
              <img src={refImg(slug, m.img)} alt={m.nome} class="w-full aspect-[4/5] object-cover" />
              <div class="p-6">
                <h2 class="text-xl font-semibold text-white">
                  <a href="/medicos/dr-1" class="hover:text-sky-400">{m.nome}</a>
                </h2>
                <p class="text-sky-400 font-medium">{m.cargo}</p>
                <p class="text-zinc-400 text-sm mt-3">{m.desc}</p>
                <a href="/medicos/dr-1" class="inline-flex items-center gap-2 mt-5 text-sky-400 hover:text-sky-300 font-medium">
                  Saiba mais <span>→</span>
                </a>
              </div>
            </article>
          ))}
        </div>

        <nav class="flex justify-center gap-2 mt-12" aria-label="Paginação">
          <a href="#" class="px-4 py-2 bg-sky-600 text-white rounded-lg font-medium">1</a>
          <a href="#" class="px-4 py-2 text-zinc-400 hover:text-white rounded-lg">2</a>
          <a href="#" class="px-4 py-2 text-zinc-400 hover:text-white rounded-lg">→</a>
        </nav>
      </div>
    </section>
  </article>
</BaseLayout>
