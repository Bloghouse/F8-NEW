---
/**
 * Página Agenda dos Médicos (timetable)
 * Baseada em demos-medcity-doctors-timetable
 * Tabela semanal com horários e especialidades por médico
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import config from '../../config';
import { refImg, REF } from '../../lib/reference';

const slug = REF.doctorsTimetable;
const dias = ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'];
const horarios = ['08:00', '09:00', '10:00', '11:00', '12:00'];
const eventos: Record<string, { esp: string; tipo: string; hora: string; medico: string }[]> = {
  '08-0': [{ esp: 'Neurologia', tipo: 'Consulta', hora: '08-09', medico: 'Dr. Muldoone' }],
  '08-1': [{ esp: 'Cardiologia', tipo: 'Consulta', hora: '08-09', medico: 'Dr. Brain' }],
  '08-2': [{ esp: 'Patologia', tipo: 'Consulta', hora: '08-09', medico: 'Dra. Andaloro' }],
  '08-3': [{ esp: 'Laboratório', tipo: 'Análise', hora: '08-11', medico: 'Dr. Markus' }],
  '08-4': [{ esp: 'Pediatria', tipo: 'Consulta', hora: '08-09', medico: 'Dra. Nicole' }],
  '08-5': [{ esp: 'Fisioterapia', tipo: 'Consulta', hora: '08-09', medico: 'Dr. Alex' }],
  '08-6': [{ esp: 'Urologia', tipo: 'Consulta', hora: '08-09', medico: 'Dra. Darlen' }],
  '09-0': [{ esp: 'Maternidade', tipo: 'Consulta', hora: '09-10', medico: 'Dr. Muldoone' }],
  '09-1': [{ esp: 'Oncologia', tipo: 'Consulta', hora: '09-10', medico: 'Dr. Brain' }],
  '09-2': [{ esp: 'Patologia', tipo: 'Consulta', hora: '09-10', medico: 'Dra. Andaloro' }],
  '09-3': [{ esp: 'Pediatria', tipo: 'Consulta', hora: '09-10', medico: 'Dra. Nicole' }],
  '09-4': [{ esp: 'Cardíaca', tipo: 'Consulta', hora: '09-10', medico: 'Dr. Alex' }],
  '09-5': [{ esp: 'Urologia', tipo: 'Consulta', hora: '09-10', medico: 'Dra. Darlen' }],
  '10-0': [{ esp: 'Neurologia', tipo: 'Consulta', hora: '09-11', medico: 'Dr. Muldoone' }],
  '10-1': [{ esp: 'Cardiologia', tipo: 'Consulta', hora: '09-11', medico: 'Dr. Brain' }],
  '10-2': [{ esp: 'Patologia', tipo: 'Consulta', hora: '09-11', medico: 'Dra. Andaloro' }],
  '10-3': [{ esp: 'Maternidade', tipo: 'Consulta', hora: '09-11', medico: 'Dra. Nicole' }],
  '10-4': [{ esp: 'Oncologia', tipo: 'Consulta', hora: '09-11', medico: 'Dr. Alex' }],
  '10-5': [{ esp: 'Urologia', tipo: 'Consulta', hora: '09-11', medico: 'Dra. Darlen' }],
};
---

<BaseLayout title={`Agenda dos Médicos | ${config.siteName}`} description="Confira a agenda semanal dos nossos médicos e especialistas.">
  <article>
    <section class="relative min-h-[220px] flex items-end pb-8 pt-24" style={`background-image: url(${refImg(slug, 'img-003.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/60" />
      <div class="container mx-auto px-4 relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-2">Agenda dos Médicos</h1>
        <nav class="text-white/90 text-sm" aria-label="Breadcrumb">
          <ol class="flex flex-wrap gap-2">
            <li><a href="/inicio" class="hover:text-sky-300">Início</a></li>
            <li class="text-white" aria-current="page">Agenda dos Médicos</li>
          </ol>
        </nav>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[800px] border-collapse text-sm">
            <thead>
              <tr class="border-b border-zinc-700">
                <th class="text-left py-4 px-3 text-zinc-400 font-medium"></th>
                {dias.map((d) => (
                  <th key={d} class="text-center py-4 px-2 text-sky-400 font-medium">{d}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {horarios.map((h, hi) => (
                <tr key={h} class="border-b border-zinc-800">
                  <td class="py-3 px-3 text-zinc-500 font-medium w-20">{h}</td>
                  {dias.map((_, di) => {
                    const key = `${h.split(':')[0]}-${di}`;
                    const ev = eventos[key];
                    return (
                      <td key={di} class="py-3 px-2 align-top">
                        {ev ? (
                          <div class="bg-sky-900/40 rounded-lg p-3 border border-sky-800/50">
                            <a href="/agendar" class="text-sky-300 hover:text-sky-200 font-medium block">{ev[0].esp}</a>
                            <span class="text-zinc-500 text-xs">{ev[0].tipo}</span>
                            <span class="text-zinc-400 text-xs block mt-1">{ev[0].medico}</span>
                          </div>
                        ) : (
                          <span class="text-zinc-600">—</span>
                        )}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-center text-zinc-500 mt-8">Entre em contato para confirmar disponibilidade de horários.</p>
      </div>
    </section>
  </article>
</BaseLayout>
