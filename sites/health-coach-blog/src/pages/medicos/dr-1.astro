---
/**
 * Página individual da Dra. Maria Andaloro (layout 1)
 * Baseada em demos-medcity-doctors-single-doctor1
 * Layout com avaliação e botão de agendamento no hero
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import config from '../../config';
import { refImg, REF } from '../../lib/reference';

const slug = REF.doctorsSingleDoctor1;
---

<BaseLayout title={`Dra. Maria Andaloro | Médicos | ${config.siteName}`} description="Perfil da Dra. Maria Andaloro, especialista em cardiologia. Avaliação 4.9. Agende sua consulta.">
  <article>
    <!-- Hero com avaliação -->
    <section class="relative min-h-[200px] flex items-center justify-end py-16 pt-24" style={`background-image: url(${refImg(slug, 'img-004.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/50" />
      <div class="container mx-auto px-4 flex flex-col md:flex-row items-end md:items-center justify-between gap-6 relative z-10">
        <div class="flex items-center gap-4 bg-white/10 backdrop-blur rounded-lg px-6 py-4">
          <span class="text-3xl font-bold text-sky-300">4.9</span>
          <div>
            <span class="block text-white font-medium">Avaliação Geral</span>
            <span class="text-sm text-sky-200">baseado em 7541 avaliações</span>
          </div>
        </div>
        <a href="/agendar" class="px-6 py-3 bg-white text-sky-700 font-medium rounded-lg hover:bg-sky-50 transition">
          Agendar Consulta
        </a>
      </div>
    </section>

    <!-- Conteúdo (mesma estrutura do dr-2) -->
    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          <aside class="lg:col-span-4 space-y-6">
            <div class="bg-[#111] rounded-xl overflow-hidden border border-zinc-800 -mt-32 relative z-20">
              <img src={refImg(slug, 'img-003.jpg')} alt="Maria Andaloro" class="w-full aspect-square object-cover" />
              <div class="p-6">
                <h2 class="text-xl font-semibold text-white"><a href="/medicos/dr-2" class="hover:text-sky-400">Maria Andaloro</a></h2>
                <p class="text-sky-400 font-medium">Especialista em Cardiologia</p>
                <p class="text-zinc-400 text-sm mt-3">Especialista em tratamentos de pele, cabelo, unhas e membranas mucosas.</p>
                <div class="flex gap-3 mt-5">
                  <a href="#" class="text-sky-400 hover:text-sky-300">→</a>
                  <a href="#" class="text-sky-400 hover:text-sky-300">→</a>
                  <a href="tel:+5511999999999" class="text-sky-400 hover:text-sky-300">📞</a>
                </div>
              </div>
            </div>

            <div class="bg-sky-600 rounded-xl p-6 text-white" style={`background-image: url(${refImg(slug, 'img-005.jpg')}); background-size: cover;`}>
              <div class="relative z-10 bg-sky-900/80 -m-6 p-6 rounded-xl">
                <h3 class="font-semibold text-lg mb-2">Casos de Emergência</h3>
                <p class="text-sm text-sky-100 mb-4">Entre em contato com nossa equipe para qualquer dúvida.</p>
                <a href="tel:+5511999999999" class="text-sky-300 font-medium">(11) 99999-9999</a>
              </div>
            </div>

            <div class="bg-[#111] rounded-xl p-6 border border-zinc-800">
              <h3 class="font-semibold text-white mb-4">Horário de Funcionamento</h3>
              <ul class="space-y-3 text-sm text-zinc-400">
                <li class="flex justify-between"><span>Segunda - Sexta</span><span>8h - 19h</span></li>
                <li class="flex justify-between"><span>Sábado</span><span>9h - 22h</span></li>
                <li class="flex justify-between"><span>Domingo</span><span>10h - 12h</span></li>
              </ul>
            </div>

            <a href="#" class="flex items-center justify-center gap-2 w-full py-3 px-4 bg-sky-600 hover:bg-sky-500 text-white rounded-lg font-medium transition">
              Relatórios de Pacientes 2024
            </a>
          </aside>

          <div class="lg:col-span-8 space-y-10">
            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Biografia</h3>
              <p class="text-zinc-400 mb-4 font-medium text-sky-200/90">Neurologista com formação especializada no diagnóstico e tratamento de distúrbios do cérebro e sistema nervoso.</p>
              <p class="text-zinc-400 mb-4">Concluiu fellowship em Cardiologia Intervencionista no Hahnemann Hospital. Participa de ensaios clínicos e publicações em periódicos revisados.</p>
              <p class="text-zinc-400">Certificado em Doença Cardiovascular e Cardiologia Intervencionista. Formou-se na Universidade da Califórnia.</p>
            </div>

            <ul class="space-y-4">
              <li><h4 class="text-sky-400 font-medium">Especialidade</h4><p class="text-zinc-400">Cardiologia</p></li>
              <li><h4 class="text-sky-400 font-medium">Títulos</h4><p class="text-zinc-400">M.D. em Medicina</p></li>
              <li><h4 class="text-sky-400 font-medium">Áreas de Atuação</h4>
                <ul class="list-disc list-inside text-zinc-400 mt-2">
                  <li>Imagem Cardíaca – Não invasiva</li>
                  <li>Reabilitação Cardíaca</li>
                  <li>Miocardiopatia Hipertrófica</li>
                  <li>Doenças Cardíacas Hereditárias</li>
                </ul>
              </li>
              <li><h4 class="text-sky-400 font-medium">Consultório</h4><p class="text-zinc-400">Rua Exemplo, 123 - São Paulo, SP</p></li>
              <li><h4 class="text-sky-400 font-medium">Universidade</h4><p class="text-zinc-400">Harvard University</p></li>
            </ul>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Serviços do Médico</h3>
              <p class="text-zinc-400">Publicou em periódicos revisados. Treinamento extensivo em intervenções coronárias e procedimentos de salvamento de membros no Hahnemann Hospital.</p>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-6">Tabela de Preços</h3>
              <div class="grid md:grid-cols-2 gap-6">
                {[1, 2].map((col) => (
                  <ul key={col} class="space-y-3 text-zinc-400">
                    {['Aparência do Cordão Umbilical', 'Eletrofisiologia Cardíaca', 'Técnicas de Reposicionamento', 'Geriatria Neurológica', 'Cardiologia Nuclear'].map((item, i) => (
                      <li key={i} class="flex justify-between py-2 border-b border-zinc-800">
                        <span>{item}</span>
                        <span class="text-sky-400 font-medium">R${[250, 225, 300, 325, 200][i]}</span>
                      </li>
                    ))}
                  </ul>
                ))}
              </div>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Prêmios e Honrarias</h3>
              <p class="text-zinc-400 mb-6">O hospital é reconhecido mundialmente, oferecendo cuidados excepcionais e pesquisa médica abrangente.</p>
              <div class="grid sm:grid-cols-2 gap-4">
                {[
                  { title: 'Edison Awards', desc: 'Excelência em inovação' },
                  { title: 'Medalha Edwin Grant', desc: 'Pesquisa em biologia' },
                  { title: 'Prêmio Robert L. Noble', desc: 'Sociedade Canadense de Câncer' },
                  { title: 'Prêmio Nacional de Medicina', desc: 'Academia Chilena de Medicina' },
                ].map((a) => (
                  <div key={a.title} class="flex gap-4 p-4 bg-[#111] rounded-lg border border-zinc-800">
                    <div class="w-12 h-12 rounded-full bg-sky-600/30 flex items-center justify-center text-sky-400 shrink-0">◆</div>
                    <div>
                      <h4 class="font-medium text-white">{a.title}</h4>
                      <p class="text-sm text-zinc-500">{a.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Formação Médica</h3>
              <p class="text-zinc-400 mb-6">Formou-se na LSU Medical School em Nova Orleans com honras. Residência em Medicina Interna na Universidade do Alabama.</p>
              <div class="space-y-6">
                {[
                  { year: '2020', title: 'Royal College of Surgeons de Harvard', desc: 'Parceria para habilitar tecnologia e focar na missão.' },
                  { year: '2015', title: 'Fellowship, Royal College of Physicians', desc: 'Diretora do Laboratório de Cateterização Cardíaca.' },
                  { year: '2015', title: 'Residência, Hospital St. Harvard', desc: 'Instrutor de Medicina na USC.' },
                ].map((t) => (
                  <div key={t.year} class="flex gap-6">
                    <span class="text-sky-400 font-bold shrink-0 w-16">{t.year}</span>
                    <div>
                      <h4 class="font-medium text-white">{t.title}</h4>
                      <p class="text-zinc-500 text-sm mt-1">{t.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Habilidades</h3>
              <p class="text-zinc-400 mb-6">Chief Resident de Medicina Interna. Formou-se no top quartil da turma.</p>
              <div class="space-y-4">
                {[
                  { label: 'Reabilitação Cardíaca', pct: 95 },
                  { label: 'Cardiologia Nuclear', pct: 87 },
                  { label: 'Cuidados Neurocríticos', pct: 81 },
                ].map((p) => (
                  <div key={p.label}>
                    <div class="flex justify-between text-sm mb-2">
                      <span class="text-zinc-400">{p.label}</span>
                      <span class="text-sky-400 font-medium">{p.pct}%</span>
                    </div>
                    <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
                      <div class="h-full bg-sky-600 rounded-full" style={`width: ${p.pct}%`} />
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <section class="rounded-xl overflow-hidden p-6 md:p-8" style={`background-image: url(${refImg(slug, 'img-006.jpg')}); background-size: cover;`}>
              <div class="bg-sky-900/90 backdrop-blur rounded-xl p-6 md:p-8">
                <h3 class="text-2xl font-semibold text-white mb-2">Agendar Consulta</h3>
                <p class="text-sky-100 mb-6">Entre em contato com nossa equipe. Nossos médicos atendem chamadas urgentes.</p>
                <form class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  <select class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white">
                    <option value="">Escolha a Clínica</option>
                  </select>
                  <select class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white">
                    <option value="">Escolha o Médico</option>
                    <option>Ahmed Abdallah</option>
                    <option>Maria Andaloro</option>
                  </select>
                  <input type="text" placeholder="Nome" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
                  <input type="email" placeholder="E-mail" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
                  <input type="tel" placeholder="Telefone" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
                  <input type="date" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white" />
                  <input type="time" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white" />
                  <button type="submit" class="sm:col-span-2 lg:col-span-3 w-full py-4 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg flex items-center justify-center gap-2 transition">
                    Agendar Consulta <span>→</span>
                  </button>
                </form>
              </div>
            </section>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
