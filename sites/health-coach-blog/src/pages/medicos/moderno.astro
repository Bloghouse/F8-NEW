---
/**
 * Página de médicos layout moderno (carrossel/cards)
 * Baseada em demos-medcity-doctors-modern
 * Hero + grid de 6 médicos com efeito hover e ícones sociais
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import config from '../../config';
import { refImg, REF } from '../../lib/reference';

const slug = REF.doctorsModern;
const medicos = [
  { nome: 'Mike Dooley', cargo: 'Especialista em Cardiologia', img: 'img-003.jpg', desc: 'Formou-se em Engenharia Biomédica na Tulane University.' },
  { nome: 'Richard Muldoone', cargo: 'Especialista em Cardiologia', img: 'img-004.jpg', desc: 'Especialista em tratamentos de pele, cabelo e membranas mucosas.' },
  { nome: 'Maria Andaloro', cargo: 'Pediatra', img: 'img-005.jpg', desc: '3 anos de residência em pediatria. Aprovada no American Board of Pediatrics.' },
  { nome: 'Dupree Black', cargo: 'Urologista', img: 'img-006.jpg', desc: 'Diagnostica e trata doenças do trato urinário e reprodutivo.' },
  { nome: 'Markus Skar', cargo: 'Laboratório', img: 'img-007.jpg', desc: 'Responsável por testes que fornecem informações cruciais.' },
  { nome: 'Kiano Barker', cargo: 'Patologista', img: 'img-008.jpg', desc: 'Fornece informações aos médicos para tratamento adequado.' },
];
---

<BaseLayout title={`Nossos Médicos | Layout Moderno | ${config.siteName}`} description="Conheça nossa equipe de médicos com layout moderno.">
  <article>
    <section class="relative min-h-[350px] flex items-center py-24" style={`background-image: url(${refImg(slug, 'img-009.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/60" />
      <div class="container mx-auto px-4 relative z-10 max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Cuidando dos Mais Necessitados na Comunidade.</h1>
        <p class="text-sky-100 mb-6">Estamos presentes desde 1990, com soluções inovadoras e especialização em serviços médicos.</p>
        <a href="/agendar" class="inline-flex items-center gap-2 px-6 py-3 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg transition">
          Agendar Consulta <span>→</span>
        </a>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {medicos.map((m) => (
            <article class="group bg-[#111] rounded-xl overflow-hidden border border-zinc-800">
              <div class="relative overflow-hidden">
                <img src={refImg(slug, m.img)} alt={m.nome} class="w-full aspect-[4/5] object-cover transition group-hover:scale-105" />
                <div class="absolute inset-0 bg-sky-600/80 opacity-0 group-hover:opacity-100 transition flex items-center justify-center gap-4">
                  <a href="#" class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white hover:bg-white/30" aria-label="Facebook">f</a>
                  <a href="#" class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white hover:bg-white/30" aria-label="Twitter">t</a>
                  <a href="tel:+5511999999999" class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white hover:bg-white/30" aria-label="Telefone">📞</a>
                </div>
              </div>
              <div class="p-6">
                <h2 class="text-xl font-semibold text-white">
                  <a href="/medicos/dr-1" class="hover:text-sky-400">{m.nome}</a>
                </h2>
                <p class="text-sky-400 font-medium">{m.cargo}</p>
                <p class="text-zinc-400 text-sm mt-3">{m.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <nav class="flex justify-center gap-2 mt-12" aria-label="Paginação">
          <a href="#" class="px-4 py-2 bg-sky-600 text-white rounded-lg font-medium">1</a>
          <a href="#" class="px-4 py-2 text-zinc-400 hover:text-white rounded-lg">2</a>
          <a href="#" class="px-4 py-2 text-zinc-400 hover:text-white rounded-lg">→</a>
        </nav>
      </div>
    </section>
  </article>
</BaseLayout>
