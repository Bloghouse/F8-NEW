---
/**
 * Página Contato - baseada em public/reference/contacts.html/
 * Formulário e informações de contato do template Melanie Hanson
 * Imagens: /reference/contacts.html/images/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title={`Contato | ${siteConfig.siteName}`}
  description="Entre em contato conosco. Interessado em programas, eventos ou quer sugerir um tema? Use o formulário abaixo."
>
  <article class="contato-page">
    <!-- Hero -->
    <section class="py-20 px-6 bg-white text-gray-800">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Entre em Contato</h1>
        <p class="text-gray-600">Precisa falar conosco? Use o formulário abaixo!</p>
        <p class="text-gray-500 mt-2">Se você está interessado em qualquer um dos nossos programas ou eventos, quer me contratar para falar, ou quer sugerir um tema para um futuro post no blog, use o formulário abaixo e um membro da minha equipe entrará em contato.</p>
      </div>
    </section>

    <!-- Info -->
    <section class="py-12 px-6 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8 text-center">
          <div>
            <div class="w-12 h-12 rounded-full bg-[#efa758]/20 flex items-center justify-center mx-auto mb-4 text-[#efa758] text-xl">📍</div>
            <h3 class="font-bold text-gray-800 mb-2">Endereço</h3>
            <p class="text-gray-600">143 Rua Exemplo,<br />São Paulo, SP 01310-100</p>
          </div>
          <div>
            <div class="w-12 h-12 rounded-full bg-[#efa758]/20 flex items-center justify-center mx-auto mb-4 text-[#efa758] text-xl">✉</div>
            <h3 class="font-bold text-gray-800 mb-2">E-mail</h3>
            <p class="text-gray-600">info@exemplo.com<br />www.exemplo.com</p>
          </div>
          <div>
            <div class="w-12 h-12 rounded-full bg-[#efa758]/20 flex items-center justify-center mx-auto mb-4 text-[#efa758] text-xl">📞</div>
            <h3 class="font-bold text-gray-800 mb-2">Telefone</h3>
            <p class="text-gray-600">+55 (11) 1234-5678<br />+55 (11) 1234-5679</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Form -->
    <section class="py-20 px-6 bg-white">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-800 mb-4">Fale Conosco</h2>
        <p class="text-gray-600 mb-8">Envie-me um e-mail com algumas palavras sobre o que você deseja alcançar e podemos agendar uma consulta inicial GRATUITA para discutir seu histórico de saúde e objetivos.</p>
        <form class="space-y-6" action="/contato" method="get">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Seu nome</label>
              <input type="text" id="name" name="name" required placeholder="Seu nome" class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-[#efa758] focus:border-transparent" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Seu e-mail</label>
              <input type="email" id="email" name="email" required placeholder="Seu e-mail" class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-[#efa758] focus:border-transparent" />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Sua mensagem</label>
            <textarea id="message" name="message" required rows="5" placeholder="Sua mensagem" class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-[#efa758] focus:border-transparent"></textarea>
          </div>
          <button type="submit" class="px-8 py-4 bg-[#efa758] hover:bg-[#e09540] text-white font-semibold rounded transition-colors">Enviar Mensagem</button>
        </form>
      </div>
    </section>

    <nav class="py-8 px-6 text-center">
      <a href="/inicio" class="text-[#efa758] hover:underline">← Voltar ao Início</a>
    </nav>
  </article>
</BaseLayout>
