---
/**
 * Header - navegação principal
 * Logo, nav desktop, menu hambúrguer mobile, ícone tema
 */
import { siteConfig } from '../config';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/' || currentPath === '';
  return currentPath === href || (href !== '/inicio' && currentPath.startsWith(href));
};
---

<header class="fixed top-0 left-0 right-0 z-50 py-4 md:py-6 bg-[var(--color-bg)]/95 backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="max-w-7xl mx-auto px-4 md:px-6 flex items-center justify-between gap-4">
    <a href="/inicio" class="font-display text-xl md:text-2xl font-semibold text-white tracking-tight shrink-0">{siteConfig.siteName}</a>

    <nav class="hidden lg:flex items-center gap-4 xl:gap-6 flex-wrap justify-end" aria-label="Navegação principal">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-xs xl:text-sm uppercase tracking-widest text-white/90 hover:text-white transition-colors whitespace-nowrap',
            isActive(item.href) && 'text-white font-medium',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <button type="button" id="menu-toggle" class="lg:hidden w-10 h-10 rounded-lg border border-white/30 flex items-center justify-center text-white/90 hover:bg-white/5 transition-colors" aria-label="Abrir menu" aria-expanded="false">
        <svg class="w-5 h-5 menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-5 h-5 menu-icon-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <button type="button" class="hidden lg:flex w-10 h-10 rounded-full border border-white/30 items-center justify-center text-white/70 hover:border-white/50 transition-colors" aria-label="Alternar tema">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </div>

  <div id="menu-mobile" class="lg:hidden hidden absolute top-full left-0 right-0 bg-[var(--color-bg)] border-b border-[var(--color-border)] shadow-lg" role="dialog" aria-label="Menu de navegação">
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1" aria-label="Navegação mobile">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block py-3 px-4 rounded-lg text-sm uppercase tracking-widest text-white/90 hover:text-white hover:bg-white/5 transition-colors',
            isActive(item.href) && 'text-white font-medium bg-white/10',
          ]}
          data-close-menu
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    const menu = document.getElementById('menu-mobile');
    const btn = document.getElementById('menu-toggle');
    const openIcon = btn?.querySelector('.menu-icon-open');
    const closeIcon = btn?.querySelector('.menu-icon-close');
    if (!menu || !btn) return;
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Abrir menu' : 'Fechar menu');
    openIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });
  document.querySelectorAll('[data-close-menu]').forEach((el) => {
    el.addEventListener('click', () => {
      document.getElementById('menu-mobile')?.classList.add('hidden');
      document.getElementById('menu-toggle')?.setAttribute('aria-expanded', 'false');
      document.querySelector('.menu-icon-open')?.classList.remove('hidden');
      document.querySelector('.menu-icon-close')?.classList.add('hidden');
    });
  });
</script>
