---
/**
 * Footer - rodapé estilo Mivon
 */
import { siteConfig } from '../config';
const currentYear = new Date().getFullYear();
---

<footer class="py-12 px-6 border-t border-[var(--color-border)]">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <p class="text-white/50 text-sm">© {currentYear} {siteConfig.name}. All rights reserved.</p>
    <nav class="flex gap-6">
      {siteConfig.nav.map((item) => (
        <a href={item.href} class="text-white/50 hover:text-white text-sm transition-colors">{item.label}</a>
      ))}
    </nav>
  </div>
</footer>
