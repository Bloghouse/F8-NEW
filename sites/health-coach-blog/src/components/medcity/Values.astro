---
/**
 * Values - seção com avaliação, CTA e valores da clínica (8 ícones)
 * Medcity core values: Medical Advices, Trusted Treatment, Emergency 24/7, etc.
 */
const values = [
  'Consultas e check-ups médicos',
  'Tratamento médico confiável',
  'Ajuda de emergência 24h',
  'Profissionais em pesquisa médica',
  'Apenas médicos qualificados',
  'Instalações de ponta',
  'Preços acessíveis para todos',
  'Cuidado de qualidade para cada paciente',
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12 mb-16">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-3xl font-bold text-amber-500">4,9</span>
          <span class="text-gray-500">Avaliação geral</span>
        </div>
        <p class="text-gray-600 text-sm">Baseado em 7541 avaliações.</p>
      </div>
      <a href="/contato" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-sky-600 text-white font-semibold hover:bg-sky-700 transition-colors w-fit">
        Agendar consulta
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-sky-900 mb-6">
          O Medcity tocou a vida de pacientes e oferece cuidado aos mais necessitados da nossa comunidade.
        </h2>
        <p class="text-gray-600 mb-6">
          O Medcity está presente desde 1990, oferecendo soluções inovadoras e especializadas em serviços médicos e infraestrutura. Com mais de 100 profissionais, participamos de diversas iniciativas voltadas à mudança sustentável para os pacientes.
        </p>
        <h3 class="text-lg font-bold text-sky-900 mb-4">Nossos valores</h3>
      </div>
      <div class="grid grid-cols-2 gap-3">
        {values.map((v) => (
          <div class="flex items-center gap-3 p-3 rounded-lg bg-sky-50">
            <div class="w-8 h-8 rounded-full bg-sky-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-sm font-medium text-sky-900">{v}</span>
          </div>
        ))}
      </div>
    </div>
    <p class="mt-8 text-center text-gray-600">
      Esperamos poder cuidar de você e ser a primeira e melhor escolha em saúde. <a href="/contato" class="text-sky-600 font-semibold hover:underline">Entre em contato para mais informações</a>.
    </p>
  </div>
</section>
