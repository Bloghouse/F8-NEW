---
/**
 * Process - passos do processo (5 etapas numeradas)
 */
const steps = [
  { num: '01', title: 'Preencha nosso formulário médico', desc: 'O Medcity oferece cobertura de baixo custo para adultos com renda limitada.' },
  { num: '02', title: 'Revise o histórico médico da família', desc: 'Exames regulares ajudam a encontrar problemas precocemente.' },
  { num: '03', title: 'Escolha entre nossos programas de cuidado', desc: 'Temos protocolos para proteger os pacientes mantendo o cuidado necessário.' },
  { num: '04', title: 'Conheça nossos médicos qualificados', desc: 'Nossa equipe possui habilidades excepcionais para auxiliá-lo.' },
  { num: '05', title: 'Seu próximo processo personalizado', desc: 'Nossa equipe está treinada para auxiliar você.' },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-sky-900 mb-4">
        Cuidando da saúde de você e da sua família
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Oferecemos todos os aspectos da prática médica para toda a sua família. Desenvolvemos planos personalizados incluindo tratamento de doenças crônicas.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {steps.slice(0, 3).map((s) => (
        <div class="flex gap-4 p-6 rounded-xl border border-sky-100 bg-sky-50/50">
          <span class="text-3xl font-bold text-sky-600 flex-shrink-0">{s.num}</span>
          <div>
            <h3 class="font-bold text-sky-900 mb-2">{s.title}</h3>
            <p class="text-sm text-gray-600">{s.desc}</p>
            <a href="/contato" class="text-sky-600 font-semibold text-sm mt-2 inline-block hover:underline">Iniciar →</a>
          </div>
        </div>
      ))}
    </div>
    <div class="grid md:grid-cols-2 gap-8 mt-8 max-w-4xl mx-auto">
      {steps.slice(3).map((s) => (
        <div class="flex gap-4 p-6 rounded-xl border border-sky-100 bg-sky-50/50">
          <span class="text-3xl font-bold text-sky-600 flex-shrink-0">{s.num}</span>
          <div>
            <h3 class="font-bold text-sky-900 mb-2">{s.title}</h3>
            <p class="text-sm text-gray-600">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
