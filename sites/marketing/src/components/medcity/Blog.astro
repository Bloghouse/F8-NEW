---
/**
 * Blog - seção "Biblioteca de recursos" com artigos recentes
 * Imagens: img-015, img-016, img-017 = blog grid 1, 2, 3
 */
const imgBase = '/reference/demos-medcity-about-us.html/images';
const posts = [
  { title: '6 dicas para proteger sua saúde mental quando estiver doente', category: 'Saúde mental', date: '30 jan 2022', author: 'Martin King', img: 'img-015.jpg' },
  { title: 'Dúvidas sobre usar máscara? Veja como e por quê', category: 'Dicas infecciosas', date: '30 jan 2022', author: 'John Ezak', img: 'img-016.jpg' },
  { title: 'Dicas para comer saudável quando estiver trabalhando em casa', category: 'Estilo de vida', date: '28 jan 2022', author: 'Saul Wade', img: 'img-017.jpg' },
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-sky-900 mb-2">Biblioteca de recursos</h2>
      <h3 class="text-xl text-gray-600">Artigos recentes</h3>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {posts.map((p) => (
        <article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="aspect-video overflow-hidden">
            <img src={`${imgBase}/${p.img}`} alt="" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <span class="text-xs font-medium text-sky-600">{p.category}</span>
            <span class="text-xs text-gray-400 ml-2">{p.date} — {p.author}</span>
            <h3 class="text-lg font-bold text-sky-900 mt-2 mb-2 line-clamp-2">{p.title}</h3>
            <p class="text-sm text-gray-600 mb-4">
              É normal sentir ansiedade, preocupação e tristeza ao ser diagnosticado. Veja como cuidar de si mesmo...
            </p>
            <a href="/blog" class="text-sky-600 font-semibold text-sm hover:underline">
              Leia mais →
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
