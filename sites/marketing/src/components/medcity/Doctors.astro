---
/**
 * Doctors - apresentação da equipe médica (cards com foto, nome, especialidade, bio)
 * Imagens: img-006 a img-011 = team 4,5,6,1,2,3
 */
const imgBase = '/reference/demos-medcity-about-us.html/images';
const doctors = [
  { name: 'Mike Dooley', specialty: 'Cardiologista', bio: 'Graduado em Engenharia Biomédica pela Tulane University.', img: 'img-009.jpg' },
  { name: 'Maria Andaloro', specialty: 'Pediatra', bio: 'Formada em medicina e residência de 3 anos em pediatria.', img: 'img-010.jpg' },
  { name: 'Dupree Black', specialty: 'Urologista', bio: 'Diagnóstico e tratamento do trato urinário e reprodutivo.', img: 'img-011.jpg' },
  { name: 'Markus Skar', specialty: 'Laboratório', bio: 'Papel fundamental no cuidado à saúde com análises clínicas.', img: 'img-006.jpg' },
  { name: 'Kiano Barker', specialty: 'Patologista', bio: 'Auxilia médicos com informações para o cuidado adequado.', img: 'img-007.jpg' },
  { name: 'Ana Silva', specialty: 'Clínica Geral', bio: 'Atendimento humanizado para toda a família.', img: 'img-008.jpg' },
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-sky-900 mb-4">Conheça nossa equipe</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Nossa equipe administrativa e de suporte possui habilidades excepcionais e está treinada para auxiliar em todas as suas necessidades médicas.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6">
      {doctors.map((d) => (
        <article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="aspect-[4/5] overflow-hidden">
            <img src={`${imgBase}/${d.img}`} alt={d.name} class="w-full h-full object-cover" />
          </div>
          <div class="p-4">
            <h3 class="font-bold text-sky-900">{d.name}</h3>
            <p class="text-sm text-sky-600 mb-2">{d.specialty}</p>
            <p class="text-xs text-gray-600 line-clamp-2">{d.bio}</p>
            <a href="/sobre" class="text-sky-600 font-semibold text-sm hover:underline mt-2 inline-block">
              Leia mais →
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
