---
/**
 * Cta - chamada para ação "Ajudando pacientes do mundo todo" + vídeo
 * Imagem: img-004 = about (ou img-019 backgrounds)
 */
const imgBase = '/reference/demos-medcity-about-us.html/images';
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-sky-900 mb-6">
          Ajudando pacientes de todo o mundo!
        </h2>
        <p class="text-gray-600 mb-6">
          Nossa equipe se esforça para tornar cada interação clara e acolhedora. Apoie o importante trabalho do Hospital Medcity fazendo uma doação.
        </p>
        <a href="/contato" class="inline-flex items-center gap-2 px-6 py-3 bg-sky-600 text-white rounded-lg font-semibold hover:bg-sky-700 transition-colors">
          Fazer uma doação
        </a>
      </div>
      <div class="aspect-video rounded-xl overflow-hidden relative">
        <img src={`${imgBase}/img-004.jpg`} alt="" class="w-full h-full object-cover" />
        <a href="https://www.youtube.com/watch?v=nrJtHemSPW4" target="_blank" rel="noopener noreferrer" class="absolute inset-0 flex items-center justify-center bg-black/30 hover:bg-black/40 transition-colors">
          <span class="w-20 h-20 rounded-full bg-sky-600 flex items-center justify-center hover:bg-sky-700 transition-colors text-white shadow-lg">
            <svg class="w-10 h-10 ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
