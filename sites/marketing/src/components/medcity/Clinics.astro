---
/**
 * Clinics - grade de clínicas especializadas (Neurologia, Cardiologia, Patologia, etc.)
 * Cards com título, descrição curta, lista e link "Leia mais".
 */
const clinics = [
  {
    title: 'Clínica de Neurologia',
    desc: 'Neurologistas com treinamento em subespecialidades em áreas específicas do campo.',
    items: ['Neurologia geriátrica', 'Neuro-oncologia', 'Cuidados neurocríticos'],
  },
  {
    title: 'Clínica de Cardiologia',
    desc: 'Cardiologistas estudam distúrbios do coração, tanto em adultos quanto em crianças.',
    items: ['Neurologia geriátrica', 'Neuro-oncologia', 'Cuidados neurocríticos'],
  },
  {
    title: 'Clínica de Patologia',
    desc: 'A patologia é a ponte entre a ciência e a medicina, fundamentando cada aspecto do cuidado ao paciente.',
    items: ['Citopatologia', 'Histopatologia', 'Patologia cirúrgica'],
  },
  {
    title: 'Análise laboratorial',
    desc: 'Análise de concentrações com dispositivos passivos e calibração de equipamentos de medição.',
    items: ['Técnicas de reposicionamento', 'Aparência do cordão umbilical', 'Cuidado neonatal'],
  },
  {
    title: 'Clínica pediátrica',
    desc: 'Profissionais pediátricos acompanham pacientes do nascimento até a idade adulta para garantir a saúde das crianças.',
    items: ['Garantia de qualidade', 'Analista de pesquisa', 'Laboratório clínico'],
  },
  {
    title: 'Clínica cardíaca',
    desc: 'Para pacientes que precisam de acompanhamento adicional, a Clínica Cardíaca oferece acesso rápido a especialistas.',
    items: ['Lacrimejamento excessivo', 'Retinopatia diabética', 'Degeneração macular'],
  },
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-sky-900 mb-4">
        Todos os aspectos da prática médica
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        A saúde e o bem-estar dos nossos pacientes e da nossa equipe serão sempre nossa prioridade, por isso seguimos as melhores práticas de higiene e segurança.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {clinics.map((c) => (
        <article class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold text-sky-900 mb-2">{c.title}</h3>
          <p class="text-gray-600 text-sm mb-4">{c.desc}</p>
          <ul class="space-y-1 mb-4 text-sm text-gray-700">
            {c.items.map((item) => (
              <li>• {item}</li>
            ))}
          </ul>
          <a href="/sobre" class="text-sky-600 font-semibold hover:text-sky-700 text-sm">
            Leia mais →
          </a>
        </article>
      ))}
    </div>
    <div class="text-center mt-12">
      <p class="text-gray-600 mb-4">
        Entregando a saúde do amanhã para sua família.
      </p>
      <a href="/contato" class="inline-block px-6 py-3 bg-sky-600 text-white rounded-lg font-semibold hover:bg-sky-700 transition-colors">
        Ver quadro de médicos
      </a>
    </div>
  </div>
</section>
