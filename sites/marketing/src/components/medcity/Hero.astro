---
/**
 * Hero - seção principal do template Medcity
 * Título, subtítulo e CTA. Imagem de fundo da referência.
 */
const imgBase = '/reference/demos-medcity-about-us.html/images';
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src={`${imgBase}/img-020.jpg`} alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-sky-900/60" />
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="max-w-2xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 drop-shadow-lg">
        Proporcionando os melhores cuidados médicos
      </h1>
      <p class="text-lg md:text-xl text-sky-100 mb-8 leading-relaxed">
        A saúde e o bem-estar dos nossos pacientes e da nossa equipe de saúde serão sempre nossa prioridade, por isso seguimos as melhores práticas de higiene e segurança.
      </p>
      <a
        href="/contato"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-white text-sky-700 font-semibold hover:bg-sky-50 transition-colors"
      >
        Agendar consulta
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
