---
/**
 * Listagem do blog - Template Bexon (html-bexon-demo-blog-grid)
 * Grid de posts, tema Bexon, conteúdo em português
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBreadcrumb from '../../components/PageBreadcrumb.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config';

const REF = 'html-bexon-demo-blog-grid.html';
const img = `/reference/${REF}/images`;
const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const gridImages = [`${img}/img-020.svg`, `${img}/img-021.svg`, `${img}/img-020.svg`];
---

<BaseLayout title={`Blog | ${siteConfig.siteName}`} description={siteConfig.siteDescription}>
  <!-- Page title - tema Bexon -->
  <section class="py-16 px-6 bg-[#0c1e21] text-white">
    <div class="max-w-4xl mx-auto text-center">
      <PageBreadcrumb title="Blog" />
      <h1 class="text-4xl font-bold mt-4">Blog</h1>
      <p class="text-white/80 mt-4">Estratégias e insights</p>
    </div>
  </section>
  <!-- Grid de posts - tema Bexon -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <article class="rounded-xl overflow-hidden bg-[#d8e5e5]/30 border border-[#d8e5e5] hover:border-[#1e8a8a] transition-colors">
            <a href={`/blog/${post.slug}`} class="block overflow-hidden">
              <img
                src={post.data.image || `/reference/html-bexon-demo-blog-grid.html/images/img-0${14 + (i % 3)}.webp`}
                alt={post.data.title}
                class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </a>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags?.slice(0, 2).map((tag) => (
                  <span class="px-2 py-0.5 rounded text-xs bg-[#1e8a8a]/20 text-[#1e8a8a]">{tag}</span>
                ))}
              </div>
              <div class="flex gap-3 text-[#364e52] text-sm mb-2">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
                <span>{siteConfig.author}</span>
              </div>
              <h2 class="text-lg font-semibold text-[#0c1e21] mb-3 line-clamp-2">
                <a href={`/blog/${post.slug}`} class="hover:text-[#1e8a8a] transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-[#364e52] text-sm line-clamp-3 mb-4">
                {post.data.description || 'Leia mais sobre este assunto.'}
              </p>
              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center gap-1 text-[#1e8a8a] text-sm font-medium hover:underline min-h-[44px] items-center"
              >
                Ler mais
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
