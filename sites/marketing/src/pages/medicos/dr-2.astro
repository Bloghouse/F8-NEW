---
/**
 * Página individual do Dr. Ahmed Abdallah (layout 2)
 * Baseada em demos-medcity-doctors-single-doctor2
 * Exibe perfil completo com biografia, detalhes, preços, premiações e formulário de agendamento
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import config from '../../config';
import { refImg, REF } from '../../lib/reference';

const slug = REF.doctorsSingleDoctor2;
---

<BaseLayout title={`Dr. Ahmed Abdallah | Médicos | ${config.siteName}`} description="Perfil do Dr. Ahmed Abdallah, especialista em cardiologia. Conheça sua formação, áreas de atuação e agende sua consulta.">
  <article>
    <!-- Hero -->
    <section class="relative min-h-[280px] flex items-end pb-8 pt-24" style={`background-image: url(${refImg(slug, 'img-004.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/60" />
      <div class="container mx-auto px-4 relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-2">Ahmed Abdallah</h1>
        <nav class="text-white/90 text-sm" aria-label="Breadcrumb">
          <ol class="flex flex-wrap gap-2">
            <li><a href="/inicio" class="hover:text-sky-300">Início</a></li>
            <li>/</li>
            <li><a href="/medicos" class="hover:text-sky-300">Médicos</a></li>
            <li>/</li>
            <li class="text-white" aria-current="page">Ahmed Abdallah</li>
          </ol>
        </nav>
      </div>
    </section>

    <!-- Conteúdo principal -->
    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          <!-- Sidebar -->
          <aside class="lg:col-span-4 space-y-6">
            <div class="bg-[#111] rounded-xl overflow-hidden border border-zinc-800">
              <img src={refImg(slug, 'img-003.jpg')} alt="Ahmed Abdallah" class="w-full aspect-square object-cover" />
              <div class="p-6">
                <h2 class="text-xl font-semibold text-white"><a href="/medicos/dr-1" class="hover:text-sky-400">Ahmed Abdallah</a></h2>
                <p class="text-sky-400 font-medium">Especialista em Cardiologia</p>
                <p class="text-zinc-400 text-sm mt-3">Especialista em tratamentos de pele, cabelo, unhas e membranas mucosas. Também atende questões cosméticas.</p>
                <div class="flex gap-3 mt-5">
                  <a href="#" class="text-sky-400 hover:text-sky-300" aria-label="Facebook"><span class="sr-only">Facebook</span>→</a>
                  <a href="#" class="text-sky-400 hover:text-sky-300" aria-label="Twitter">→</a>
                  <a href="tel:+5511999999999" class="text-sky-400 hover:text-sky-300" aria-label="Telefone">📞</a>
                </div>
              </div>
            </div>

            <div class="bg-sky-600 rounded-xl p-6 text-white" style={`background-image: url(${refImg(slug, 'img-005.jpg')}); background-size: cover; background-position: center;`}>
              <div class="relative z-10 bg-sky-900/80 -m-6 p-6 rounded-xl">
                <h3 class="font-semibold text-lg mb-2">Casos de Emergência</h3>
                <p class="text-sm text-sky-100 mb-4">Entre em contato com nossa equipe de recepção para qualquer dúvida geral ou médica.</p>
                <a href="tel:+5511999999999" class="text-sky-300 font-medium">(11) 99999-9999</a>
              </div>
            </div>

            <div class="bg-[#111] rounded-xl p-6 border border-zinc-800">
              <h3 class="font-semibold text-white mb-4">Horário de Funcionamento</h3>
              <ul class="space-y-3 text-sm">
                <li class="flex justify-between text-zinc-400"><span>Segunda - Sexta</span><span>8h - 19h</span></li>
                <li class="flex justify-between text-zinc-400"><span>Sábado</span><span>9h - 22h</span></li>
                <li class="flex justify-between text-zinc-400"><span>Domingo</span><span>10h - 12h</span></li>
              </ul>
            </div>

            <a href="#" class="flex items-center justify-center gap-2 w-full py-3 px-4 bg-sky-600 hover:bg-sky-500 text-white rounded-lg font-medium transition">
              Relatórios de Pacientes 2024
            </a>
          </aside>

          <!-- Conteúdo -->
          <div class="lg:col-span-8 space-y-10">
            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Biografia</h3>
              <p class="text-zinc-400 mb-4 font-medium text-sky-200/90">Um neurologista é um médico com formação especializada no diagnóstico, tratamento e manejo de distúrbios do cérebro e sistema nervoso, incluindo Alzheimer, ELA, concussão, epilepsia, enxaqueca, esclerose múltipla, Parkinson e AVC.</p>
              <p class="text-zinc-400 mb-4">Viajou para Filadélfia para concluir fellowship em Cardiologia Intervencionista no Hahnemann Hospital em conjunto com a Drexel University, onde recebeu treinamento em intervenções coronárias e periféricas.</p>
              <p class="text-zinc-400 mb-4">Tem participação ativa em ensaios clínicos e publicações em periódicos revisados. Atualmente é certificado em Doença Cardiovascular e Cardiologia Intervencionista.</p>
            </div>

            <ul class="space-y-4">
              <li><h4 class="text-sky-400 font-medium">Especialidade</h4><p class="text-zinc-400">Cardiologia</p></li>
              <li><h4 class="text-sky-400 font-medium">Títulos</h4><p class="text-zinc-400">M.D. em Medicina</p></li>
              <li><h4 class="text-sky-400 font-medium">Áreas de Atuação</h4>
                <ul class="list-disc list-inside text-zinc-400 mt-2 space-y-1">
                  <li>Imagem Cardíaca – Não invasiva</li>
                  <li>Reabilitação Cardíaca e Exercício</li>
                  <li>Miocardiopatia Hipertrófica</li>
                  <li>Doenças Cardíacas Hereditárias</li>
                </ul>
              </li>
              <li><h4 class="text-sky-400 font-medium">Consultório</h4><p class="text-zinc-400">Rua Exemplo, 123 - São Paulo, SP</p></li>
              <li><h4 class="text-sky-400 font-medium">Universidade</h4><p class="text-zinc-400">Harvard University</p></li>
            </ul>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Serviços do Médico</h3>
              <p class="text-zinc-400">Participa ativamente de ensaios clínicos e publicou em periódicos como Journal of the State Medical Society. No Hahnemann Hospital recebeu treinamento extensivo em intervenções coronárias e procedimentos de salvamento de membros.</p>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-6">Tabela de Preços dos Tratamentos</h3>
              <div class="grid md:grid-cols-2 gap-6">
                <ul class="space-y-3 text-zinc-400">
                  {['Aparência do Cordão Umbilical', 'Eletrofisiologia Cardíaca', 'Técnicas de Reposicionamento', 'Geriatria Neurológica', 'Cardiologia Nuclear', 'Cardiologia Nuclear'].map((item, i) => (
                    <li key={i} class="flex justify-between py-2 border-b border-zinc-800">
                      <span>{item}</span>
                      <span class="text-sky-400 font-medium">{['R$250', 'R$225', 'R$300', 'R$325', 'R$200', 'R$275'][i]}</span>
                    </li>
                  ))}
                </ul>
                <ul class="space-y-3 text-zinc-400">
                  {['Aparência do Cordão Umbilical', 'Eletrofisiologia Cardíaca', 'Técnicas de Reposicionamento', 'Geriatria Neurológica', 'Cardiologia Nuclear', 'Cardiologia Nuclear'].map((item, i) => (
                    <li key={i} class="flex justify-between py-2 border-b border-zinc-800">
                      <span>{item}</span>
                      <span class="text-sky-400 font-medium">{['R$250', 'R$225', 'R$300', 'R$325', 'R$200', 'R$275'][i]}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Prêmios e Honrarias</h3>
              <p class="text-zinc-400 mb-6">O hospital é reconhecido como instituição de renome mundial, oferecendo cuidados excepcionais e melhorando resultados através de pesquisa médica abrangente.</p>
              <div class="grid sm:grid-cols-2 gap-4">
                {[
                  { title: 'Edison Awards', desc: 'Excelência em inovação' },
                  { title: 'Medalha Edwin Grant', desc: 'Pesquisa em biologia do desenvolvimento' },
                  { title: 'Prêmio Robert L. Noble', desc: 'Sociedade Canadense de Câncer' },
                  { title: 'Prêmio Nacional de Medicina', desc: 'Academia Chilena de Medicina' },
                ].map((a) => (
                  <div key={a.title} class="flex gap-4 p-4 bg-[#111] rounded-lg border border-zinc-800">
                    <div class="w-12 h-12 rounded-full bg-sky-600/30 flex items-center justify-center text-sky-400 shrink-0">◆</div>
                    <div>
                      <h4 class="font-medium text-white">{a.title}</h4>
                      <p class="text-sm text-zinc-500">{a.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Formação Médica</h3>
              <p class="text-zinc-400 mb-6">Concluiu a residência em Medicina Interna na Universidade do Alabama. Formou-se com honras na LSU Medical School em Nova Orleans.</p>
              <div class="space-y-6">
                {[
                  { year: '2020', title: 'Royal College of Surgeons de Harvard', desc: 'Parceria para habilitar sua tecnologia e focar na missão da organização.' },
                  { year: '2015', title: 'Fellowship, Royal College of Physicians de Harvard', desc: 'Diretora do Laboratório de Cateterização Cardíaca no Centro Médico Regional.' },
                  { year: '2015', title: 'Residência, Hospital St. Harvard', desc: 'Instrutor de Medicina, Chief Administrative Fellow na USC.' },
                ].map((t) => (
                  <div key={t.year} class="flex gap-6">
                    <span class="text-sky-400 font-bold shrink-0 w-16">{t.year}</span>
                    <div>
                      <h4 class="font-medium text-white">{t.title}</h4>
                      <p class="text-zinc-500 text-sm mt-1">{t.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="text-2xl font-semibold text-white mb-4">Habilidades do Médico</h3>
              <p class="text-zinc-400 mb-6">Foi selecionado como Chief Resident de Medicina Interna. Formou-se no top quartil da turma na LSU Medical School.</p>
              <div class="space-y-4">
                {[
                  { label: 'Reabilitação Cardíaca', pct: 95 },
                  { label: 'Cardiologia Nuclear', pct: 87 },
                  { label: 'Cuidados Neurocríticos', pct: 81 },
                ].map((p) => (
                  <div key={p.label}>
                    <div class="flex justify-between text-sm mb-2">
                      <span class="text-zinc-400">{p.label}</span>
                      <span class="text-sky-400 font-medium">{p.pct}%</span>
                    </div>
                    <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
                      <div class="h-full bg-sky-600 rounded-full" style={`width: ${p.pct}%`} />
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Formulário Agendamento -->
            <section class="rounded-xl overflow-hidden p-6 md:p-8" style={`background-image: url(${refImg(slug, 'img-006.jpg')}); background-size: cover; background-position: center;`}>
              <div class="bg-sky-900/90 backdrop-blur rounded-xl p-6 md:p-8">
                <h3 class="text-2xl font-semibold text-white mb-2">Agendar Consulta</h3>
                <p class="text-sky-100 mb-6">Entre em contato com nossa equipe para dúvidas. Nossos médicos atendem chamadas urgentes.</p>
                <form class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  <select class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400">
                    <option value="">Escolha a Clínica</option>
                    <option>Clínica de Patologia</option>
                  </select>
                  <select class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white">
                    <option value="">Escolha o Médico</option>
                    <option>Ahmed Abdallah</option>
                    <option>Maria Andaloro</option>
                  </select>
                  <input type="text" placeholder="Nome" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
                  <input type="email" placeholder="E-mail" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
                  <input type="tel" placeholder="Telefone" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-zinc-400" />
                  <input type="date" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white" />
                  <input type="time" class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white" />
                  <button type="submit" class="sm:col-span-2 lg:col-span-3 w-full py-4 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg flex items-center justify-center gap-2 transition">
                    Agendar Consulta
                    <span>→</span>
                  </button>
                </form>
              </div>
            </section>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
