---
/**
 * Página Detalhe do Serviço - Service Details
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-services.html
 * Rota: /servicos/[slug]
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBreadcrumb from '../../components/PageBreadcrumb.astro';
import { siteConfig } from '../../config';
import { IMG_SERVICES } from '../../lib/porto-images';

export function getStaticPaths() {
  return [
    'estrategia-empresarial',
    'experiencia-cliente',
    'suporte-ti',
    'sustentabilidade-esg',
    'treinamento-desenvolvimento',
    'marketing',
  ].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const titulo = slug ? slug.split('-').map((s) => s.charAt(0).toUpperCase() + s.slice(1)).join(' ') : 'Serviço';
---

<BaseLayout
  title={`${titulo} | Serviços | ${siteConfig.siteName}`}
  description={`Conheça nosso serviço de ${titulo}.`}
>
  <article class="porto-servico-detail">
    <section class="py-12 md:py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <PageBreadcrumb items={[
          { label: 'Início', href: '/inicio' },
          { label: 'Serviços', href: '/servicos' },
          { label: titulo },
        ]} />
        <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-accent-secondary)] mt-6">{titulo}</h1>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="aspect-video rounded-xl overflow-hidden mb-8 bg-[var(--color-bg-elevated)]">
          <img src={IMG_SERVICES('img-001.png')} alt="" class="w-full h-full object-cover" />
        </div>
        <div class="prose prose-invert max-w-none">
          <p class="text-[var(--color-body-2)] text-lg leading-relaxed mb-6">Oferecemos soluções personalizadas para impulsionar o crescimento do seu negócio. Nossa abordagem combina análise de dados, estratégias inovadoras e acompanhamento contínuo.</p>
          <h2 class="text-2xl font-bold text-white mt-12 mb-4">O que incluímos</h2>
          <ul class="list-disc list-inside text-[var(--color-body-2)] space-y-2">
            <li>Diagnóstico e análise inicial</li>
            <li>Plano de ação personalizado</li>
            <li>Implementação com suporte</li>
            <li>Relatórios e acompanhamento</li>
          </ul>
        </div>
        <div class="mt-12 flex flex-wrap gap-4">
          <a href="/contato" class="inline-flex items-center gap-2 px-6 py-4 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium rounded-lg transition-colors">
            Solicitar Orçamento →
          </a>
          <a href="/servicos" class="inline-flex items-center gap-2 text-[var(--color-accent)] hover:underline font-medium">
            ← Voltar para Serviços
          </a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
