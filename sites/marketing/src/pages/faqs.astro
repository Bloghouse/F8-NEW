---
/**
 * Página FAQs - Perguntas Frequentes
 * Baseada em public/reference/html-bexon-demo-faq.html/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumb from '../components/PageBreadcrumb.astro';
import { siteConfig } from '../config';

const REF = 'html-bexon-demo-faq.html';
const IMG = (file: string) => `/reference/${REF}/images/${file}`;

const faqs = [
  { pergunta: 'Quais serviços a empresa oferece aos clientes?', resposta: 'Oferecemos consultoria em estratégia empresarial, experiência do cliente, sustentabilidade e ESG, treinamento e desenvolvimento, suporte de TI e estratégias de marketing. Entre em contato para uma consultoria inicial.' },
  { pergunta: 'Como começar com os serviços empresariais?', resposta: 'Basta entrar em contato através do nosso formulário ou ligar. Agendaremos uma consultoria para discutir seu projeto e como podemos ajudar. Mantemos você informado durante todo o processo.' },
  { pergunta: 'Como garantem o sucesso do projeto?', resposta: 'Utilizamos metodologias comprovadas, equipe dedicada e acompanhamento contínuo. Trabalhamos em estreita colaboração com você para garantir qualidade e entrega no prazo.' },
  { pergunta: 'Quanto tempo leva para concluir meu projeto?', resposta: 'O prazo depende da complexidade. Após a consultoria inicial, apresentaremos um cronograma detalhado. Projetos típicos levam de 4 a 12 semanas.' },
  { pergunta: 'Posso acompanhar o progresso do meu projeto?', resposta: 'Sim. Oferecemos relatórios regulares e acesso a uma plataforma onde você pode acompanhar o andamento em tempo real.' },
];
---

<BaseLayout title={`FAQs | ${siteConfig.siteName}`} description="Perguntas frequentes. Encontre respostas para as dúvidas mais comuns.">
  <article>
    <section class="py-16 px-6 bg-[#0c1e21] text-white">
      <div class="max-w-4xl mx-auto text-center">
        <PageBreadcrumb title="FAQs" />
        <h1 class="text-4xl font-bold mt-4">Perguntas Frequentes</h1>
      </div>
    </section>

    <section class="py-20 px-6 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-[#0c1e21] mb-8">Precisa de Ajuda? Comece Aqui.</h2>
        <div class="space-y-2">
          {faqs.map((faq, i) => (
            <details class="group border border-[#d8e5e5] rounded-lg overflow-hidden">
              <summary class="px-6 py-4 cursor-pointer font-semibold text-[#0c1e21] hover:bg-[#d8e5e5]/50 list-none flex items-center justify-between">
                {faq.pergunta}
                <span class="text-[#1e8a8a] group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <div class="px-6 py-4 bg-[#d8e5e5]/30 text-[#364e52]">
                {faq.resposta}
              </div>
            </details>
          ))}
        </div>
        <div class="mt-12 p-6 bg-[#d8e5e5] rounded-lg text-center">
          <h3 class="font-bold text-[#0c1e21] mb-2">Quer uma consultoria gratuita?</h3>
          <a href="tel:1188884521505" class="text-[#1e8a8a] font-semibold text-lg">(11) 8888-4521</a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
