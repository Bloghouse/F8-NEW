---
/**
 * Página detalhe de Case
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-case-studies-details.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBreadcrumb from '../../components/PageBreadcrumb.astro';
import { siteConfig } from '../../config';

export function getStaticPaths() {
  return [
    { params: { slug: 'okler-themes' } },
    { params: { slug: 'porto' } },
    { params: { slug: 'envato' } },
    { params: { slug: 'theme-forest' } },
    { params: { slug: 'code-canyon' } },
  ];
}

const { slug } = Astro.params;
const titles: Record<string, string> = {
  'okler-themes': 'Okler Themes',
  'porto': 'Porto',
  'envato': 'Envato',
  'theme-forest': 'Theme Forest',
  'code-canyon': 'Code Canyon',
};
const title = titles[slug || ''] || 'Case';
---

<BaseLayout
  title={`${title} | Cases | ${siteConfig.siteName}`}
  description={`Case de sucesso: ${title}. Resultados de marketing e estratégia.`}
>
  <article class="porto-case-detail">
    <section class="py-12 md:py-16 bg-[var(--color-bg-light)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <PageBreadcrumb items={[
          { label: 'Início', href: '/inicio' },
          { label: 'Cases', href: '/cases' },
          { label: title },
        ]} />
        <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-accent-secondary)] mt-6">{title}</h1>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="prose prose-invert max-w-none">
          <p class="text-[var(--color-body-2)] text-lg leading-relaxed mb-6">Este projeto demonstra nossa capacidade de entregar resultados significativos através de estratégias de marketing integradas. Trabalhamos em estreita colaboração com o cliente para entender seus objetivos e superar as expectativas.</p>
          <h2 class="text-2xl font-bold text-white mt-12 mb-4">Desafio</h2>
          <p class="text-[var(--color-body-2)] mb-6">O cliente precisava ampliar seu alcance e aumentar a conversão em um mercado competitivo.</p>
          <h2 class="text-2xl font-bold text-white mt-8 mb-4">Solução</h2>
          <p class="text-[var(--color-body-2)] mb-6">Desenvolvemos uma estratégia integrada combinando pesquisa de mercado, posicionamento de marca e campanhas digitais direcionadas.</p>
          <h2 class="text-2xl font-bold text-white mt-8 mb-4">Resultados</h2>
          <ul class="list-disc list-inside text-[var(--color-body-2)] space-y-2">
            <li>Aumento significativo em conversões</li>
            <li>Maior engajamento nas redes sociais</li>
            <li>Crescimento da base de clientes</li>
          </ul>
        </div>
        <div class="mt-12">
          <a href="/cases" class="inline-flex items-center gap-2 text-[var(--color-accent)] hover:underline font-medium">
            ← Voltar aos cases
          </a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
