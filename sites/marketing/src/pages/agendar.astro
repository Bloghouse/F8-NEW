---
/**
 * Página de Agendamento de Consultas
 * Baseada em demos-medcity-appointment
 * Hero + grid de médicos + formulário de agendamento
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import config from '../config';
import { refImg, REF } from '../lib/reference';

const slug = REF.appointment;
const medicos = [
  { nome: 'Dupree Black', cargo: 'Urologista', img: 'img-003.jpg' },
  { nome: 'Markus Skar', cargo: 'Laboratório', img: 'img-004.jpg' },
  { nome: 'Kiano Barker', cargo: 'Patologista', img: 'img-005.jpg' },
  { nome: 'Mike Dooley', cargo: 'Cardiologia', img: 'img-006.jpg' },
  { nome: 'Richard Muldoone', cargo: 'Cardiologia', img: 'img-007.jpg' },
  { nome: 'Maria Andaloro', cargo: 'Pediatra', img: 'img-008.jpg' },
];
---

<BaseLayout title={`Agendar Consulta | ${config.siteName}`} description="Agende sua consulta com nossos médicos especialistas. Preencha o formulário e nossa equipe entrará em contato.">
  <article>
    <section class="relative min-h-[350px] flex items-center justify-center py-24 text-center" style={`background-image: url(${refImg(slug, 'img-013.jpg')}); background-size: cover; background-position: center;`}>
      <div class="absolute inset-0 bg-sky-900/60" />
      <div class="container mx-auto px-4 relative z-10 max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Melhore a Qualidade de Vida Através de Melhor Saúde.</h1>
        <p class="text-sky-100 mb-6">Estamos presentes desde 1990, com soluções inovadoras em serviços médicos para tratamento e infraestrutura médica.</p>
        <a href="#formulario" class="inline-flex items-center gap-2 px-6 py-3 border border-sky-400 text-sky-300 hover:bg-sky-900/50 rounded-lg transition">
          Encontrar um Médico <span>→</span>
        </a>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-2xl font-bold text-white mb-2">Conheça Nossos Médicos</h2>
          <p class="text-zinc-400">Nossa equipe administrativa e de apoio possui habilidades excepcionais para auxiliá-lo em todas as suas dúvidas médicas.</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 mb-20">
          {medicos.map((m) => (
            <a href="#formulario" class="group text-center">
              <div class="rounded-xl overflow-hidden aspect-square mb-3 border border-zinc-800 group-hover:border-sky-600/50 transition">
                <img src={refImg(slug, m.img)} alt={m.nome} class="w-full h-full object-cover" />
              </div>
              <h3 class="font-medium text-white group-hover:text-sky-400">{m.nome}</h3>
              <p class="text-sm text-zinc-500">{m.cargo}</p>
            </a>
          ))}
        </div>

        <div id="formulario" class="max-w-3xl mx-auto">
          <div class="bg-[#111] rounded-xl p-6 md:p-8 border border-zinc-800">
            <h3 class="text-2xl font-semibold text-white mb-2">Agendar Consulta</h3>
            <p class="text-zinc-400 mb-8">Preencha o formulário abaixo. Nossa equipe entrará em contato para confirmar o agendamento.</p>
            <form class="space-y-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="clinica" class="block text-sm text-zinc-400 mb-2">Clínica</label>
                  <select id="clinica" name="clinica" class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white">
                    <option value="">Escolha a Clínica</option>
                    <option>Clínica de Patologia</option>
                    <option>Clínica de Cardiologia</option>
                    <option>Clínica de Neurologia</option>
                  </select>
                </div>
                <div>
                  <label for="medico" class="block text-sm text-zinc-400 mb-2">Médico</label>
                  <select id="medico" name="medico" class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white">
                    <option value="">Escolha o Médico</option>
                    {medicos.map((m) => (
                      <option key={m.nome}>{m.nome}</option>
                    ))}
                  </select>
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="nome" class="block text-sm text-zinc-400 mb-2">Nome</label>
                  <input type="text" id="nome" name="nome" required placeholder="Seu nome" class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500" />
                </div>
                <div>
                  <label for="email" class="block text-sm text-zinc-400 mb-2">E-mail</label>
                  <input type="email" id="email" name="email" required placeholder="seu@email.com" class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500" />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                  <label for="telefone" class="block text-sm text-zinc-400 mb-2">Telefone</label>
                  <input type="tel" id="telefone" name="telefone" required placeholder="(11) 99999-9999" class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500" />
                </div>
                <div>
                  <label for="data" class="block text-sm text-zinc-400 mb-2">Data preferida</label>
                  <input type="date" id="data" name="data" required class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white" />
                </div>
                <div>
                  <label for="hora" class="block text-sm text-zinc-400 mb-2">Horário preferido</label>
                  <input type="time" id="hora" name="hora" required class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white" />
                </div>
              </div>
              <div>
                <label for="mensagem" class="block text-sm text-zinc-400 mb-2">Mensagem (opcional)</label>
                <textarea id="mensagem" name="mensagem" rows="3" placeholder="Descreva brevemente o motivo da consulta" class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 resize-none"></textarea>
              </div>
              <button type="submit" class="w-full py-4 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg flex items-center justify-center gap-2 transition">
                Agendar Consulta
                <span>→</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
