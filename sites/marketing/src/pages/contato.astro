---
/**
 * Página Contato
 * Template: Porto Marketing - previews-porto-13.0.0-demo-marketing-1-contact-us.html
 * Formulário de contato, email e telefone.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumb from '../components/PageBreadcrumb.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title={`Contato | ${siteConfig.siteName}`}
  description="Entre em contato. Estamos prontos para elevar sua marca."
>
  <article class="porto-contato">
    <section class="py-12 md:py-16 bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-secondary)]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <h1 class="text-3xl md:text-5xl font-bold text-white">Contato</h1>
          <PageBreadcrumb items={[
            { label: 'Início', href: '/inicio' },
            { label: 'Contato' },
          ]} />
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid lg:grid-cols-2 gap-16">
          <div>
            <span class="inline-block bg-[var(--color-accent)]/20 text-white text-sm font-medium px-4 py-1 rounded-full mb-6">Vamos lá</span>
            <h2 class="text-2xl md:text-4xl font-bold text-white mb-6">Pronto para elevar sua marca? Fale conosco.</h2>
            <p class="text-[var(--color-body-2)] text-lg mb-8">Estamos animados para ouvir você! Seja para iniciar um novo projeto, obter orientação sobre sua estratégia de marketing ou saber mais sobre nossos serviços.</p>
            <ul class="space-y-6">
              <li>
                <a href={`mailto:${siteConfig.contactEmail}`} class="text-xl font-semibold text-white hover:text-[var(--color-accent)] transition-colors">{siteConfig.contactEmail}</a>
              </li>
              <li>
                <a href="tel:+5511999999999" class="text-xl font-semibold text-white hover:text-[var(--color-accent)] transition-colors">(11) 99999-9999</a>
              </li>
            </ul>
          </div>
          <div>
            <form class="space-y-6" action="#" method="post">
              <div>
                <label for="nome" class="block text-sm font-medium text-white mb-2">Nome</label>
                <input type="text" id="nome" name="nome" required class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-elevated)] border border-[var(--color-border)] text-white placeholder-white/40 focus:ring-2 focus:ring-[var(--color-accent)] min-h-[44px]" placeholder="Seu nome" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-white mb-2">E-mail</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-elevated)] border border-[var(--color-border)] text-white placeholder-white/40 focus:ring-2 focus:ring-[var(--color-accent)] min-h-[44px]" placeholder="seu@email.com" />
              </div>
              <div>
                <label for="mensagem" class="block text-sm font-medium text-white mb-2">Mensagem</label>
                <textarea id="mensagem" name="mensagem" rows="5" required class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-elevated)] border border-[var(--color-border)] text-white placeholder-white/40 focus:ring-2 focus:ring-[var(--color-accent)] min-h-[120px]" placeholder="Como podemos ajudar?"></textarea>
              </div>
              <button type="submit" class="w-full md:w-auto px-8 py-4 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-semibold rounded-lg transition-colors min-h-[44px]">
                Enviar mensagem
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
