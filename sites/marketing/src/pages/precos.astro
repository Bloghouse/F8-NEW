---
/**
 * Página Preços - Pricing
 * Baseada em public/reference/html-bexon-demo-pricing.html/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumb from '../components/PageBreadcrumb.astro';
import { siteConfig } from '../config';

const REF = 'html-bexon-demo-pricing.html';
const IMG = (file: string) => `/reference/${REF}/images/${file}`;

const planos = [
  { nome: 'Básico', preco: 299, itens: ['Consultoria básica', 'Relatórios mensais', 'Suporte por e-mail'], destaque: false },
  { nome: 'Profissional', preco: 599, itens: ['Tudo do Básico', 'Estratégia personalizada', 'Suporte prioritário', 'Reuniões quinzenais'], destaque: true },
  { nome: 'Empresarial', preco: 999, itens: ['Tudo do Profissional', 'Equipe dedicada', 'Suporte 24/7', 'Implementação completa'], destaque: false },
];
---

<BaseLayout title={`Preços | ${siteConfig.siteName}`} description="Planos e preços para sua empresa. Escolha o ideal para você.">
  <article>
    <section class="py-16 px-6 bg-[#0c1e21] text-white">
      <div class="max-w-4xl mx-auto text-center">
        <PageBreadcrumb title="Preços" />
        <h1 class="text-4xl font-bold mt-4">Nosso Plano de Preços</h1>
        <p class="text-white/80 mt-4">Escolha o plano ideal para o seu negócio</p>
      </div>
    </section>

    <section class="py-20 px-6 bg-[#d8e5e5]">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8">
          {planos.map((p) => (
            <div class={`p-8 rounded-xl ${p.destaque ? 'bg-[#1e8a8a] text-white shadow-xl scale-105' : 'bg-white'}`}>
              {p.destaque && <span class="block text-center text-sm font-bold mb-4">Mais Popular</span>}
              <h3 class={`font-bold text-xl ${p.destaque ? '' : 'text-[#0c1e21]'}`}>{p.nome}</h3>
              <p class="mt-4">
                <span class={`text-4xl font-bold ${p.destaque ? '' : 'text-[#1e8a8a]'}`}>R$ {p.preco}</span>
                <span class="text-sm opacity-80">/mês</span>
              </p>
              <ul class="mt-6 space-y-3">
                {p.itens.map((i) => (
                  <li class="flex items-center gap-2">
                    <span class="text-[#1e8a8a]">✓</span>
                    <span class={p.destaque ? 'text-white/90' : 'text-[#364e52]'}>{i}</span>
                  </li>
                ))}
              </ul>
              <a
                href="/contato"
                class={`block text-center py-4 rounded-lg mt-8 font-semibold transition-colors ${
                  p.destaque ? 'bg-white text-[#1e8a8a] hover:bg-gray-100' : 'bg-[#1e8a8a] text-white hover:bg-[#1a7777]'
                }`}
              >
                Escolher Plano
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
