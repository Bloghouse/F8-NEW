---
/**
 * Footer.astro – Rodapé do site Digilinks
 * Links para páginas, redes sociais e informações de contato.
 * Mantém a estrutura visual da referência com cores e layout.
 */
import { siteConfig } from '../config';
---

<footer class="bg-[#131212] text-white/90">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Logo + Sobre -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img
            src="/reference/2025-digilink-html-page-about.html/images/img-001.png"
            alt="Digilinks"
            class="h-10 w-auto object-contain"
          />
        </a>
        <p class="text-sm text-white/70 mb-6 max-w-xs">
          Através de análise crítica e inquietude criativa, nossa missão é entender as complexidades humanas e transformá-las em experiências digitais memoráveis.
        </p>
        <div class="flex gap-4">
          <a href={siteConfig.social.twitter} class="text-white/70 hover:text-[#D9F45F] transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Twitter">𝕏</a>
          <a href={siteConfig.social.facebook} class="text-white/70 hover:text-[#D9F45F] transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Facebook">f</a>
          <a href={siteConfig.social.instagram} class="text-white/70 hover:text-[#D9F45F] transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Instagram">📷</a>
        </div>
      </div>

      <!-- Links rápidos -->
      <div>
        <h3 class="font-bold text-white mb-4">Links Rápidos</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Início</a></li>
          <li><a href="/sobre" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Sobre</a></li>
          <li><a href="/servicos" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Serviços</a></li>
          <li><a href="/projetos" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Projetos</a></li>
          <li><a href="/contato" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Contato</a></li>
        </ul>
      </div>

      <!-- Mais páginas -->
      <div>
        <h3 class="font-bold text-white mb-4">Mais</h3>
        <ul class="space-y-2">
          <li><a href="/depoimentos" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Depoimentos</a></li>
          <li><a href="/precos" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Preços</a></li>
          <li><a href="/faq" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">FAQ</a></li>
          <li><a href="/blog" class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">Blog</a></li>
        </ul>
      </div>

      <!-- Contato -->
      <div>
        <h3 class="font-bold text-white mb-4">Contato</h3>
        <ul class="space-y-3">
          <li>
            <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">
              {siteConfig.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-white/60">© {new Date().getFullYear()} Digilinks. Todos os direitos reservados.</p>
      <div class="flex gap-6 text-sm">
        <a href="#" class="text-white/60 hover:text-[#D9F45F] transition-colors">Política de Privacidade</a>
        <span class="text-white/40">|</span>
        <a href="#" class="text-white/60 hover:text-[#D9F45F] transition-colors">Termos de Uso</a>
      </div>
    </div>
  </div>
</footer>
