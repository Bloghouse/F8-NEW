---
/**
 * PageTitle.astro – Componente de título de página com hero/breadcrumb
 * Usado nas páginas internas para consistência visual.
 */
interface Props {
  title: string;
  breadcrumbs?: { label: string; href?: string }[];
  image?: string;
}

const { title, breadcrumbs = [], image = '/reference/2025-digilink-html-page-about.html/images/img-030.jpg' } = Astro.props;
---

<section
  class="relative min-h-[200px] flex items-center justify-center bg-cover bg-center"
  style={`background-image: url(${image})`}
>
  <div class="absolute inset-0 bg-black/50" />
  <div class="relative z-10 text-center px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{title}</h1>
    {breadcrumbs.length > 0 && (
      <nav class="flex justify-center gap-2 text-white/80 text-sm flex-wrap">
        {breadcrumbs.map((b, i) => (
          <>
            {b.href ? (
              <a href={b.href} class="hover:text-[#D9F45F]">{b.label}</a>
            ) : (
              <span>{b.label}</span>
            )}
            {i < breadcrumbs.length - 1 && <span>/</span>}
          </>
        ))}
      </nav>
    )}
  </div>
</section>
