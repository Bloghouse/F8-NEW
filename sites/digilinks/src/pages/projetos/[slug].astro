---
/**
 * projetos/[slug].astro – Detalhes de projeto (Prompt 4)
 * Base: 2025-digilink-html-page-project-details.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-project-details.html';

export function getStaticPaths() {
  return [
    { params: { slug: 'cartao-visual' } },
    { params: { slug: 'scrappy' } },
    { params: { slug: 'showcase' } },
    { params: { slug: 'onboarding' } },
    { params: { slug: 'cold-outreach' } },
  ];
}

const { slug } = Astro.params;
const titulos: Record<string, string> = {
  'cartao-visual': 'Design de cartão de visitas',
  scrappy: 'Scrappy & Resourceful',
  showcase: 'Mostre seu processo',
  onboarding: 'Onboarding profissional',
  'cold-outreach': 'Cold outreach segmentado',
};
const title = titulos[slug ?? ''] ?? slug;
---

<BaseLayout title={title} description={`Projeto ${title} - Digilinks Agência Digital`}>
  <PageTitle title={title} breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Projetos', href: '/projetos' }, { label: title }]} image={`/reference/${ref}/images/img-004.jpg`} />

  <section class="py-16 px-4 bg-[#0f0f0f]">
    <div class="max-w-4xl mx-auto prose prose-invert prose-lg">
      <p class="text-white/80">
        Este projeto demonstra nossa abordagem em design e branding. Combinamos estratégia visual com experiência do usuário para criar soluções que impactam.
      </p>
      <img src={`/reference/${ref}/images/img-005.jpg`} alt={title} class="rounded-lg w-full max-h-[400px] object-cover my-8" />
      <p class="text-white/80">
        Trabalhamos em estreita colaboração com o cliente para entender suas necessidades e entregar resultados que superam expectativas.
      </p>
      <a href="/projetos" class="inline-flex items-center gap-2 mt-8 text-[#D9F45F] hover:underline">
        ← Voltar aos projetos
      </a>
    </div>
  </section>
</BaseLayout>
