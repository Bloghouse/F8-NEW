---
/**
 * contato.astro – Página de contato (Prompt 15)
 * Base: 2025-digilink-html-page-contact.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import { siteConfig } from '../config';
const ref = '2025-digilink-html-page-contact.html';
---

<BaseLayout title="Contato" description="Entre em contato com a Digilinks. Estamos prontos para ajudar seu negócio a crescer no digital.">
  <PageTitle title="Contato" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Contato' }]} image={`/reference/${ref}/images/img-007.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <span class="text-[#D9F45F] text-sm font-medium">Envie uma mensagem</span>
          <h2 class="text-2xl md:text-3xl font-bold text-white mt-2 mb-6">Fale conosco</h2>
          <form class="space-y-4" action="#" method="post">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="text" name="nome" placeholder="Seu nome" required class="w-full px-4 py-3 rounded-md bg-[#131212] border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] outline-none min-h-[44px]" />
              <input type="email" name="email" placeholder="Seu e-mail" required class="w-full px-4 py-3 rounded-md bg-[#131212] border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] outline-none min-h-[44px]" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="text" name="assunto" placeholder="Assunto" required class="w-full px-4 py-3 rounded-md bg-[#131212] border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] outline-none min-h-[44px]" />
              <input type="tel" name="telefone" placeholder="Telefone" class="w-full px-4 py-3 rounded-md bg-[#131212] border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] outline-none min-h-[44px]" />
            </div>
            <textarea name="mensagem" placeholder="Sua mensagem" rows="6" required class="w-full px-4 py-3 rounded-md bg-[#131212] border border-white/10 text-white placeholder-white/50 focus:border-[#D9F45F] outline-none resize-none"></textarea>
            <div class="flex gap-4">
              <button type="submit" class="px-6 py-3 rounded-md bg-[#D9F45F] text-[#0f0f0f] font-medium hover:bg-[#c5e04f] transition-colors min-h-[44px]">
                Enviar mensagem
              </button>
              <button type="reset" class="px-6 py-3 rounded-md bg-white/10 text-white font-medium hover:bg-white/20 transition-colors min-h-[44px]">
                Limpar
              </button>
            </div>
          </form>
        </div>
        <div>
          <span class="text-[#D9F45F] text-sm font-medium">Precisa de ajuda?</span>
          <h2 class="text-2xl md:text-3xl font-bold text-white mt-2 mb-6">Entre em contato</h2>
          <p class="text-white/70 mb-8">Estamos à disposição para tirar dúvidas e apresentar nossas soluções. Respondemos em até 24 horas.</p>
          <ul class="space-y-6">
            <li class="flex gap-4">
              <span class="text-[#D9F45F] text-xl">📞</span>
              <div>
                <h4 class="font-bold text-white mb-1">Telefone</h4>
                <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-white/70 hover:text-[#D9F45F]">{siteConfig.phone}</a>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-[#D9F45F] text-xl">✉️</span>
              <div>
                <h4 class="font-bold text-white mb-1">E-mail</h4>
                <a href={`mailto:${siteConfig.email}`} class="text-white/70 hover:text-[#D9F45F]">{siteConfig.email}</a>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-[#D9F45F] text-xl">📍</span>
              <div>
                <h4 class="font-bold text-white mb-1">Endereço</h4>
                <span class="text-white/70">São Paulo, SP - Brasil</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="h-64 bg-[#131212]">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d467692.0482790456!2d-46.87549005!3d-23.6814346!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce448183a461d1%3A0x9ba94b08ff335bae!2zU8OjbyBQYXVsbywgU1A!5e0!3m2!1spt-BR!2sbr!4v1700000000000!5m2!1spt-BR!2sbr"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Mapa São Paulo"
      class="opacity-60"
    />
  </section>
</BaseLayout>
