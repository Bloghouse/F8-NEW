---
/**
 * servicos/[slug].astro – Detalhes de serviço (Prompt 12)
 * Base: 2025-digilink-html-page-service-details.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-service-details.html';

export function getStaticPaths() {
  return [
    { params: { slug: 'marketing-digital' } },
    { params: { slug: 'branding' } },
    { params: { slug: 'web-design' } },
    { params: { slug: 'estrategia-marca' } },
    { params: { slug: 'conteudo' } },
    { params: { slug: 'email-marketing' } },
  ];
}

const { slug } = Astro.params;
const servicos: Record<string, { titulo: string; desc: string }> = {
  'marketing-digital': { titulo: 'Marketing Digital', desc: 'Desenvolvemos estratégias completas de marketing digital: SEO, redes sociais, Google Ads, conteúdo e análise de dados para alavancar seus resultados.' },
  branding: { titulo: 'Branding', desc: 'Criamos identidades visuais memoráveis: logo, manual de marca, aplicações e posicionamento que diferenciam sua empresa no mercado.' },
  'web-design': { titulo: 'Web Design & Desenvolvimento', desc: 'Sites modernos, responsivos e otimizados para conversão. Do design à implementação e hospedagem.' },
  'estrategia-marca': { titulo: 'Estratégia de Marca', desc: 'Consultoria especializada em posicionamento, arquitetura de marca e definição de tom de voz.' },
  conteudo: { titulo: 'Criação de Conteúdo', desc: 'Conteúdo que engaja: textos, vídeos, imagens e estratégias editoriais para suas redes e canais.' },
  'email-marketing': { titulo: 'E-mail Marketing', desc: 'Automação de e-mails, campanhas segmentadas e fluxos de nutrição para conversão.' },
};
const s = servicos[slug ?? ''] ?? { titulo: slug, desc: 'Serviço da Digilinks.' };
---

<BaseLayout title={s.titulo} description={s.desc}>
  <PageTitle title={s.titulo} breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Serviços', href: '/servicos' }, { label: s.titulo }]} image={`/reference/${ref}/images/img-010.jpg`} />

  <section class="py-16 px-4 bg-[#0f0f0f]">
    <div class="max-w-4xl mx-auto">
      <img src={`/reference/${ref}/images/img-003.jpg`} alt={s.titulo} class="w-full rounded-lg object-cover max-h-[400px] mb-8" />
      <p class="text-white/80 text-lg">{s.desc}</p>
      <a href="/contato" class="inline-flex items-center gap-2 mt-8 px-6 py-3 bg-[#D9F45F] text-[#0f0f0f] font-medium rounded-md hover:bg-[#c5e04f] transition-colors min-h-[44px]">
        Solicitar orçamento
      </a>
      <a href="/servicos" class="inline-flex items-center gap-2 mt-4 ml-4 text-[#D9F45F] hover:underline">
        ← Voltar aos serviços
      </a>
    </div>
  </section>
</BaseLayout>
