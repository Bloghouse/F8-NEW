---
/**
 * servicos/index.astro – Listagem de serviços (Prompt 11)
 * Base: 2025-digilink-html-page-services.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-services.html';

const servicos = [
  { slug: 'marketing-digital', titulo: 'Marketing Digital', desc: 'Estratégias completas para sua presença digital.', img: 'img-009' },
  { slug: 'branding', titulo: 'Branding', desc: 'Identidade visual e posicionamento de marca.', img: 'img-009' },
  { slug: 'web-design', titulo: 'Web Design & Desenvolvimento', desc: 'Sites modernos e responsivos.', img: 'img-009' },
  { slug: 'estrategia-marca', titulo: 'Estratégia de Marca', desc: 'Posicionamento e consultoria de marca.', img: 'img-009' },
  { slug: 'conteudo', titulo: 'Criação de Conteúdo', desc: 'Conteúdo que engaja e converte.', img: 'img-009' },
  { slug: 'email-marketing', titulo: 'E-mail Marketing', desc: 'Automação e campanhas por e-mail.', img: 'img-009' },
];
---

<BaseLayout title="Nossos Serviços" description="Conheça os serviços da Digilinks: marketing digital, branding, web design e mais.">
  <PageTitle title="Nossos Serviços" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Serviços' }]} image={`/reference/${ref}/images/img-008.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {servicos.map((s) => (
          <a href={`/servicos/${s.slug}`} class="group block rounded-xl overflow-hidden bg-[#131212] border border-white/10 hover:border-[#D9F45F]/50 transition-all">
            <div class="aspect-video overflow-hidden">
              <img
                src={`/reference/${ref}/images/${s.img}.jpg`}
                alt={s.titulo}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="p-6">
              <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors mb-2">{s.titulo}</h3>
              <p class="text-white/70 text-sm">{s.desc}</p>
              <span class="inline-block mt-4 text-[#D9F45F] text-sm font-medium">Saiba mais →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
