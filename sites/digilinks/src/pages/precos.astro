---
/**
 * precos.astro – Página de preços (Prompt 8)
 * Base: 2025-digilink-html-page-pricing.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
const ref = '2025-digilink-html-page-pricing.html';

const planos = [
  { nome: 'Plano Starter', preco: 399, periodo: '/ano', itens: ['Consultoria de negócios', 'Até 10h de suporte/mês', 'Monitoramento de rede', 'Configuração de e-mail e softwares', 'Relatórios mensais'], destaque: false },
  { nome: 'Plano Profissional', preco: 660, periodo: '/ano', itens: ['Consultoria de negócios', 'Até 10h de suporte/mês', 'Monitoramento de rede', 'Configuração de e-mail e softwares', 'Relatórios mensais'], destaque: true },
  { nome: 'Plano Enterprise', preco: 990, periodo: '/ano', itens: ['Consultoria de negócios', 'Até 10h de suporte/mês', 'Monitoramento de rede', 'Configuração de e-mail e softwares', 'Relatórios mensais'], destaque: false },
];
---

<BaseLayout title="Preços" description="Planos e preços da Digilinks. Encontre o plano ideal para o seu negócio.">
  <PageTitle title="Preços" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Preços' }]} image={`/reference/${ref}/images/img-007.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {planos.map((p) => (
          <div class={`p-8 rounded-xl border ${p.destaque ? 'border-[#D9F45F] bg-[#D9F45F]/5' : 'border-white/10 bg-[#131212]'}`}>
            {p.destaque && <span class="block text-center text-[#D9F45F] text-sm font-medium mb-4">Recomendado</span>}
            <div class="text-3xl font-bold text-white mb-2">
              <sup class="text-lg">R$</sup>{p.preco}
              <span class="text-base font-normal text-white/70">{p.periodo}</span>
            </div>
            <h3 class="font-bold text-white mb-6">{p.nome}</h3>
            <ul class="space-y-3 mb-8">
              {p.itens.map((i) => (
                <li class="flex items-center gap-2 text-white/80 text-sm">
                  <span class="text-[#D9F45F]">✓</span> {i}
                </li>
              ))}
            </ul>
            <a href="/contato" class="block w-full py-3 text-center rounded-md font-medium min-h-[44px] flex items-center justify-center transition-colors {p.destaque ? 'bg-[#D9F45F] text-[#0f0f0f] hover:bg-[#c5e04f]' : 'bg-white/10 text-white hover:bg-white/20'}">
              Começar
            </a>
          </div>
        ))}
      </div>
      <div class="text-center mt-16">
        <p class="text-white/80 mb-4">Pronto para o próximo passo? Vamos criar algo incrível juntos.</p>
        <a href="/contato" class="text-[#D9F45F] hover:underline font-medium">Entre em contato</a>
      </div>
    </div>
  </section>
</BaseLayout>
