---
/**
 * faq.astro – Página de perguntas frequentes (Prompt 9)
 * Base: 2025-digilink-html-page-faq.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
const ref = '2025-digilink-html-page-faq.html';

const faqs = [
  { q: 'Quais serviços a Digilinks oferece?', a: 'Oferecemos marketing digital, branding, design web, gestão de redes sociais, criação de conteúdo e consultoria estratégica.' },
  { q: 'Como funciona o processo de contratação?', a: 'Entre em contato pelo formulário ou telefone. Agendamos uma reunião para entender suas necessidades e apresentar uma proposta personalizada.' },
  { q: 'Qual o prazo médio dos projetos?', a: 'Varía conforme o escopo. Projetos de branding levam em média 4-6 semanas; websites, 6-8 semanas; campanhas de marketing, a partir de 1 mês.' },
  { q: 'Trabalham com empresas de qualquer porte?', a: 'Sim, atendemos startups, PMEs e grandes empresas. Adaptamos nossas soluções ao seu orçamento e objetivos.' },
];
---

<BaseLayout title="FAQ" description="Perguntas frequentes sobre os serviços e processos da Digilinks.">
  <PageTitle title="Perguntas Frequentes" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'FAQ' }]} image={`/reference/${ref}/images/img-006.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-3xl mx-auto">
      <div class="space-y-4">
        {faqs.map((f) => (
          <details class="group p-6 rounded-xl bg-[#131212] border border-white/10">
            <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
              {f.q}
              <span class="text-[#D9F45F] group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="text-white/80 mt-4 text-sm">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
