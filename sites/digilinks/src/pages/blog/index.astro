---
/**
 * blog/index.astro – Grid de posts do blog (Prompt 13)
 * Base: 2025-digilink-html-news-grid.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-news-grid.html';

const posts = [
  { slug: 'tendencias-marketing-2025', titulo: 'Tendências de Marketing Digital 2025', data: '2025-01-15', excerpt: 'O que esperar do marketing digital neste ano.', img: 'img-003' },
  { slug: 'como-melhorar-seo', titulo: 'Como Melhorar o SEO do seu Site', data: '2025-01-10', excerpt: 'Dicas práticas para ranquear melhor no Google.', img: 'img-004' },
  { slug: 'importancia-branding', titulo: 'A Importância do Branding', data: '2025-01-05', excerpt: 'Por que sua marca precisa de uma identidade forte.', img: 'img-005' },
];
---

<BaseLayout title="Blog" description="Artigos e insights sobre marketing digital, design e tecnologia.">
  <PageTitle title="Blog" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Blog' }]} image={`/reference/${ref}/images/img-009.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((p) => (
          <a href={`/blog/${p.slug}`} class="group block rounded-xl overflow-hidden bg-[#131212] border border-white/10 hover:border-[#D9F45F]/50 transition-all">
            <div class="aspect-video overflow-hidden">
              <img src={`/reference/${ref}/images/${p.img}.jpg`} alt={p.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            </div>
            <div class="p-6">
              <time class="text-white/60 text-sm" datetime={p.data}>{new Date(p.data).toLocaleDateString('pt-BR')}</time>
              <h3 class="font-bold text-white mt-2 group-hover:text-[#D9F45F] transition-colors">{p.titulo}</h3>
              <p class="text-white/70 text-sm mt-2">{p.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
