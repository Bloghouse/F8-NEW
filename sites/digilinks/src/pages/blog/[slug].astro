---
/**
 * blog/[slug].astro – Detalhes do post (Prompt 14)
 * Base: 2025-digilink-html-news-details.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-news-details.html';

export function getStaticPaths() {
  return [
    { params: { slug: 'tendencias-marketing-2025' } },
    { params: { slug: 'como-melhorar-seo' } },
    { params: { slug: 'importancia-branding' } },
  ];
}

const { slug } = Astro.params;
const posts: Record<string, { titulo: string; data: string; conteudo: string }> = {
  'tendencias-marketing-2025': {
    titulo: 'Tendências de Marketing Digital 2025',
    data: '2025-01-15',
    conteudo: 'O marketing digital continua evoluindo rapidamente. Em 2025, destacamos a personalização com IA, o conteúdo em vídeo curto, e estratégias de first-party data como pilares principais. As marcas que investirem em automação inteligente e experiência do cliente terão vantagem competitiva.',
  },
  'como-melhorar-seo': {
    titulo: 'Como Melhorar o SEO do seu Site',
    data: '2025-01-10',
    conteudo: 'SEO é fundamental para visibilidade. Invista em conteúdo de qualidade, títulos otimizados, meta descriptions e velocidade de carregamento. O Core Web Vitals do Google continua crucial. Também priorize links internos e autoridade de domínio.',
  },
  'importancia-branding': {
    titulo: 'A Importância do Branding',
    data: '2025-01-05',
    conteudo: 'Uma marca forte vai além do logo. É a percepção que os clientes têm da sua empresa. Branding bem feito aumenta reconhecimento, confiança e permite cobrar mais. Invista em consistência visual e tom de voz em todos os canais.',
  },
};
const post = posts[slug ?? ''] ?? { titulo: slug, data: '', conteudo: '' };
---

<BaseLayout title={post.titulo} description={post.conteudo.slice(0, 160)}>
  <PageTitle title={post.titulo} breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Blog', href: '/blog' }, { label: post.titulo }]} image={`/reference/${ref}/images/img-004.jpg`} />

  <article class="py-16 px-4 bg-[#0f0f0f]">
    <div class="max-w-3xl mx-auto">
      <time class="text-white/60 text-sm" datetime={post.data}>{new Date(post.data).toLocaleDateString('pt-BR')}</time>
      <div class="prose prose-invert prose-lg mt-4">
        <p class="text-white/80">{post.conteudo}</p>
      </div>
      <a href="/blog" class="inline-flex items-center gap-2 mt-8 text-[#D9F45F] hover:underline">
        ← Voltar ao blog
      </a>
    </div>
  </article>
</BaseLayout>
