---
/**
 * depoimentos.astro – Página de depoimentos (Prompt 7)
 * Base: 2025-digilink-html-page-testimonial.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
const ref = '2025-digilink-html-page-testimonial.html';

const depoimentos = [
  { nome: 'Carlos Mendes', cargo: 'CEO, TechStart', texto: 'A Digilinks transformou nossa presença digital. Resultados incríveis em pouco tempo!' },
  { nome: 'Fernanda Oliveira', cargo: 'Diretora de Marketing', texto: 'Profissionalismo e criatividade em cada projeto. Recomendo fortemente.' },
  { nome: 'Ricardo Lima', cargo: 'Fundador, InovaCorp', texto: 'Parceria que fez toda a diferença. A equipe entendeu nossa visão perfeitamente.' },
];
---

<BaseLayout title="Depoimentos" description="O que nossos clientes dizem sobre a Digilinks. Depoimentos reais de parceiros satisfeitos.">
  <PageTitle title="Depoimentos" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Depoimentos' }]} image={`/reference/${ref}/images/img-011.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {depoimentos.map((d) => (
          <div class="p-8 rounded-xl bg-[#131212] border border-white/10">
            <img src={`/reference/${ref}/images/img-007.png`} alt="" class="w-12 h-12 mb-4 opacity-80" />
            <p class="text-white/90 mb-6 italic">&ldquo;{d.texto}&rdquo;</p>
            <div>
              <h4 class="font-bold text-white">{d.nome}</h4>
              <p class="text-white/60 text-sm">{d.cargo}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
