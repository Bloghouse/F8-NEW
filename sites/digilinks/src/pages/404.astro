---
/**
 * 404.astro – Página de erro 404 (Prompt 10)
 * Base: 2025-digilink-html-page-404.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const ref = '2025-digilink-html-page-404.html';
---

<BaseLayout title="Página não encontrada" description="A página que você procura não existe." noIndex>
  <section class="min-h-[70vh] flex flex-col items-center justify-center px-4 bg-[#0f0f0f]">
    <img src={`/reference/${ref}/images/img-001.png`} alt="404" class="max-w-xs w-full mb-8 opacity-50" />
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">404</h1>
    <p class="text-white/80 text-lg text-center mb-8">Página não encontrada. O conteúdo que você procura pode ter sido movido ou removido.</p>
    <a href="/" class="px-6 py-3 rounded-md bg-[#D9F45F] text-[#0f0f0f] font-medium hover:bg-[#c5e04f] transition-colors min-h-[44px] flex items-center">
      Voltar ao início
    </a>
  </section>
</BaseLayout>
