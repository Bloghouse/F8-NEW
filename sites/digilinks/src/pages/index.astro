---
/**
 * index.astro – Página inicial do site Digilinks (domínio raiz)
 * Base estrutural em 2025-digilink-html-page-about.html.
 * Hero, sobre, features, clientes e serviços. Conteúdo em português.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const ref = '2025-digilink-html-page-about.html';
---

<BaseLayout title="Digilinks - Agência Digital" description="Agência digital especializada em marketing, design e desenvolvimento web. Transforme seu negócio em histórias de sucesso digital.">
  <!-- Hero -->
  <section
    class="relative min-h-[280px] flex items-center justify-center bg-cover bg-center"
    style={`background-image: url(/reference/${ref}/images/img-030.jpg)`}
  >
    <div class="absolute inset-0 bg-black/50" />
    <div class="relative z-10 text-center px-4 py-16">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Bem-vindo à Digilinks</h1>
      <nav class="flex justify-center gap-2 text-white/80 text-sm">
        <span class="text-[#D9F45F]">Início</span>
      </nav>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-4">
          <p class="text-white/80 mb-6">
            Acreditamos em inovação, colaboração e design orientado a dados para ajudar clientes a se destacarem no mundo digital.
          </p>
          <div class="flex flex-col gap-4">
            <div>
              <h3 class="text-2xl font-bold text-[#D9F45F]">10M+</h3>
              <p class="text-white/70 text-sm">Captados para clientes</p>
            </div>
            <div class="flex -space-x-2">
              <img src={`/reference/${ref}/images/img-004.jpg`} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
              <img src={`/reference/${ref}/images/img-005.jpg`} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
              <img src={`/reference/${ref}/images/img-006.jpg`} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
              <img src={`/reference/${ref}/images/img-007.jpg`} alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#131212]" />
              <span class="w-12 h-12 rounded-full bg-[#D9F45F]/20 flex items-center justify-center text-[#D9F45F] font-bold text-sm">+</span>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 relative">
          <img src={`/reference/${ref}/images/img-008.jpg`} alt="Equipe Digilinks" class="w-full rounded-lg object-cover max-h-[400px]" />
          <div class="absolute bottom-4 left-4 right-4 md:right-8 bg-[#131212]/95 p-4 rounded-lg flex gap-3">
            <img src={`/reference/${ref}/images/img-009.png`} alt="" class="w-10 h-10 shrink-0" />
            <p class="text-white/90 text-sm italic">
              O progresso verdadeiro é feito em parceria—com quem confia em nós, nos desafia e cresce conosco.
            </p>
          </div>
        </div>
        <div class="lg:col-span-3 space-y-6">
          <div class="flex gap-4">
            <img src={`/reference/${ref}/images/img-010.png`} alt="" class="w-12 h-12 shrink-0" />
            <div>
              <h4 class="font-bold text-white mb-1">Conteúdo Criativo & Design</h4>
              <p class="text-white/70 text-sm">Desenvolvemos conteúdo e identidades visuais que conectam marcas e audiências.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <img src={`/reference/${ref}/images/img-011.png`} alt="" class="w-12 h-12 shrink-0" />
            <div>
              <h4 class="font-bold text-white mb-1">Estratégia & Consultoria</h4>
              <p class="text-white/70 text-sm">Consultoria especializada para alavancar seus resultados no digital.</p>
            </div>
          </div>
          <a href="/sobre" class="inline-flex items-center gap-2 px-6 py-3 bg-[#D9F45F] text-[#0f0f0f] font-medium rounded-md hover:bg-[#c5e04f] transition-colors min-h-[44px]">
            Saiba mais sobre nós
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 md:py-24 bg-[#131212] relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-40 bg-[#D9F45F]" style="clip-path: polygon(0 0, 100% 0, 100% 60%, 0 100%);" />
    <div class="relative z-10 max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="inline-block text-[#D9F45F] text-sm font-medium mb-2">Nossos diferenciais</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Transformando negócios em <span class="text-[#D9F45F]">histórias de sucesso digital</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
        {[
          { icon: 'img-012', title: 'Estratégia de Marca', href: '/servicos/estrategia-marca' },
          { icon: 'img-013', title: 'Web Design & Desenvolvimento', href: '/servicos/web-design' },
          { icon: 'img-014', title: 'Marketing em Redes Sociais', href: '/servicos/marketing-digital' },
          { icon: 'img-015', title: 'Criação de Conteúdo', href: '/servicos/conteudo' },
          { icon: 'img-016', title: 'Automação de E-mail', href: '/servicos/email-marketing' },
        ].map((item) => (
          <a href={item.href} class="block p-6 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 transition-colors group">
            <img src={`/reference/${ref}/images/${item.icon}.png`} alt="" class="w-12 h-12 mb-4" />
            <h3 class="font-bold text-white mb-2 group-hover:text-[#D9F45F] transition-colors">{item.title}</h3>
            <p class="text-white/70 text-sm mb-4">Soluções sob medida para o seu negócio.</p>
            <span class="text-[#D9F45F] text-sm font-medium">Saiba mais →</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/servicos" class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-[#D9F45F] text-[#D9F45F] font-medium hover:bg-[#D9F45F] hover:text-[#0f0f0f] transition-colors min-h-[44px]">
          Mais serviços
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Clients -->
  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-white text-center mb-12">
        Trabalhando com <span class="text-[#D9F45F]">30+ marcas</span> no Brasil
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 items-center justify-items-center opacity-70">
        <img src={`/reference/${ref}/images/img-022.png`} alt="Cliente" class="max-h-12 w-auto object-contain" />
        <img src={`/reference/${ref}/images/img-023.png`} alt="Cliente" class="max-h-12 w-auto object-contain" />
        <img src={`/reference/${ref}/images/img-024.png`} alt="Cliente" class="max-h-12 w-auto object-contain" />
        <img src={`/reference/${ref}/images/img-022.png`} alt="Cliente" class="max-h-12 w-auto object-contain hidden md:block" />
      </div>
    </div>
  </section>

  <!-- Services CTA -->
  <section class="py-16 md:py-24 px-4 bg-[#131212]">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row lg:items-end gap-8 mb-12">
        <div class="lg:flex-1">
          <span class="text-[#D9F45F] text-sm font-medium">Nossos Serviços</span>
          <h2 class="text-3xl md:text-4xl font-bold text-white mt-2">Serviços que fazem a diferença</h2>
        </div>
        <p class="lg:max-w-md text-white/70">
          Na Digilinks, trazemos sua visão à vida com designs inovadores que unem funcionalidade e estética.
        </p>
      </div>
      <div class="space-y-4">
        {[
          { title: 'Marketing Digital', desc: 'Estratégias completas para sua presença digital.' },
          { title: 'Branding', desc: 'Identidade visual e posicionamento de marca.' },
          { title: 'Estratégia de Produto', desc: 'Planejamento e otimização de produtos digitais.' },
          { title: 'Consultoria', desc: 'Apoio especializado para decisões estratégicas.' },
        ].map((s) => (
          <a href="/servicos" class="block p-6 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 transition-colors group">
            <h4 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors">{s.title}</h4>
            <p class="text-white/70 text-sm mt-1">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
