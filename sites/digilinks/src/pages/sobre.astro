---
/**
 * sobre.astro – Página Sobre (Prompt 2)
 * Base: 2025-digilink-html-page-about.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
const ref = '2025-digilink-html-page-about.html';
---

<BaseLayout title="Sobre Nós" description="Conheça a Digilinks: misturamos criatividade e tecnologia para construir experiências digitais memoráveis.">
  <PageTitle title="Sobre Nós" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Sobre Nós' }]} image={`/reference/${ref}/images/img-030.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-4">
          <span class="text-[#D9F45F] text-sm font-medium">Sobre Nós</span>
          <h2 class="text-2xl md:text-3xl font-bold text-white mt-2 mb-6">
            Misturamos criatividade e tecnologia para construir <span class="text-[#D9F45F]">experiências digitais</span>
          </h2>
          <p class="text-white/80 mb-6">Acreditamos em inovação, colaboração e design orientado a dados para ajudar clientes a se destacarem no mundo digital.</p>
          <div class="flex gap-4">
            <div>
              <h3 class="text-2xl font-bold text-[#D9F45F]">2010</h3>
              <p class="text-white/70 text-sm">Desde</p>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-[#D9F45F]">89+</h3>
              <p class="text-white/70 text-sm">Prêmios digitais</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 relative">
          <img src={`/reference/${ref}/images/img-008.jpg`} alt="Equipe Digilinks" class="w-full rounded-lg object-cover max-h-[400px]" />
          <div class="absolute bottom-4 left-4 right-4 md:right-8 bg-[#131212]/95 p-4 rounded-lg flex gap-3">
            <img src={`/reference/${ref}/images/img-009.png`} alt="" class="w-10 h-10 shrink-0" />
            <p class="text-white/90 text-sm italic">O progresso verdadeiro é feito em parceria—com quem confia em nós, nos desafia e cresce conosco.</p>
          </div>
        </div>
        <div class="lg:col-span-3 space-y-6">
          <div class="flex gap-4">
            <img src={`/reference/${ref}/images/img-010.png`} alt="" class="w-12 h-12 shrink-0" />
            <div>
              <h4 class="font-bold text-white mb-1">Conteúdo Criativo & Design</h4>
              <p class="text-white/70 text-sm">Desenvolvemos conteúdo e identidades visuais que conectam marcas e audiências.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <img src={`/reference/${ref}/images/img-011.png`} alt="" class="w-12 h-12 shrink-0" />
            <div>
              <h4 class="font-bold text-white mb-1">Estratégia & Consultoria</h4>
              <p class="text-white/70 text-sm">Consultoria especializada para alavancar seus resultados no digital.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
