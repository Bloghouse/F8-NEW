---
/**
 * equipe/[slug].astro – Perfil do membro da equipe (Prompt 6)
 * Base: 2025-digilink-html-page-team-details.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-team-details.html';

export function getStaticPaths() {
  return [
    { params: { slug: 'maria-silva' } },
    { params: { slug: 'joao-santos' } },
    { params: { slug: 'ana-costa' } },
  ];
}

const { slug } = Astro.params;
const perfis: Record<string, { nome: string; cargo: string; bio: string }> = {
  'maria-silva': { nome: 'Maria Silva', cargo: 'CEO & Fundadora', bio: 'Com mais de 15 anos de experiência em marketing digital, Maria lidera a Digilinks com visão estratégica e paixão por inovar.' },
  'joao-santos': { nome: 'João Santos', cargo: 'Diretor Criativo', bio: 'João é responsável pela identidade visual e experiência do usuário em todos os projetos da agência.' },
  'ana-costa': { nome: 'Ana Costa', cargo: 'Head de Marketing', bio: 'Ana comanda as estratégias de marketing digital e garante que cada campanha alcance seus objetivos.' },
};
const perfil = perfis[slug ?? ''] ?? { nome: slug, cargo: '', bio: '' };
---

<BaseLayout title={perfil.nome} description={perfil.bio}>
  <PageTitle title={perfil.nome} breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Equipe', href: '/equipe' }, { label: perfil.nome }]} image={`/reference/${ref}/images/img-003.jpg`} />

  <section class="py-16 px-4 bg-[#0f0f0f]">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <img src={`/reference/${ref}/images/img-003.jpg`} alt={perfil.nome} class="w-full rounded-xl object-cover aspect-square" />
        </div>
        <div class="md:col-span-2">
          <p class="text-[#D9F45F] text-sm font-medium">{perfil.cargo}</p>
          <h2 class="text-2xl font-bold text-white mt-2">{perfil.nome}</h2>
          <p class="text-white/80 mt-6">{perfil.bio}</p>
          <a href="/equipe" class="inline-flex items-center gap-2 mt-8 text-[#D9F45F] hover:underline">
            ← Voltar à equipe
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
