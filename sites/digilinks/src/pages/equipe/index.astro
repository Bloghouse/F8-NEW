---
/**
 * equipe/index.astro – Listagem da equipe (Prompt 5)
 * Base: 2025-digilink-html-page-team.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-team.html';

const membros = [
  { slug: 'maria-silva', nome: 'Maria Silva', cargo: 'CEO & Fundadora' },
  { slug: 'joao-santos', nome: 'João Santos', cargo: 'Diretor Criativo' },
  { slug: 'ana-costa', nome: 'Ana Costa', cargo: 'Head de Marketing' },
];

const images = ['img-003', 'img-004', 'img-005'] as const;
---

<BaseLayout title="Nossa Equipe" description="Conheça a equipe da Digilinks: profissionais apaixonados por criar experiências digitais memoráveis.">
  <PageTitle title="Nossa Equipe" breadcrumbs={[{ label: 'Início', href: '/' }, { label: 'Equipe' }]} image={`/reference/${ref}/images/img-010.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {membros.map((m, i) => (
          <a href={`/equipe/${m.slug}`} class="group block text-center">
            <div class="aspect-square rounded-xl overflow-hidden mb-4">
              <img
                src={`/reference/${ref}/images/${images[i]}.png`}
                alt={m.nome}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors">{m.nome}</h3>
            <p class="text-white/70 text-sm">{m.cargo}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
