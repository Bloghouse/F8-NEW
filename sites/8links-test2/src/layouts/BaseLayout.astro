---
/**
 * BaseLayout.astro – Layout base do site 8links-test2
 * Define estrutura HTML, meta SEO, Header e Footer.
 */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const { title, description, image = '/reference/2025-digilink-html-page-about.html/images/img-030.jpg', noIndex = false } = Astro.props;
const siteUrl = 'https://8links-test2.vercel.app';
const fullTitle = title === '8links' ? title : `${title} | 8links`;
const fullDescription = description || 'Agência digital especializada em marketing, design e desenvolvimento web';
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image.startsWith('/') ? '' : '/'}${image}`;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={fullDescription} />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname || '/'}`} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={fullImage} />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={fullDescription} />
    <meta name="twitter:image" content={fullImage} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "8links",
      "url": siteUrl,
      "description": fullDescription,
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+55-11-99999-0000",
        "contactType": "customer service"
      }
    })} />
  </head>
  <body class="bg-[#0f0f0f] text-white antialiased">
    <Header />
    <main class="pt-16 md:pt-20">
      <slot />
    </main>
    <Footer />
  </body>
</html>
