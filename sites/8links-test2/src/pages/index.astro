---
/**
 * index.astro – Página inicial (PROMPT 1)
 * Base: item-digilink-digital-marketing-agency. Hero, sobre, features. Placeholders para imagens.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="8links - Agência Digital" description="Agência digital especializada em marketing, design e desenvolvimento web. Transforme seu negócio em histórias de sucesso digital.">
  <!-- Hero -->
  <section class="relative min-h-[320px] flex items-center justify-center bg-cover bg-center" style="background-image: url(https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1920&h=800&fit=crop)">
    <div class="absolute inset-0 bg-black/50" />
    <div class="relative z-10 text-center px-4 py-20">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Bem-vindo à 8links</h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto mb-6">Transformamos ideias em experiências digitais que conectam marcas e pessoas.</p>
      <a href="/sobre" class="inline-flex items-center gap-2 px-6 py-4 bg-[#D9F45F] text-[#0f0f0f] font-semibold rounded-lg hover:bg-[#c5e04f] transition-colors min-h-[44px]">
        Conheça o que fazemos
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-4">
          <p class="text-white/80 mb-6">
            Acreditamos em inovação, colaboração e design orientado a dados para ajudar clientes a se destacarem no mundo digital.
          </p>
          <div class="flex flex-col gap-4">
            <div>
              <h3 class="text-2xl font-bold text-[#D9F45F]">10M+</h3>
              <p class="text-white/70 text-sm">Captados para clientes</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 relative">
          <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&h=600&fit=crop" alt="Equipe 8links" class="w-full rounded-lg object-cover max-h-[400px]" />
          <div class="absolute bottom-4 left-4 right-4 md:right-8 bg-[#131212]/95 p-4 rounded-lg">
            <p class="text-white/90 text-sm italic">
              O progresso verdadeiro é feito em parceria—com quem confia em nós, nos desafia e cresce conosco.
            </p>
          </div>
        </div>
        <div class="lg:col-span-3 space-y-6">
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-lg bg-[#D9F45F]/20 flex items-center justify-center text-[#D9F45F] shrink-0">⚡</div>
            <div>
              <h4 class="font-bold text-white mb-1">Conteúdo Criativo & Design</h4>
              <p class="text-white/70 text-sm">Desenvolvemos conteúdo e identidades visuais que conectam marcas e audiências.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-lg bg-[#D9F45F]/20 flex items-center justify-center text-[#D9F45F] shrink-0">📊</div>
            <div>
              <h4 class="font-bold text-white mb-1">Estratégia & Consultoria</h4>
              <p class="text-white/70 text-sm">Consultoria especializada para alavancar seus resultados no digital.</p>
            </div>
          </div>
          <a href="/sobre" class="inline-flex items-center gap-2 px-6 py-3 bg-[#D9F45F] text-[#0f0f0f] font-medium rounded-md hover:bg-[#c5e04f] transition-colors min-h-[44px]">
            Saiba mais sobre nós
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 md:py-24 bg-[#131212] relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-40 bg-[#D9F45F]" style="clip-path: polygon(0 0, 100% 0, 100% 60%, 0 100%);" />
    <div class="relative z-10 max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="inline-block text-[#D9F45F] text-sm font-medium mb-2">Nossos diferenciais</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Transformando negócios em <span class="text-[#D9F45F]">histórias de sucesso digital</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
        {['Estratégia de Marca', 'Web Design', 'Marketing Digital', 'Criação de Conteúdo', 'Automação de E-mail'].map((title, i) => (
          <a href="/servicos" class="block p-6 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 transition-colors group">
            <div class="w-12 h-12 mb-4 rounded-lg bg-[#D9F45F]/20 flex items-center justify-center text-[#D9F45F]">◆</div>
            <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors">{title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
