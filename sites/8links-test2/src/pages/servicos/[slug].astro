---
/**
 * servicos/[slug].astro – Detalhes de serviço (PROMPT 6)
 * Base: 2025-digilink-html-page-service-details.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-service-details.html';

export function getStaticPaths() {
  return [
    { params: { slug: 'consultoria' } },
    { params: { slug: 'branding' } },
    { params: { slug: 'web-design' } },
    { params: { slug: 'marketing-digital' } },
  ];
}

const { slug } = Astro.params;
const servicos: Record<string, { titulo: string; desc: string }> = {
  consultoria: { titulo: 'Consultoria', desc: 'Consultoria especializada em posicionamento digital, estratégia de conteúdo e análise de dados para alavancar seus resultados.' },
  branding: { titulo: 'Branding', desc: 'Criamos identidades visuais memoráveis: logo, manual de marca e posicionamento que diferenciam sua empresa no mercado.' },
  'web-design': { titulo: 'Web Design & Desenvolvimento', desc: 'Sites modernos, responsivos e otimizados. Do design à implementação.' },
  'marketing-digital': { titulo: 'Marketing Digital', desc: 'Estratégias completas: SEO, redes sociais, Google Ads e conteúdo para sua presença digital.' },
};
const s = servicos[slug ?? ''] ?? { titulo: slug ?? 'Serviço', desc: 'Serviço da 8links.' };
---

<BaseLayout title={s.titulo} description={s.desc}>
  <PageTitle title={s.titulo} subtitle={`Início / Serviços / ${s.titulo}`} image={`/reference/${ref}/images/img-010.jpg`} />

  <section class="py-16 px-4 bg-[#0f0f0f]">
    <div class="max-w-4xl mx-auto">
      <img src={`/reference/${ref}/images/img-003.jpg`} alt={s.titulo} class="w-full rounded-lg object-cover max-h-[400px] mb-8" />
      <p class="text-white/80 text-lg">{s.desc}</p>
      <a href="/sobre" class="inline-flex items-center gap-2 mt-8 px-6 py-3 bg-[#D9F45F] text-[#0f0f0f] font-medium rounded-md hover:bg-[#c5e04f] transition-colors min-h-[44px]">
        Fale conosco
      </a>
      <a href="/servicos" class="inline-flex items-center gap-2 mt-4 ml-4 text-[#D9F45F] hover:underline min-h-[44px] items-center">
        ← Voltar aos serviços
      </a>
    </div>
  </section>
</BaseLayout>
