---
/**
 * projetos/index.astro – Listagem de projetos (PROMPT 3)
 * Base: 2025-digilink-html-page-projects.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-projects.html';

const projetos = [
  { slug: 'projeto-1', title: 'Projeto Digital 1', tags: ['Branding', 'UI/UX'] },
  { slug: 'projeto-2', title: 'Projeto Digital 2', tags: ['Design', 'Web'] },
  { slug: 'projeto-3', title: 'Projeto Digital 3', tags: ['Marketing', 'Branding'] },
  { slug: 'projeto-4', title: 'Projeto Digital 4', tags: ['UI/UX', 'Design'] },
  { slug: 'projeto-5', title: 'Projeto Digital 5', tags: ['Branding', 'Web'] },
];

const images = ['img-005', 'img-006', 'img-007', 'img-008', 'img-009'] as const;
---

<BaseLayout title="Nossos Projetos" description="Portfólio de projetos da 8links: branding, UI/UX e design digital.">
  <PageTitle title="Nossos Projetos" subtitle="Início / Projetos" image={`/reference/${ref}/images/img-013.jpg`} />

  <section class="py-16 md:py-24 px-4 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projetos.map((p, i) => (
          <a href={`/projetos/${p.slug}`} class="group block rounded-xl overflow-hidden bg-[#131212] border border-white/10 hover:border-[#D9F45F]/50 transition-all">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={`/reference/${ref}/images/${images[i]}.jpg`}
                alt={p.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="p-6">
              <ul class="flex flex-wrap gap-2 mb-2">
                {p.tags.map((t) => (
                  <li class="text-xs text-[#D9F45F]">{t}</li>
                ))}
              </ul>
              <h3 class="font-bold text-white group-hover:text-[#D9F45F] transition-colors">{p.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
