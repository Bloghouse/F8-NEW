---
/**
 * projetos/[slug].astro – Detalhes de projeto (PROMPT 4)
 * Base: 2025-digilink-html-page-project-details.html
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/PageTitle.astro';
const ref = '2025-digilink-html-page-project-details.html';

export function getStaticPaths() {
  return [
    { params: { slug: 'projeto-1' } },
    { params: { slug: 'projeto-2' } },
    { params: { slug: 'projeto-3' } },
    { params: { slug: 'projeto-4' } },
    { params: { slug: 'projeto-5' } },
  ];
}

const { slug } = Astro.params;
const titulos: Record<string, string> = {
  'projeto-1': 'Projeto Digital 1',
  'projeto-2': 'Projeto Digital 2',
  'projeto-3': 'Projeto Digital 3',
  'projeto-4': 'Projeto Digital 4',
  'projeto-5': 'Projeto Digital 5',
};
const title = titulos[slug ?? ''] ?? slug;
---

<BaseLayout title={title} description={`Projeto ${title} - 8links Agência Digital`}>
  <PageTitle title={title} subtitle={`Início / Projetos / ${title}`} image={`/reference/${ref}/images/img-010.jpg`} />

  <section class="py-16 px-4 bg-[#0f0f0f]">
    <div class="max-w-4xl mx-auto">
      <p class="text-white/80 text-lg mb-8">
        Este projeto demonstra nossa abordagem em design e branding. Combinamos estratégia visual com experiência do usuário para criar soluções que impactam.
      </p>
      <img src={`/reference/${ref}/images/img-003.jpg`} alt={title} class="rounded-lg w-full max-h-[400px] object-cover mb-8" />
      <p class="text-white/80 mb-8">
        Trabalhamos em estreita colaboração com o cliente para entender suas necessidades e entregar resultados que superam expectativas.
      </p>
      <a href="/projetos" class="inline-flex items-center gap-2 text-[#D9F45F] hover:underline min-h-[44px] items-center">
        ← Voltar aos projetos
      </a>
    </div>
  </section>
</BaseLayout>
