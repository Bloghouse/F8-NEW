---
/**
 * PageTitle.astro – Hero de página interna com título e breadcrumb
 */
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}

const { title, subtitle, image = 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1920&h=600&fit=crop' } = Astro.props;
---

<section class="relative min-h-[200px] flex items-center justify-center bg-cover bg-center" style={`background-image: url(${image})`}>
  <div class="absolute inset-0 bg-black/60" />
  <div class="relative z-10 text-center px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{title}</h1>
    {subtitle && <p class="text-white/80 text-sm">{subtitle}</p>}
  </div>
</section>
