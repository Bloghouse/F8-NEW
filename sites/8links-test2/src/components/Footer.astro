---
/**
 * Footer.astro – Rodapé do site
 */
import { siteConfig } from '../config';
---

<footer class="bg-[#131212] text-white/90">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <a href="/" class="text-2xl font-bold text-[#D9F45F] block mb-4">8links</a>
        <p class="text-sm text-white/70 mb-6 max-w-xs">
          Através de análise crítica e inquietude criativa, transformamos complexidades em experiências digitais memoráveis.
        </p>
      </div>
      <div>
        <h3 class="font-bold text-white mb-4">Links Rápidos</h3>
        <ul class="space-y-2">
          {siteConfig.footerNav.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-[#D9F45F] transition-colors min-h-[44px] flex items-center">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-white mb-4">Contato</h3>
        <ul class="space-y-3">
          <li><a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-white/70 hover:text-[#D9F45F] min-h-[44px] flex items-center">{siteConfig.phone}</a></li>
          <li><a href={`mailto:${siteConfig.email}`} class="text-white/70 hover:text-[#D9F45F] min-h-[44px] flex items-center">{siteConfig.email}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-white/10">
      <p class="text-sm text-white/60">© {new Date().getFullYear()} 8links. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
